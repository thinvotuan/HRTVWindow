        <td style="text-align: right">@String.Format("{0:###,##0}", ls.Sum(d=>d.truyLanh))</td>
        <td style="text-align: right">@String.Format("{0:###,##0}", ls.Sum(d=>d.thucLanh))</td>
    </tr>
}*@
