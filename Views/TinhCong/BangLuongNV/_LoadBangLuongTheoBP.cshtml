        <td style="text-align: right">@String.Format("{0:###,##0}", item.thue)</td>
        <td style="text-align: right">@String.Format("{0:###,##0}", item.truyThu)</td>
        <td style="text-align: right">@String.Format("{0:###,##0}", item.truyLanh)</td>
        <td style="text-align: right">@String.Format("{0:###,##0}", item.thucLanh)</td>
    </tr>
    }
    
    <tr style="background: #a94442; color: #ffec61; font-weight: bold;">
        <td align="center" colspan="4">Tổng cộng
        </td>
        <td style="text-align: right">@String.Format("{0:###,##0}", ls.Sum(d=>d.tongLuong))</td>
        <td style="text-align: right">@String.Format("{0:###,##0}", ls.Sum(d=>d.baoHiem))</td>

        <td style="text-align: right">@String.Format("{0:###,##0}", ls.Sum(d=>d.thue))</td>
