                            </div>
                        </td>
                        <td style="text-align: right; font-size: large;">
                            <b>@String.Format("{0:###,##0}", (double)(item.phuCapKhac + item.truyLanh - item.truyThu))</b></td>
                    </tr>

                    <tr>
                        <td></td>
                        <td style="">Tiền ăn giữa ca:</td>
