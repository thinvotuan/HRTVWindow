                    </tr>                   
                    <tr>
                        <td colspan="2">

                            <div class="form-group bs-callout bs-callout-info" style="overflow: hidden; margin-bottom: 1px;">
                                <h4 class="col-md-12 tieudeGroup" style="color: #1b809e"><b>3.</b> Chờ việc<span style="color: red; font-style: italic"></span></h4>
                            </div>
                        </td>
                        <td style="text-align: right; font-size: large;">
                            <b></b></td>
                    </tr>
                       <tr>
                        <td></td>
