                    </tr>
                    <tr>
                        <td></td>
                        <td style="">Tiền điện thoại:</td>
                        <td style="">@String.Format("{0:###,##0}", (double)item.truyThu)</td>
                    </tr>

                    <tr>
                        <td colspan="2">
                            <div class="form-group bs-callout bs-callout-info" style="overflow: hidden; margin-bottom: 1px;">
                                <h4 class="col-md-12 tieudeGroup" style="color: #1b809e"><b>5.</b> Các khoản khấu trừ<span style="color: red; font-style: italic"></span></h4>
                            </div>
                        </td>
                        <td style="text-align: right; font-size: large;"></td>
                    </tr>
                    <tr>
                        <td></td>
                        <td style="">BHXH (10.5%):</td>
                        <td style="">@String.Format("{0:###,##0}", (double)item.baoHiem)</td>
                    </tr>
                    <tr>
                        <td></td>
                        <td style="">BHYT (10.5%):</td>
                        <td style="">@String.Format("{0:###,##0}", (double)item.baoHiem)</td>
                    </tr>
                    <tr>
                        <td></td>
                        <td style="">BHTN (10.5%):</td>
                        <td style="">@String.Format("{0:###,##0}", (double)item.baoHiem)</td>
                    </tr>
                    <tr>
                        <td></td>
                        <td style="font-size: 15px">Thuế TNCN tháng:</td>
                        <td style="">@String.Format("{0:###,##0}", (double)item.thue)</td>
                    </tr>
                    <tr>
                        <td></td>
                        <td style="font-size: 15px">Đoàn phí:</td>
                        <td style="">@String.Format("{0:###,##0}", (double)item.thue)</td>
                    </tr>
                    <tr>
                        <td></td>
                        <td style="font-size: 15px">Đảng phí:</td>
                        <td style="">@String.Format("{0:###,##0}", (double)item.thue)</td>
                    </tr>

                    <tr>
                        <td colspan="2">
                            <div class="form-group bs-callout bs-callout-info" style="overflow: hidden; margin-bottom: 1px;">
                                <h4 class="col-md-12 tieudeGroup" style="color: #1b809e"><b>6.</b> Phụ Cấp Khác Và Truy Lĩnh<span style="color: red; font-style: italic"></span></h4>
                            </div>
                        </td>
                        <td style="text-align: right; font-size: large;">
                            <b>@String.Format("{0:###,##0}", (double)(item.phuCapKhac + item.truyLanh - item.truyThu))</b></td>
                    </tr>

                    <tr>
                        <td></td>
                        <td style="">Phụ cấp khác:</td>
                        <td style="">@String.Format("{0:###,##0}", (double)item.phuCapKhac)</td>

                    </tr>
                    <tr>
                        <td></td>
                        <td style="">Truy thu:</td>
                        <td style="">@String.Format("{0:###,##0}", (double)item.truyThu)</td>
                    </tr>

                    <tr>
                        <td colspan="2">
                            <div class="form-group bs-callout bs-callout-info" style="overflow: hidden; margin-bottom: 1px;">
                                <h4 class="col-md-12 tieudeGroup" style="color: #1b809e"><b>7.</b> Thực Nhận Lương Tháng @item.thang.@item.nam (C-D+E)<span style="color: red; font-style: italic"></span></h4>
                            </div>

                        </td>
                        <td style="text-align: right; font-size: large;">
                            <b>@String.Format("{0:###,##0}", (double)item.thucLanh)</b></td>
                    </tr>
                </table>
            </div>           
        </div>

    </fieldset>

</div>
