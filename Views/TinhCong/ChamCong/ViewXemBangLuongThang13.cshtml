@using BatDongSan.Models.NhanSu;
@model IPagedList<sp_NS_BangLuongThang13_IndexResult>
@{
    int i = 1;
    var checkDuyet = ViewBag.checkDuyet;
}
<script>
    function beginPaging(args) {
        // Animate        
        $('#content').fadeOut('fast');
    }

    function successPaging() {
        // Animate
        $('#content').fadeIn('normal');
    }

    function failurePaging() {
        alert("Không thể tải dữ liệu");
    }

</script>

@{
    BatDongSan.Models.HeThong.Sys_User user1 = new BatDongSan.Models.HeThong.Sys_User();
    if (Session["User"] != null)
    {
        user1 = (BatDongSan.Models.HeThong.Sys_User)Session["User"];
    }
}
<table class="table table-striped table-hover table-condensed" id="maintable">
    <thead>
        <tr>
            <th style="width: 35px">STT</th>
            <th style="width: 120px">Số phiếu</th>
            <th style="width: 110px">Nhân viên</th>
            <th style="width: 135px">Phòng ban</th>
            <th style="width: 50px">Năm</th>
            <th style="width: 80px">Lương tháng 13</th>
            <th style="width: 180px">Lý do</th>
            
        </tr>
    </thead>
    <tbody id="load">


        @{
            if (checkDuyet == 1)
            {
                if (Model != null)
                {

                    foreach (var item in Model)
                    {
            <tr>
                <td style="text-align: center">@i</td>
                <td>
                    <i class="fa fa-clipboard"></i><a style="color:blue" href="@Url.Action("Details", "PhieuTamUng", new { id = item.soPhieu })">@item.soPhieu</a>
                    <br />
                    <i class="fa fa-user"></i>@item.nguoiLap
                    <br />
                    <i class="fa fa-calendar" aria-hidden="true"></i>@String.Format("{0: dd/MM/yyyy}", item.ngayLap)
                </td>
                <td>
                    <i class="fa fa-user"></i>@item.hoTenNhanVien
                </td>
                <td>@item.tenPhongBan
                    <br />
                    <i class="fa fa-ticket" aria-hidden="true"></i>@item.TenChucDanh
                </td>
                <td style="text-align: center">@item.nam</td>
                <td style="text-align: right">
                    @String.Format("{0:#,##0}", item.luongThang13)
                </td>
                <td>@Html.Raw(item.ghiChu)</td>

               
            </tr> 
                        i++;
                    }
                }
            }}
    </tbody>
</table>
