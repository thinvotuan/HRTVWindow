                            Tháng:@Html.DropDownList("thang", ViewData["lstThang"] as SelectList, new { @style = "width:150px" })
                            Năm:@Html.DropDownList("nam", ViewData["lstNam"] as SelectList, new { @style = "width:150px" })



                        </div>
                        <div style="float: right">
                            <input type="text" id="qSearch" value="@ViewBag.Search" class="form-control" style="width:150px;float:left;margin-right:5px" placeholder="Nhập giá trị tìm kiếm" onkeypress="enterToSeacrh(event);" />
                            <button class="btn btn-info" id="btnSearch" type="button" style="float: left; margin-left: 2px">Tìm kiếm</button>
                            <button class="btn btn-info" id="btnTinhCCChiTiet" type="button" style="float: left; margin-left: 10px !important">Tính Công </button>
                            <button class="btn btn-info" type="button" style="float: left; margin-left: 10px !important; min-width: 145px;" onclick="ProgressXuatTheoBP(this)">Xuất File theo bộ phận</button>
                            <button class="btn btn-info" type="button" style="float: left; margin-left: 10px !important; min-width: 145px;" onclick="ProgressXuatChiTiet(this)">Xuất file chi tiết giờ quét</button>

                        </div>

                    </div>
                </div>
            </div>
            <div class="infor_CCChiTiet" style="display: none"></div>
            <table style="width: 100%" class="table table-striped table-hover table-condensed tableThemeCustome">

                <thead>
                    <tr>
                        <th style="width: 35px; text-align: center">STT
                        </th>
                        <th style="text-align: center">Nhân viên
                        </th>

                        <th style="text-align: center">Mã vân tay
                        </th>

                        <th style="text-align: center">Ngày quét</th>
                        <th style="text-align: center">Tên ngày</th>

                        <th style="text-align: center">Giờ vào</th>
                        <th style="text-align: center">Giờ ra</th>
                        <th style="text-align: center">Loại</th>
                        <th style="text-align: center">Số giờ công</th>



                    </tr>
                </thead>
                <tbody id="tbody">
                </tbody>


            </table>
        </div>
        <div class="contentToggle" style="display: none">
            <div id="filter-panel" class="collapse filter-panel" style="display: block; position: relative">
                <div class="panel panel-default background_top">
                    <div class="panel-body">
                        <div style="line-height: 26px; float: left">
                            Tháng:@Html.DropDownList("thangtc", ViewData["lstThang"] as SelectList, new { @style = "width:120px" })
                            Năm:@Html.DropDownList("namtc", ViewData["lstNam"] as SelectList, new { @style = "width:120px" })

                        </div>
                        <div class="form-group" id="phongban-div" style="float: left">

                            <div class="dropdown">
                                <button class="btn btn-primary btn-sm dropdown-toggle" id="btnPhongBan" type="button" data-toggle="dropdown">
                                    Danh sách phòng ban&nbsp;<span class="caret"></span>
                                </button>
                                <ul class="dropdown-menu" id="phongban-dropdown-menu">
                                    <li role="presentation">
                                        <div class="form-group has-feedback" style="width: 90%; margin: 5px auto !important; display: block;">
                                            <input type="text" class="form-control input-sm" id="txtsearch" placeholder="Search" style="width: 100%" />
                                            <span class="glyphicon glyphicon-search form-control-feedback"></span>
                                        </div>
                                    </li>
                                    <li role="presentation">
                                        @Html.Raw(ViewBag.PhongBans)
                                    </li>
                                </ul>
                            </div>
                        </div>
                        <div style="float: right">
                            <input type="text" id="qSearchTC" value="@ViewBag.SearchTC" class="form-control" style="width:180px;float:left;margin-right:5px" placeholder="Nhập giá trị tìm kiếm" onkeypress="enterToSeacrhTC(event);" />
                            <button class="btn btn-info" id="btnSearchTC" type="button" style="float: left; margin-left: 2px">Tìm kiếm</button>

                            <button class="btn btn-info" id="btnTinhTHCT" type="button" style="float: left; margin-left: 10px !important">Tính Công</button>
                            <button class="btn btn-info" id="btnDuyetTongHopCong" type="button" style="float: left; margin-left: 10px !important; display: block;">Duyệt</button>
                            <button class="btn btn-info" type="button" style="float: left; margin-left: 10px !important; min-width: 145px;" onclick="ProgressXuatFileCongThang(this)">Xuất File</button>
                            @if ((string)ViewBag.Administrator == "true")
                            {
                                <button type="button" data-toggle="modal" data-target="#importModal" class="btn btn-info">Import file</button>
                            }
                        </div>

                    </div>
                </div>
            </div>
            <div class="infor_THCT" style="display: none"></div>
            <div class="infor_DuyetTongHopCong" style="display: none"></div>
            <table style="width: 100%" class="table table-striped table-hover table-condensed tableThemeCustome">

                <thead>
                    <tr>
                        <th style="width: 35px; text-align: center">STT
                        </th>
                        <th style="text-align: center">Nhân viên 
                        </th>


                        <th style="text-align: center">Phòng ban<br />
                            chức vụ
                        </th>
                        <th style="text-align: center">Công chuẩn
                        </th>
                        <th style="text-align: center">Số ngày quét</th>
                        <th style="text-align: center">Công tác</th>
                        <th style="text-align: center">Nghỉ phép năm</th>
                        <th style="text-align: center">Nghỉ bù</th>
                        <th style="text-align: center">Nghỉ khác hưởng lương</th>
                        <th style="text-align: center">Nghỉ phép<br />
                            không lương</th>
                        <th style="text-align: center">Nghỉ lễ</th>

                        <th style="text-align: center">TC thường</th>
                        <th style="text-align: center">TC chủ nhật</th>
                        <th style="text-align: center">TC nghỉ lễ</th>

                        <th style="text-align: center">Lũy kế<br />
                            tháng trước</th>
                        <th style="text-align: center"><b>Tổng cộng</b></th>
                        <th style="text-align: center"><b>Tổng công điều chỉnh</b></th>

                    </tr>
                </thead>
                <tbody id="tbodyTC">
                </tbody>


            </table>


        </div>
        <div class="contentToggle" style="display: none">
            <div id="filter-panel" class="collapse filter-panel" style="display: block; position: relative">
                <div class="panel panel-default background_top">
                    <div class="panel-body">


                        <div style="line-height: 26px; float: left">
                            Từ ngày:@Html.DropDownList("TuNgay", ViewData["TuNgay"] as SelectList, new { @style = "width:150px" })-
                            Đến ngày:@Html.DropDownList("DenNgay", ViewData["DenNgay"] as SelectList, new { @style = "width:150px" })
                            Tháng:@Html.DropDownList("thangImport", ViewData["lstThang"] as SelectList, new { @style = "width:150px" })
                            Năm:@Html.DropDownList("namImport", ViewData["lstNam"] as SelectList, new { @style = "width:150px" })

                        </div>

                        <div style="float: right">

                            <button class="btn btn-info" id="btnImportDuLieuVanTay" type="button" style="float: left; margin-left: 10px !important">Import dữ liệu chấm công</button>
                        </div>

                    </div>
                </div>
            </div>
            <div class="infor_VanTay" style="display: none"></div>
            <div class="list-group" style="max-width: 600px; margin-top: 200px;">
                <a href="#" class="list-group-item disabled">Ghi chú
                </a>
                <a href="#" class="list-group-item">Vui lòng chọn: ngày, tháng, năm cần import.</a>


            </div>
        </div>
    </div>
</fieldset>
<div id="importModal" class="modal fade" role="dialog">
    <div class="modal-dialog modal-lg">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title"></h4>
            </div>
            <div class="modal-body">
                <div class="container" style="width: 100%">
                    <div class="row">
                        <div id="import-panel" class="filter-panel">
                            <div id="dialog" class="alert alert-info" style="display: none">
                                <strong>Thông báo!</strong> File đính kèm không đúng định dạng.  
                            </div>
                            <h4>Tải về mẫu phiếu nhập thông tin dữ liệu chấm công từ file: </h4>
                            <button class="btn btn-link btn-sm" id="btnDownload"><i style="color: #2e6da4" class="fa fa-download" aria-hidden="true"></i></button>
                            <h4>Chọn file dữ liệu (*.xlsx, *.xls)</h4>
                            <div class="panel panel-default">
                                <input type="file" id="fileImport" name="fileImport" value="Chọn file" style="border: none" />
                            </div>
                            <div class="panel panel-default" style="float: right">
                                <button type="button" id="btnSaveImport" class="btn btn-primary">Lưu</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
