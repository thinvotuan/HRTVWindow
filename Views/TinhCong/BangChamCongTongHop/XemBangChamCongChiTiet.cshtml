<script type="text/javascript">
    $(document).ready(function () {
        $("#navigation1").treeview({
            persist: "location",
            unique: false,
            collapsed: true
        }).find(".expandable-hitarea").click();
        $("#btnSearchTC").click(function () {
            $(".infor_THCT,.infor_CCChiTiet,.infor_DuyetTongHopCong").html('').css('display', 'none');
            SearchTC();
        });
        $("#thangtc,#namtc").change(function () {
            $(".infor_THCT,.infor_CCChiTiet,.infor_DuyetTongHopCong").html('').css('display', 'none');
            SearchTC();
        });
        $(document).on("click", "#phongban-dropdown-menu li a", function () {
            $("#btnPhongBan").val(this.id);

            $(this).parents(".dropdown").find('.btn').html($(this).text() + ' &nbsp;<span class="caret"></span>');
            SearchTC();
        })
        $('ul.dropdown-menu .hitarea').on('click', function (event) {
            event.stopPropagation();
        });
        $('#txtsearch').on("input", function () {
            $('#navigation1').filterLink($('#txtsearch').val());
        });
        $("#phongban-dropdown-menu").removeAttr("style");





        SearchTC();
        $(document).on('click', '#btnTinhTHCT', function () {
            var imageUrl = '<div id="divMsg" align="center"><img src="@Url.Content("~/Content/Images/loading.gif") "/></div>';
            $('.infor_THCT').html(imageUrl).css('display', 'block');
            $.ajax({

                type: "POST",
                url: '@Url.Action("UpdateBangChamCongTH", "BangChamCongTongHop")',
                data: {
                    'nam': $("#namtc").val(),
                    'thang': $("#thangtc").val()

                },
                success: function (result) {
                    $(".infor_THCT").css('display', 'block');

                    if (result.kq == true) {
                        $(".infor_THCT").html('Cập nhật thành công tháng: ' + $("#thangtc").val() + " năm: " + $("#namtc").val());
                    }
                    else {
                        $(".infor_THCT").html('Cập nhật thất bại tháng: ' + $("#thangtc").val() + " năm: " + $("#namtc").val());
                    }

                    SearchTC();
                }
            });
        });
        $(document).on('click', '#btnDuyetTongHopCong', function () {
            $.ajax({
                type: "POST",
                url: "/BangChamCongTongHop/CheckDuyetTongHopCong",
                data: {
                    thang: $("#thangtc").val(),
                    nam: $("#namtc").val()
                },
                success: function (result) {
                    if (result.kq == false) {
                        //
                        bootbox.confirm("Bạn có chắc chắn duyệt công tháng này không? Sau khi duyệt nhân viên sẽ thấy tổng hợp công.", function (result) {
                            if (result) {
                                var imageUrl = '<div id="divMsg" align="center"><img src="/Content/Images/loading.gif "/></div>';
                                $('.infor_DuyetTongHopCong').html(imageUrl).css('display', 'block');
                                $.ajax({

                                    type: "POST",
                                    url: '/BangChamCongTongHop/DuyetTongHopCongNV',
                                    data: {
                                        'nam': $("#namtc").val(),
                                        'thang': $("#thangtc").val()

                                    },
                                    success: function (result) {
                                        $(".infor_DuyetTongHopCong").css('display', 'block');

                                        if (result.kq == true) {
                                            $(".infor_DuyetTongHopCong").html('Đã duyệt tổng hợp công nhân viên tháng: ' + $("#thangtc").val() + " năm: " + $("#namtc").val());
                                        }
                                        else {
                                            $(".infor_DuyetTongHopCong").html('Duyệt tổng hợp công nhân viên thất bại tháng: ' + $("#thangtc").val() + " năm: " + $("#namtc").val());
                                        }

                                        SearchTC();
                                    }
                                });
                            }
                        });
                    }
                    else {
                        $(".infor_DuyetTongHopCong").css('display', 'block');
                        $(".infor_DuyetTongHopCong").html('Đã duyệt công tháng: ' + $("#thangtc").val() + " năm: " + $("#namtc").val());
                    }
                }
            });
            //

        });

        $(document).on("blur", "[name=congDieuChinh]", function () {
            var parent = $(this).closest("tr");
            var maNhanVienDieuChinh = parent.find("[name='maNhanVienDieuChinh']").val();
            var thangDieuChinh = parent.find("[name='thangDieuChinh']").val();
            var namDieuChinh = parent.find("[name='namDieuChinh']").val();
            var congDieuChinh = parent.find("[name='congDieuChinh']").val();
            $.ajax({
                type: "POST",
                url: '/BangChamCongTongHop/DieuChinhCong/',
                data: {
                    maNhanVienDieuChinh: maNhanVienDieuChinh, thangDieuChinh: thangDieuChinh, namDieuChinh: namDieuChinh, congDieuChinh: congDieuChinh
                },
                success: function (result) {
                    if (result == "Error") {
                        Alert.warning("Điều chỉnh công thất bại!", "Thông báo", { displayDuration: 2000 });
                    }
                }
            });
        });

        $(document).on('click', '#btnDownload', function () {
            var giatri = $("#qSearchTC").val().trim();
            var maPhongBan = $("#btnPhongBan").val().trim();
            maPhongBan = maPhongBan.replace(/ /gi, '+');
            var url = "/BangChamCongTongHop/XuatFileBangTongHopCongThangMau" + '?thang=' + $("#thangtc").val() + "&nam=" + $("#namtc").val() + "&qSearch=" + giatri + "&maPhongBan=" + maPhongBan
            location.href = url;
        });

        $(document).on('click', '#btnSaveImport', function () {
            var obj = $(this);
            var button = $(obj).clone();
            $(obj).prop('disabled', true).html('<img src="/Images/progress.gif" />')
            var fd = new FormData();
            fd.append("fileToUpload", document.getElementById('fileImport').files[0]);
            $.ajax({
                url: "/BangChamCongTongHop/ImportFileTC" + '?thang=' + $("#thangtc").val() + "&nam=" + $("#namtc").val(),
                type: 'POST',
                dateType: 'json',
                data: fd,
                cache: false,
                contentType: false,
                processData: false,
                success: function (data) {
                    if (data.success == true) {
                        $(obj).replaceWith(button);
                        Alert.success("Lưu dữ liệu thành công", "Thông báo", { displayDuration: 2000 });
                        $("#fileImport").val("");
                        $("#btnSearchTC").click();
                    } else {
                        $(obj).replaceWith(button);
                        Alert.warning("Định dạng file không được hỗ trợ", "Thông báo", { displayDuration: 0 });
                        $("#fileImport").val("");
                    }
                },
                error: function (request, textStatus, errorThrown) {
                    Alert.error("Lưu không thành công", "Thông báo", { displayDuration: 0 });
                }
            })
        });


    });
    function OnCriteriaPCTC(page) {
        var giatri = $("#qSearchTC").val().trim();
        giatri = giatri.replace(/ /gi, '+');
        var url = '@Url.Action("LoadBangChamCongTongHop", "BangChamCongTongHop")' + "?thang=" + $("#thangtc").val() + "&nam=" + $("#namtc").val() + "&qSearch=" + giatri + "&_page=" + page;
        var imageUrl = '<div id="divMsgTC" align="center"><img src="@Url.Content("~/Content/Images/loading.gif") "/></div>';
        $('#tbodyTC').html(imageUrl);
        $('#tbodyTC').load(url, function () {
        });
    }

    function SearchTC() {

        var giatri = $("#qSearchTC").val().trim();
        giatri = giatri.replace(/ /gi, '+');
        var maPhongBan = $("#btnPhongBan").val().trim();
        maPhongBan = maPhongBan.replace(/ /gi, '+');


        var url = '@Url.Action("LoadBangChamCongTongHop", "BangChamCongTongHop")' + "?thang=" + $("#thangtc").val() + "&nam=" + $("#namtc").val() + "&qSearch=" + giatri + "&maPhongBan=" + maPhongBan + "&_page=0";

        var imageUrl = '<div id="divMsgTC" align="center"><img src="@Url.Content("~/Content/Images/loading.gif") "/></div>';
        $('#tbodyTC').html(imageUrl);
        $('#tbodyTC').load(url, function () {
        });
    }


    function ResetTC() {
        location.href = '@Url.Action("LoadBangChamCongTongHop", "BangChamCongTongHop")';
    }
    function enterToSeacrhTC(event) {
        if (event.keyCode == 13)
            $("#btnSearchTC").click();
    }
    function beginPaging() {
        // Animate        
        $('#content').fadeOut('fast');
    }
    function successPaging() {
        // Animate
        $('#content').fadeIn('fast');
    }

    function failurePaging() {
        alert("Không thể tải dữ liệu");
    }




</script>

