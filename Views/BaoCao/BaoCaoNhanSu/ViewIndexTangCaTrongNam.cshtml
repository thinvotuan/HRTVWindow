@using BatDongSan.Models.PhieuDeNghi;
@model IPagedList<sp_NS_TongSoGioTangCaResult>
@{
    int i = 1;
}
<script>
    function beginPaging(args) {
        // Animate        
        $('#content').fadeOut('fast');
    }

    function successPaging() {
        // Animate
        $('#content').fadeIn('normal');
    }

    function failurePaging() {
        alert("Không thể tải dữ liệu");
    }

</script>
<table class="table table-striped table-hover table-condensed" id="maintable">
    <thead>
        <tr>
            <th style="width: 45px">STT</th>
            <th style="width: 130px">Nhân viên</th>
            <th style="width: 200px">Phòng ban/Chức vụ</th>
            <th>Số giờ tăng ca</th>
            <th>Số ngày đã nghỉ bù</th>
            <th>Số giờ còn lại</th>
        </tr>
    </thead>
    <tbody id="load">

        @foreach (var item in Model)
        {
            <tr>
                <td style="text-align: center">@i</td>

                <td style="text-align: left"><a style="color:#519ee5" target="_blank" href="/NhanVien/Details/@item.maNhanVien">@item.maNhanVien</a><br />
                    <i class="fa fa-user" aria-hidden="true"></i>@item.hoTen</td>
                <td>@item.tenPhongBan<br />
                    <i class="fa fa-ticket" aria-hidden="true"></i>@item.TenChucDanh</td>
                
                <td style="text-align: right">@item.soGioTangCa</td>
                <td style="text-align: right">@item.soNgayNghiBu</td>        
                <td style="text-align: right">@item.soGioConLai</td>               
            </tr> 
            i++;
        }
    </tbody>
</table>
<div>
    Trang @Model.PageNumber của @Model.PageCount / @ViewBag.Count
</div>
<div>
    <ul class="pagination">
        @Html.Raw(Ajax.Pager(new AjaxOptions { UpdateTargetId = "content", OnBegin = "beginPaging", OnSuccess = "successPaging", OnFailure = "failurePaging" }, Model.PageSize, Model.PageNumber, Model.TotalItemCount, new { controller = "BaoCaoNhanSu", action = "BCTangCaTrongNam", searchString = ViewBag.searchString }))
    </ul>
</div>
