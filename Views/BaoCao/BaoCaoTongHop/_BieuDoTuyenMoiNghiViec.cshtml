@using BatDongSan.Models.NhanSu;
@{
    Layout = null;
}

<script>
    getDataTuyenMoiNghiViec();
    function getDataTuyenMoiNghiViec() {
      
        $.ajax({

            type: "POST",
            url: '@Url.Action("GetListBieuDoTuyenMoiNghiViec", "BaoCaoTongHop")',
            data: {
                thang: $("#thangTuyenMoi").val()

            },
            success: function (result) {
             
                if (result != null) {

                    // Load the Visualization API and the corechart package.
                    google.charts.load('current', { 'packages': ['corechart'] });

                    // Set a callback to run when the Google Visualization API is loaded.
                    google.charts.setOnLoadCallback(drawChart);

                    // Callback that creates and populates a data table,
                    // instantiates the pie chart, passes in the data and
                    // draws it.
                    function drawChart() {


                        var html = '';
                      
                        if (result.list != null) {

                          
                                //Detail_BieuDoTongNV
                                html += '<tr>';
                                html += '<td style="text-align:right">' + $.fn.autoNumeric.Format('formatSo', result.list[0].tuyenMoi)+ '</td>';
                                html += '<td style="text-align:right">' + $.fn.autoNumeric.Format('formatSo', result.list[0].nghiViec)  + '</td>';
                                html += '</tr>';
                                //End Detail_BieuDoTongNV
                                // Create the data table.
                                var data = new google.visualization.DataTable();
                                data.addColumn('string', 'Topping');
                                data.addColumn('number', 'Slices');
                                data.addRows([
                                  ['Tuyển mới', result.list[0].tuyenMoi]
                                ]);
                                data.addRows([
                                  ['Nghỉ việc', result.list[0].nghiViec]
                                ]);
                              
                              

                                // Set chart options
                                var options = {
                                    'title': '',
                                    'width': '100%',
                                    'height': 'auto',
                                    is3D: true,
                                };

                                // Instantiate and draw our chart, passing in some options.
                                var chart = new google.visualization.PieChart(document.getElementById('BieuDoTuyenMoiNV'));
                                chart.draw(data, options);
                            
                        }
                        $(".Detail_BieuDoTuyenMoiNV .showData").html(html);
                       
                    }
                    //Dong i code ajax
                }
            },
            error: function (error) {
                alert(error);
            }
        });



    }
</script>
<div id="BieuDoTuyenMoiNV"></div>
<div class="Detail_BieuDoTuyenMoiNV contentBieuDo">
    
    <div class="detail_BieuDo">
        <table class="table table-striped table-hover table-condensed">
            <thead>
                <tr>
                  <th>Tuyển mới</th>  
                    <th>Nghỉ việc</th>
                    
                </tr>
            </thead>
            <tbody class="showData">
               
            </tbody>
        </table>

    </div>
</div>
