@using BatDongSan.Models.NhanSu;
@{
    Layout = null;
}

<script>
    getDataBieuDoLuong();
    function getDataBieuDoLuong() {

        $.ajax({

            type: "POST",
            url: '@Url.Action("GetListBieuDoLuong", "BaoCaoTongHop")',
            data: {

            },
            success: function (result) {

                if (result != null) {

                    // Load the Visualization API and the corechart package.
                    google.charts.load('current', { 'packages': ['corechart'] });

                    // Set a callback to run when the Google Visualization API is loaded.
                    google.charts.setOnLoadCallback(drawChart);

                    // Callback that creates and populates a data table,
                    // instantiates the pie chart, passes in the data and
                    // draws it.
                    function drawChart() {


                        var html = '';
                        // Create the data table.
                        var data = new google.visualization.DataTable();
                        data.addColumn('string', 'Month');
                        data.addColumn('number', 'Thực lãnh');
                        data.addColumn('number', 'Trung Bình');
                        for (var i = 0; i < result.list.length; i++) {
                            html += '<tr>';
                            html += '<td style="text-align:center">' + result.list[i].thangNam + '</td>';
                            html += '<td style="text-align:right">' + $.fn.autoNumeric.Format('formatSo', result.list[i].thucLanh) + '</td>';
                            html += '</tr>';
                            data.addRows([
                             [result.list[i].thangNam, result.list[i].thucLanh, result.list[i].thucLanh]
                            ]);
                        }




                        // Set chart options
                        var options = {
                            title: '',
                            vAxis: { title: 'Giá trị' },
                            hAxis: { title: 'Month' },
                            seriesType: 'bars',
                            series: { 1: { type: 'line' } }
                        };

                        // Instantiate and draw our chart, passing in some options.
                        var chart = new google.visualization.ComboChart(document.getElementById('BieuDoLuong'));
                        chart.draw(data, options);
                        $(".Detail_BieuDoLuong .showData").html(html);

                    }

                }
                //Dong i code ajax

            },
            error: function (error) {
                alert(error);
            }
        });


    }
</script>
<div id="BieuDoLuong"></div>
<div class="Detail_BieuDoLuong contentBieuDo" id="show_BieuDoLuong">
    <div class="btnXemChiTiet"><i class="fa fa-arrow-circle-down" aria-hidden="true"></i>Xem chi tiết</div>
    <div class="detail_BieuDo" style="display: none">
        <table class="table table-striped table-hover table-condensed">
            <thead>
                <tr>
                    <th>Tháng/năm</th>
                    <th>Thực lãnh</th>

                </tr>
            </thead>
            <tbody class="showData">
            </tbody>
        </table>

    </div>
</div>
