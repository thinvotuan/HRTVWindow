@using BatDongSan.Models.NhanSu;
@{
    Layout = null;
}
<link href="~/Content/bootstrap-switch.css" rel="stylesheet">


<script>
    getDataTongSoNV();
    function getDataTongSoNV() {

        $.ajax({

            type: "POST",
            url: '@Url.Action("GetListBieuDoTongSoNV", "BaoCaoTongHop")',
            data: {

            },
            success: function (result) {

                if (result != null) {

                    // Load the Visualization API and the corechart package.
                    google.charts.load('current', { 'packages': ['corechart'] });

                    // Set a callback to run when the Google Visualization API is loaded.
                    google.charts.setOnLoadCallback(drawChart);

                    // Callback that creates and populates a data table,
                    // instantiates the pie chart, passes in the data and
                    // draws it.
                    function drawChart() {


                        var html = '';
                        var htmlMucLuong = '';
                        var htmlTuyenMoiNVThang = '';
                        var htmlTuyenMoiNVNam = '';
                        if (result.list != null) {


                            //Detail_BieuDoTongNV
                            html += '<tr>';
                            html += '<td style="text-align:right">' + $.fn.autoNumeric.Format('formatSo', result.list[0].soLuongTong) + '</td>';
                            html += '<td style="text-align:right">' + $.fn.autoNumeric.Format('formatSo', result.list[0].nu) + '</td>';
                            html += '<td style="text-align:right">' + $.fn.autoNumeric.Format('formatSo', result.list[0].nam) + '</td>';
                            html += '<td style="text-align:right">' + $.fn.autoNumeric.Format('formatSo', result.list[0].mucLuongTB) + '</td>';
                            html += '<td style="text-align:right">' + result.list[0].doTuongTB + '</td>';
                            html += '</tr>';
                            htmlMucLuong += '<li><i class="fa fa-star" aria-hidden="true"></i>Mức lương TB: ' + $.fn.autoNumeric.Format('formatSo', result.list[0].mucLuongTB) + '<li>';
                            htmlMucLuong += '<li><i class="fa fa-star" aria-hidden="true"></i>Độ tuổi TB: ' + result.list[0].doTuongTB + '<li>';

                            //End Detail_BieuDoTongNV
                            // TuyenMoiNghiViec
                            htmlTuyenMoiNVThang += '<ul>';
                            htmlTuyenMoiNVThang += '<li><i class="fa fa-times" aria-hidden="true"></i>Nghỉ việc: ' + result.listThang[0].nghiViec + ' NV<li>';
                            htmlTuyenMoiNVThang += '<li><i class="fa fa-plus" aria-hidden="true"></i>Tuyển mới: ' + result.listThang[0].tuyenMoi + ' NV<li>';
                            htmlTuyenMoiNVThang += '</ul>';
                            htmlTuyenMoiNVNam += '<ul>';
                            htmlTuyenMoiNVNam += '<li><i class="fa fa-times" aria-hidden="true"></i>Nghỉ việc: ' + result.listNam[0].nghiViec + ' NV<li>';
                            htmlTuyenMoiNVNam += '<li><i class="fa fa-plus" aria-hidden="true"></i>Tuyển mới: ' + result.listNam[0].tuyenMoi + ' NV<li>';
                            htmlTuyenMoiNVNam += '</ul>';
                            // End TuyenMoiNghiViec
                            // Create the data table.
                            var data = new google.visualization.DataTable();
                            data.addColumn('string', 'Topping');
                            data.addColumn('number', 'Slices');
                            data.addRows([
                              ['Nữ', result.list[0].nu]
                            ]);
                            data.addRows([
                              ['Nam', result.list[0].nam]
                            ]);



                            // Set chart options
                            var options = {
                                'title': 'Tổng số nhân viên',
                                'width': 300,
                                'height': 'auto',
                                is3D: true,
                            };

                            // Instantiate and draw our chart, passing in some options.
                            var chart = new google.visualization.PieChart(document.getElementById('BieuDoTongNV'));
                            chart.draw(data, options);

                        }
                        $(".Detail_BieuDoTongNV .showData").html(html);
                        $(".box_MLTuyenMoi").show();
                        $(".box_mucLuong ul").html(htmlMucLuong);
                        $("#trongThang").html(htmlTuyenMoiNVThang);
                        $("#trongNam").html(htmlTuyenMoiNVNam);
                    }
                    //Dong i code ajax
                }
            },
            error: function (error) {
                alert(error);
            }
        });



    }
</script>
<div class="wrapper_TongNV_MucLuong_TuyenMoi">
    <div id="BieuDoTongNV" class="box_TongNV"></div>
    <div class="box_MLTuyenMoi" style="display: none">
        <div class="box_mucLuong">
            <ul>
            </ul>
        </div>
        <div class="box_tuyenMoi">
            <div class="btnTitle">
                <input type="checkbox" name="my-checkbox" id="my-checkbox" checked>
            </div>
            <div class="showContent" id="trongThang">
            </div>
            <div class="showContent" id="trongNam" style="display: none">
            </div>
        </div>
    </div>
</div>

<div class="Detail_BieuDoTongNV contentBieuDo" id="show_BieuDoTongNV">
    <div class="btnXemChiTiet"><i class="fa fa-arrow-circle-down" aria-hidden="true"></i>Xem chi tiết</div>
    <div class="detail_BieuDo" style="display: none">
        <table class="table table-striped table-hover table-condensed">
            <thead>
                <tr>
                    <th>Số lượng tổng</th>
                    <th>Nữ</th>
                    <th>Nam</th>
                    <th>Mức lương TB</th>
                    <th>Độ tuổi trung bình</th>
                </tr>
            </thead>
            <tbody class="showData">
            </tbody>
        </table>

    </div>
</div>
<script src="~/Scripts/bootstrap-switch.js"></script>
<script type="text/javascript">

    $(document).ready(function () {


        $("[name='my-checkbox']").bootstrapSwitch();
        $(".bootstrap-switch-handle-on").html('Trong tháng');
        $(".bootstrap-switch-handle-off").html('Trong năm');
        $(".bootstrap-switch-handle-on").click(function () {

            if ($("#trongThang").css('display') == 'none') {
                $("#trongThang").show();
                $("#trongNam").hide();
            }
            else {

                $("#trongThang").hide();
                $("#trongNam").show();
            }
        });
        $(".bootstrap-switch-handle-off").click(function () {
            if ($("#trongThang").css('display') == 'none') {
                $("#trongThang").show();
                $("#trongNam").hide();
            }
            else {

                $("#trongThang").hide();
                $("#trongNam").show();
            }

        });
        $(".bootstrap-switch-label").click(function () {
            if ($("#trongThang").css('display') == 'none') {
                $("#trongThang").show();
                $("#trongNam").hide();
            }
            else {

                $("#trongThang").hide();
                $("#trongNam").show();
            }
        });

    });

</script>
