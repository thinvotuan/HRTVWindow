                            <div class="form-group bs-callout bs-callout-info" style="overflow: hidden; margin-bottom: 1px;">
                                <h4 class="col-md-12 tieudeGroup" style="color: #1b809e">Biểu đồ lương <span style="color: red; font-style: italic"></span></h4>
                            </div>
                        </div>
                        <div id="content_TuyenHopBieuDoLuong">
                        </div>

                    </div>
                    <div class="hetHan">
                        <div class="title_BieuDo">

                            <div class="form-group bs-callout bs-callout-info" style="overflow: hidden; margin-bottom: 1px;">
                                <h4 class="col-md-12 tieudeGroup" style="color: #1b809e">Hợp đồng sắp hết hạn <span style="color: red; font-style: italic"></span></h4>
                            </div>
                        </div>
                        <div id="content_HopDongSapHetHan">
                        </div>
                    </div>

                </div>
                <div class="rightWrap">
                    <div class="doTuoi">
                        <div class="title_BieuDo">

                            <div class="form-group bs-callout bs-callout-info" style="overflow: hidden; margin-bottom: 1px;">
                                <h4 class="col-md-12 tieudeGroup" style="color: #1b809e">Độ tuổi <span style="color: red; font-style: italic"></span></h4>
                            </div>
                        </div>
                        <div id="content_TongHopDoTuoi">
                        </div>

                    </div>
                    <div class="trinhDo">
                        <div class="title_BieuDo">

                            <div class="form-group bs-callout bs-callout-info" style="overflow: hidden; margin-bottom: 1px;">
                                <h4 class="col-md-12 tieudeGroup" style="color: #1b809e">Trình Độ <span style="color: red; font-style: italic"></span></h4>
                            </div>
                        </div>
                        <div id="content_TongHopTrinhDo">
                        </div>
                    </div>
                    <div class="binhquan">
                        <div class="title_BieuDo">

                            <div class="form-group bs-callout bs-callout-info" style="overflow: hidden; margin-bottom: 1px;">
                                <h4 class="col-md-12 tieudeGroup" style="color: #1b809e">Biểu đồ biến động nhân viên theo tháng <span style="color: red; font-style: italic"></span></h4>
                            </div>
                        </div>
                        <div id="content_BieuDoBienDongNVThang"></div>
                    </div>

                </div>
            </div>
        </div>
    </fieldset>
</div>

