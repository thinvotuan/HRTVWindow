@using BatDongSan.Models.NhanSu;
@{
    Layout = null;
}

<script>
    getDataBieuDoTuoi();
    function getDataBieuDoTuoi() {

        $.ajax({

            type: "POST",
            url: '@Url.Action("GetListBieuDoTuoi", "BaoCaoTongHop")',
            data: {

            },
            success: function (result) {

                if (result != null) {

                    // Load the Visualization API and the corechart package.
                    google.charts.load('current', { 'packages': ['corechart'] });

                    // Set a callback to run when the Google Visualization API is loaded.
                    google.charts.setOnLoadCallback(drawChart);

                    // Callback that creates and populates a data table,
                    // instantiates the pie chart, passes in the data and
                    // draws it.
                    function drawChart() {


                        var html = '';

                        if (result.list != null) {

                            // Create the data table.
                            var data = new google.visualization.DataTable();
                            data.addColumn('string', 'Topping');
                            data.addColumn('number', 'Slices');
                            //Detail_BieuDoTongNV
                            for (var i = 0; i < result.list.length; i++) {
                                html += '<tr>';
                                html += '<td style="text-align:center">' + result.list[i].tenDoTuoi + '</td>';
                                html += '<td style="text-align:right">' + result.list[i].soLuong + '</td>';
                                html += '</tr>';
                                data.addRows([
                                 [result.list[i].tenDoTuoi, result.list[i].soLuong]
                                ]);
                            }

                            //End Detail_BieuDoTongNV


                            // Set chart options
                            var options = {
                                'title': '',
                                'width': '100%',
                                'height': 'auto',
                                is3D: true,

                            };

                            // Instantiate and draw our chart, passing in some options.
                            var chart = new google.visualization.PieChart(document.getElementById('BieuDoDoTuoi'));
                            chart.draw(data, options);

                        }
                        $(".Detail_BieuDoDoTuoi .showData").html(html);

                    }
                    //Dong i code ajax
                }
            },
            error: function (error) {
                alert(error);
            }
        });



    }
</script>
<div id="BieuDoDoTuoi"></div>

<div class="Detail_BieuDoDoTuoi contentBieuDo" id="show_BieuDoDoTuoi">
    <div class="btnXemChiTiet"><i class="fa fa-arrow-circle-down" aria-hidden="true"></i>Xem chi tiết</div>
    <div class="detail_BieuDo" style="display: none">

        <table class="table table-striped table-hover table-condensed">
            <thead>
                <tr>
                    <th>Tên độ tuổi</th>
                    <th>Số lượng</th>

                </tr>
            </thead>
            <tbody class="showData">
            </tbody>
        </table>

    </div>
</div>
