                    @*<td>Loại công tác</td>
                    <td>
                        @Html.RadioButtonFor(model => model.loaiCongTac, false, new { @id = "rad-1", @style = "width:auto",@checked=true }) Trong nước @Html.RadioButtonFor(model => model.loaiCongTac, true, new { @id = "rad-2", style = "width:auto" }) Nước ngoài

                    </td>*@
                </tr>
                <tr>
                    <td class="tdtitle">Ngày lập</td>
                    <td>@Html.TextBoxFor(model => model.ngayLap, "{0: dd/MM/yyyy}", new { @class = "form-control datepicker", @readonly = "readonly" })</td>
                    <td class="tdtitle">Ngày tăng ca</td>
                    <td>@Html.TextBoxFor(model => model.ngayTangCa, "{0: dd/MM/yyyy}", new { @class = "form-control datepicker" })</td>
                </tr>
                <tr>
                    <td class="tdtitle">Giờ bắt đầu</td>
                    <td>@Html.TextBoxFor(model => model.gioBatDau, new { @class = "form-control", required = "required" })</td>
                    <td class="tdtitle">Giờ kết thúc</td>
                    <td>@Html.TextBoxFor(model => model.gioKetThuc, new { @class = "form-control", required = "required" })</td>
                </tr>

                <tr>

                    <td class="tdtitle">Số giờ tăng ca</td>
                    <td>@Html.TextBoxFor(model => model.soGioTangCa, new { @class = "form-control", @readonly = "readonly" })
                        <input type="hidden" id="soGioTangCaHidden" name="soGioTangCaHidden" />
                    </td>
                    <td class="tdtitle">Loại tăng ca</td>
                    <td>@Html.DropDownListFor(model => model.maLoaiTangCa, ViewBag.LoaiTangCa as SelectList, new { @class = "form-control", required = "required" })</td>
                </tr>
                <tr>
                    <td class="tdtitle">Hình thức tăng ca <span style="font-style: italic; float: right; color: red">*</span></td>
                    <td>
                        <label class="radio-inline" style="font-size: 13px">
                            @Html.RadioButtonFor(model => model.hinhThucTangCa, "tcnb", new { style = "width:auto", required = "required" }) Tăng ca nghỉ bù
                        </label>
                        <label class="radio-inline" style="font-size: 13px">
                            @Html.RadioButtonFor(model => model.hinhThucTangCa, "tctl", new { style = "width:auto", required = "required" }) Tăng ca tính lương
                        </label>
                    </td>


                </tr>

                <tr>
                    <td class="tdtitle">Bắt đầu nghỉ giữa ca</td>
                    <td>@Html.TextBoxFor(model => model.thoiGianNghiGiuaCa, new { @class = "form-control" })</td>
                    <td class="tdtitle">Kết thúc nghỉ giữa ca</td>
                    <td>@Html.TextBoxFor(model => model.thoiGianNghiKetThucGiuaCa, new { @class = "form-control" })</td>
                </tr>


                <tr>
                    <td class="tdtitle">Hệ số tăng ca</td>
                    <td>@Html.TextBoxFor(model => model.heSoTangCa, new { @class = "form-control numberinput", @readonly = "readonly", data_v_max = "999" })</td>

                    <td class="tdtitle">Thời gian nghỉ giữa ca (phút)</td>
                    <td>@Html.TextBoxFor(model => model.soGioNghiGiuaCa, new { @class = "form-control numberinputInt", @readonly = "readonly" })

                        <input type="hidden" id="timeNghiGiuaCaHidden" name="timeNghiGiuaCaHidden" />
                    </td>
                </tr>
                <tr>
                    <td class="tdtitle">Nội dung tăng ca</td>
                    <td colspan="3">
                        <div id="editor"></div>
                        @Html.HiddenFor(model => model.ghiChu, new { @class = "form-control" })
                    </td>

                </tr>
            </table>
            <br />
            <label>
                @*<button class="btn btn-link btn-sm" id="btnNhanVien" type="button" data-toggle="modal" data-target="#myModal">Thêm nhân viên</button>*@
                <button class="btn btn-link btn-sm" id="btnNhanVien" type="button">Thêm nhân viên</button>
            </label>
            <div id="containerNhanVien">
                <table class="table table-striped table-hover table-condensed" id="tbl-users">
                    <thead>
                        <tr id="trtop">
                            <th>STT</th>
                            <th>Mã nhân viên</th>
                            <th>Họ và tên</th>
                            <th>Phòng ban</th>
                            <th>Chức danh</th>
                            <th style="width: 100px">Email</th>
                            <th style="width: 40px"></th>
                        </tr>
                    </thead>
                    <tbody id="tbody">
                    </tbody>
                </table>
            </div>
            <br />
            <div style="text-align: right; margin-bottom: 10px">
                <button class="btn btn-info" id="btnSubmit" type="button">Lưu </button>
                <button class="btn btn-info" type="button" id="btnTroVe">Trở về </button>
            </div>
        </fieldset>

    </div>
</form>

<div id="myModal" class="modal fade" role="dialog">
    <div class="modal-dialog" style="width: 900px">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-body">
                <div class="container" style="width: 98%">
                    <div class="row">
                        <div style="position: relative">
                            <input type="text" id="searchString" class="form-control" style="padding-right: 30px; border-radius: 50px" placeholder="Search" onkeyup="enterToSeacrh(event)">
                            <i class="fa fa-search" id="btnSearch" style="position: absolute; cursor: pointer; top: 6px; right: 7px;"></i>
                        </div>
                        <div id="filter-panel" class="filter-panel" style="padding-top: 10px;">
                            <div class="panel panel-default" style="border: none">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary btn-sm" id="btnAccept">
                    <span class="glyphicon glyphicon-ok"></span>&nbsp;Đồng ý
                </button>
                <button type="button" class="btn btn-default" data-dismiss="modal" id="btnClose">Hủy</button>
            </div>
        </div>
    </div>
</div>


