<form id="form-submit" class="form-horizontal" method="post">
    <div id="container" class="custome_fieldSet">
        <fieldset class="removeBorderFieldset">
            <div id="tabs" style="width: 30%; height: auto; border: none; float: left; box-sizing: border-box; overflow: hidden; clear: none;" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                    <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active ">
                        <a><span><i class="fa fa-plus-square-o" aria-hidden="true"></i>Thêm mới phiếu tăng ca</span></a></li>
                </ul>
            </div>
            <table class="table table-striped table-hover table-condensed" id="tbl-create" style="position: relative">
                <tr>
                    <td style="width: 15%" class="tdtitle">Mã nhân viên</td>
                    <td style="width: 35%">@Model.NhanVien.maNhanVien</td>
                    <td style="width: 15%" class="tdtitle">Tên nhân viên </td>
                    <td style="width: 35%">@Model.NhanVien.hoVaTen
                        <input type="hidden" id="url" value="@ViewBag.URL" />
                        @Html.HiddenFor(m => m.maQuiTrinhDuyet)
                        @Html.HiddenFor(model => model.maPhieu)
                        <input type="hidden" id="tenBuocDuyet" value="@ViewBag.TenBuocDuyet " />
                    </td>
                </tr>
                <tr>
                    <td class="tdtitle">Số phiếu ĐK tăng ca </td>
                    <td>@Model.maPhieu</td>
                    <td class="tdtitle">Phòng ban công tác </td>
                    <td>@Model.tenPhongBan
                        @Html.HiddenFor(model => model.maPhongBan)
                    </td>
                </tr>
                <tr>
                    <td class="tdtitle">Ngày lập</td>
                    <td>
                    @Html.Encode(String.Format("{0:dd/MM/yyyy}", Model.ngayLap))
                    <td class="tdtitle">Ngày tăng ca</td>
                    <td>@Html.Encode(String.Format("{0:dd/MM/yyyy}", Model.ngayTangCa))</td>
                </tr>
                <tr>
                    <td class="tdtitle">Giờ bắt đầu</td>
                    <td>
                        @Html.Encode(String.Format("{0:HH\\:mm}", Model.gioBatDau))
                    </td>
                    <td class="tdtitle">Giờ kết thúc</td>
                    <td>
                        @Html.Encode(String.Format("{0:HH\\:mm}", Model.gioKetThuc))</td>
                </tr>

                <tr>

                    <td class="tdtitle">Số giờ tăng ca</td>
                    <td>@Html.Encode(String.Format("{0:HH\\:mm}", Model.soGioTangCa))</td>
                    <td class="tdtitle">Loại tăng ca</td>
                    <td>@Model.tenLoaiTangCa</td>
                </tr>
                <tr>
                    <td class="tdtitle">Hình thức tăng ca <span style="font-style: italic; float: right; color: red">*</span></td>
                    <td>
                        <label class="radio-inline" style="font-size: 13px">
                            @Html.RadioButtonFor(model => model.hinhThucTangCa, "tcnb", new { style = "width:auto", required = "required" }) Tăng ca nghỉ bù
                        </label>
                        <label class="radio-inline" style="font-size: 13px">
                            @Html.RadioButtonFor(model => model.hinhThucTangCa, "tctl", new { style = "width:auto", required = "required" }) Tăng ca tính lương
                        </label>
                    </td>


                </tr>

                <tr>
                    <td class="tdtitle">Bắt đầu nghỉ giữa ca</td>
                    <td>@Html.Encode(String.Format("{0:HH\\:mm}", Model.thoiGianNghiGiuaCa))</td>
                    <td class="tdtitle">Kết thúc nghỉ giữa ca</td>
                    <td>@Html.Encode(String.Format("{0:HH\\:mm}", Model.thoiGianNghiKetThucGiuaCa))</td>
                </tr>
                <tr>
                    <td class="tdtitle">Hệ số tăng ca</td>
                    <td>@Model.heSoTangCa</td>

                    <td class="tdtitle">Thời gian nghỉ giữa ca (phút)</td>
                    <td>@Model.soGioNghiGiuaCa</td>
                </tr>
                <tr>
                    <td class="tdtitle">Nội dung tăng ca</td>
                    <td colspan="3">
                        @Html.Raw(Model.ghiChu)
                    </td>

                </tr>
            </table>
            <br />
            <div id="containerNhanVien">
                <table class="table table-striped table-hover table-condensed" id="tbl-users">
                    <thead>
                        <tr id="trtop">
                            <th>STT</th>
                            <th>Mã nhân viên</th>
                            <th>Họ và tên</th>
                            <th>Phòng ban</th>
                            <th>Chức danh</th>
                            <th style="width: 100px">Email</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (nhanVienThuocNhoms != null)
                        {
                            foreach (var item in nhanVienThuocNhoms)
                            {
                            <tr>
                                <td class="sothutu">@i</td>
                                <td>@item.maNhanVien
                                    <input type="hidden" id="maNhanVien" name="maNhanVien" value="@item.maNhanVien"/>
                                    <input type="hidden" id="userId" name="userId" value="@item.userID"/>
                                </td>
                                <td>
                                    <i class="fa fa-user" aria-hidden="true" style="color: #519ee5"></i>&nbsp;@item.hoVaTen
                                </td>
                                <td>@item.tenPhongBan</td>
                                <td>@item.tenChucDanh</td>
                                <td><i class="fa fa-envelope-o" aria-hidden="true"></i>@item.email</td>
                            </tr> 
                                i++;
                            }
                        }
                    </tbody>
                </table>
            </div>
            <br />
            <div style="text-align: right; margin-bottom: 10px">
                <input type="hidden" name="maNVD" id="maNVD" value="@user1.manv" />
                <input type="hidden" name="tenNhanVien" id="tenNhanVien" value="@ViewBag.HoTen" />
                @Html.HiddenFor(model => model.ghiChu)
                @* @if (ViewBag.TenTrangThaiDuyet != "KDD")
                {
                    if ((Model.Duyet == null || Model.Duyet.tinhTrang == 0) && Model.NhanVien.maNhanVien == user1.manv && Model.Duyet.maBuocDuyet != "KDD")
                    {
                    <button class="btn btn-info" type="button" onclick="chonNguoiDuyet();">Gửi duyệt </button>
                    }
                    else if (Model.Duyet != null && (Model.Duyet.nguoiDuyet.maNhanVien == null ? string.Empty : Model.Duyet.nguoiDuyet.maNhanVien.Trim()) == user1.manv && Model.Duyet.maBuocDuyet != "DTN" && Model.Duyet.maBuocDuyet != "CDL2" && Model.Duyet.maBuocDuyet != "CD")
                    {
                    <button class="btn btn-info" type="button" onclick="chonNguoiDuyet2();">Duyệt phiếu </button>
                    <button class="btn btn-info" type="button" onclick="KhongDuyet();">Không duyệt</button>
                    <button class="btn btn-info" type="button" onclick="TraLai();">Trả lại</button>
                    }
                    else if (Model.Duyet != null && (Model.Duyet.maBuocDuyet == "CDL2" || Model.Duyet.maBuocDuyet == "CD") && (Model.Duyet.nguoiDuyet.maNhanVien == null ? string.Empty : Model.Duyet.nguoiDuyet.maNhanVien.Trim()) == user1.manv && Model.Duyet.maBuocDuyet != "DTN")
                    {
                    <button class="btn btn-info" type="button" onclick="DuyetPhieu();">Duyệt</button>
                    <button class="btn btn-info" type="button" onclick="KhongDuyet();">Không duyệt</button>
                    <button class="btn btn-info" type="button" onclick="TraLai();">Trả lại</button>
                    }
                    else if (Model.Duyet != null && (nhanVienNS != null && nhanVienNS.Contains(user1.manv)) && Model.Duyet.maBuocDuyet == "CTN" && Model.Duyet.maBuocDuyet != "DTN")//Tất cả nhân viên ở phòng nhân sự đều được duyệt ở đấy
                    {
                    <button class="btn btn-info" type="button" onclick="DuyetPhieu();">Duyệt</button>
                    <button class="btn btn-info" type="button" onclick="KhongDuyet();">Không duyệt</button>
                    <button class="btn btn-info" type="button" onclick="TraLai();">Trả lại</button>
                    }
                }*@

                @if ((Model.Duyet == null || Model.Duyet.tinhTrang == 0) && Model.NhanVien.maNhanVien == user1.manv)
                {                         
                    <button class="btn btn-info" type="button" id="btnGuiDuyet">Gửi duyệt </button>
                }
                else if (Model.Duyet != null && (Model.Duyet.maBuocDuyet != "DTN" && Model.Duyet.maBuocDuyet != "DD") && Model.Duyet.nguoiDuyet.maNhanVien == user1.manv)
                {                         
                    <button class="btn btn-info" type="button" id="btnDuyetPhieu">Duyệt phiếu này</button>
                    <button class="btn btn-info" type="button" id="btnTraLai">Trả lại</button>
                }
                <button class="btn btn-info" type="button" id="btnTroVe">Trở về </button>
            </div>
        </fieldset>

    </div>
</form>

<div id="myModal" class="modal fade" role="dialog">
    <div class="modal-dialog">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-body">
                <div class="container" style="width: 98%">
                    <div class="row">
                        <div style="position: relative">
                            <input type="text" id="searchString" class="form-control" style="padding-right: 30px; border-radius: 50px" placeholder="Search" onkeyup="enterToSeacrh(event)">
                            <i class="fa fa-search" id="btnSearch" style="position: absolute; cursor: pointer; top: 6px; right: 7px;"></i>
                        </div>
                        <div id="filter-panel" class="filter-panel" style="padding-top: 10px;">
                            <div class="panel panel-default" style="border: none">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary btn-sm" id="btnAccept">
                    <span class="glyphicon glyphicon-ok"></span>&nbsp;Đồng ý
                </button>
                <button type="button" class="btn btn-default" data-dismiss="modal" id="btnClose">Hủy</button>
            </div>
        </div>
    </div>
</div>

