<script>
    $(document).ready(function () {
        $(".numberinput").autoNumeric('init', { mDec: 1, mNum: 3, lZero: 'deny', aSep: ',', aDec: '.', pSign: 's', vMin: '0' });
        $(".numberinputInt").autoNumeric('init', { lZero: 'deny', mDec: 0, pSign: 's', aSep: ',', aDec: '.' });
        $("#btnTroVe").click(function () {
            var url = "@Url.Action("Index")";
            location.href = url;
        });
        $('#editor').summernote({
            height: 150,                 // set editor height
            minHeight: null,             // set minimum height of editor
            maxHeight: null             // set maximum height of editor
            //focus: true                  // set focus to editable area after initializing summernote
        });
        $(".timepicker").datetimepicker({
            locale: 'vi',
            format: 'HH:mm'
        });

        $(".datepicker").datetimepicker({
            locale: 'vi',
            format: 'DD/MM/YYYY',
            useCurrent: false
        });
        $("#btnSubmit").click(function () {
            if (CheckForm()) {
                var noiDung = $(".note-editable").html();
                $("#ghiChu").val(noiDung);
                $("#form-submit").submit();
            }
        });

        $("#maLoaiTangCa").change(function () {
            $.post('@Url.Action("HeSoTangCa", "PhieuTangCa")', { maLoaiTangCa: $("#maLoaiTangCa").val() }, function (data) {
                $("#heSoTangCa").val(data);
            });
        });


        $("#ChoosePB").click(function () {
            $('#myModalChonPhongBan').modal();
            var Url = '@Url.Action("ChonPhongBan", "PhieuCongTac")';
            $('#filter-panel').load(Url);
        });

        $(document).on("dp.change", "#ngayTangCa", function (e) {
            var date = new Date();
            var expire = moment().subtract(0, "day");
            $(this).data("DateTimePicker").minDate(expire, function () {
                return;
            });
            var ngayBD = $('#ngayLap').val();
            var ngayKT = $('#ngayTangCa').val();
            var d1 = Date.parse(convertDate(ngayBD));
            var d2 = Date.parse(convertDate(ngayKT));
            if (d2 < d1) {
                Alert.error("Ngày tăng ca > ngày lập. Vui lòng nhập lại.", "Thông báo", { displayDuration: 3000 });
                $("#ngayTangCa").val("");
            }
        });

        $('#btnNhanVien').click(function () {
            var maPhongBan = $("#maPhongBan").val(),
                searchString = $("#searchString").val();
            var url = '@Url.Action("GetMoreUsers", "PhieuTangCa")' + "?maPB=" + maPhongBan + "&searchString=" + searchString;
            beginPaging();
            $('#filter-panel .panel-default').load(url, function () {
                successPaging();
            });
        })

        $('#btnSearch').click(function () {
            var maPhongBan = $("#maPhongBan").val(),
                searchString = $("#searchString").val();
            var url = '@Url.Action("GetMoreUsers", "PhieuTangCa")' + "?maPB=" + maPhongBan + "&searchString=" + searchString;
            beginPaging();
            $('#filter-panel .panel-default').load(url, function () {
                successPaging();
            });
        })

        $(document).on("click", ".btnXoa", function () {
            $(this).closest("tr").remove();
        });

        $("#btnGuiDuyet").click(function () {
            chonNguoiDuyet();
        });

        $("#btnDuyetPhieu").click(function () {
            duyetPhieu();
        });


        $("#btnTraLai").click(function () {
            TraLai();
        });

    });

    function beginPaging(args) {
        // Animate         
        $('#content').fadeOut('fast');
    }

    function successPaging() {
        // Animate        
        $('#content').fadeIn('fast');
    }

    function checkEndTime() {
        var valueStartTime = $("#gioBatDau").val();
        var valueEndTime = $("#gioKetThuc").val();
        var startTimeSplit = valueStartTime.split(':');
        var endTimeSplit = valueEndTime.split(':');
        if (parseFloat(endTimeSplit[0]) < parseFloat(startTimeSplit[0])) {
            $("#gioKetThuc").val('');
            $("#gioKetThuc").focus();
            $("#gioKetThuc").addClass("error").attr("title", "Giờ kết thúc > giờ bắt đầu");
        }
        else {
            if (parseFloat(endTimeSplit[0]) == parseFloat(startTimeSplit[0])) {
                if (parseFloat(endTimeSplit[1]) < parseFloat(startTimeSplit[1])) {
                    $("#gioKetThuc").val('');
                    $("#gioKetThuc").focus();
                    $("#gioKetThuc").addClass("error").attr("title", "Giờ kết thúc > giờ bắt đầu");
                }
            }
        }
        GenerateDuration();
    }

    function GenerateDuration() {
        var valueStartTime = $("#gioBatDau").val();
        var valueEndTime = $("#gioKetThuc").val();
        var startTimeSplit = valueStartTime.split(':');
        var endTimeSplit = valueEndTime.split(':');
        var today = new Date();
        var startDate = new Date(today.getFullYear(), today.getMonth(), today.getDate(), startTimeSplit[0], startTimeSplit[1], 00);
        var endDate = new Date(today.getFullYear(), today.getMonth(), today.getDate(), endTimeSplit[0], endTimeSplit[1], 00);


        var diff = new Date(today.getFullYear(), today.getMonth(), today.getDate());
        diff.setTime(endDate.getTime() - startDate.getTime());
        var result = diff.getHours() - 7 + ":" + diff.getMinutes();
        if (result == 'NaN:NaN') {
            $("#soGioTangCa").val('');
        }
        else {
            if (diff.getMinutes() == 0) {
                $("#soGioTangCa").val(diff.getHours() - 7 + ":" + "00");
                if ($("#soGioTangCa").val() == 'NaN:0NaN') {
                    $("#soGioTangCa").val(0);
                }
                //  $("#soGioTangCaHidden").val(diff.getHours() - 7 + ":" + "00");
            }
            else {
                $("#soGioTangCa").val(result);
                if ($("#soGioTangCa").val() == 'NaN:0NaN') {
                    $("#soGioTangCa").val(0);
                }
                //  $("#soGioTangCaHidden").val(result);
            }
        }
        GenerateSoGioTangCa();
    }

    function GenerateSoGioTangCa() {
        var timeNghiGiuaCa = parseFloat($("#soGioNghiGiuaCa").val());
        GenerateDurationTwo();
        var soGioTangCa = $("#soGioTangCa").val();
        var splitSoGioTangCa = soGioTangCa.split(':');
        var soGioTangCaGio = parseFloat(splitSoGioTangCa[0]);
        var soGioTangCaPhut = parseFloat(splitSoGioTangCa[1]);
        var doiRaPhutCuaGioTangCa = soGioTangCaGio * 60 + soGioTangCaPhut;
        var soPhutTangCa = doiRaPhutCuaGioTangCa - timeNghiGiuaCa;

        var soGioNew = Math.floor(soPhutTangCa / 60);
        var soPhutNew = soPhutTangCa - soGioNew * 60;
        if (soPhutNew > 9) {
            $("#soGioTangCa").val(soGioNew + ":" + soPhutNew);
            if ($("#soGioTangCa").val() == 'NaN:0NaN') {
                $("#soGioTangCa").val(0);
            }
        }
        else {
            $("#soGioTangCa").val(soGioNew + ":0" + soPhutNew);
            if ($("#soGioTangCa").val() == 'NaN:0NaN') {
                $("#soGioTangCa").val(0);
            }
        }
    }

    function GenerateDurationTwo() {
        var valueStartTime = $("#gioBatDau").val();
        var valueEndTime = $("#gioKetThuc").val();
        var startTimeSplit = valueStartTime.split(':');
        var endTimeSplit = valueEndTime.split(':');
        var today = new Date();
        var startDate = new Date(today.getFullYear(), today.getMonth(), today.getDate(), startTimeSplit[0], startTimeSplit[1], 00);
        var endDate = new Date(today.getFullYear(), today.getMonth(), today.getDate(), endTimeSplit[0], endTimeSplit[1], 00);


        var diff = new Date(today.getFullYear(), today.getMonth(), today.getDate());
        diff.setTime(endDate.getTime() - startDate.getTime());
        var result = diff.getHours() - 7 + ":" + diff.getMinutes();
        if (result == 'NaN:NaN') {
            $("#soGioTangCa").val('');
        }
        else {
            if (diff.getMinutes() == 0) {
                $("#soGioTangCa").val(diff.getHours() - 7 + ":" + "00");
                //  $("#soGioTangCaHidden").val(diff.getHours() - 7 + ":" + "00");
            }
            else {
                $("#soGioTangCa").val(result);
                //  $("#soGioTangCaHidden").val(result);
            }
        }
    }

    //Kiểm tra khi change bắt đầu nghỉ giữa ca
    function CheckThoiGianBatDauNghiGiuaCa() {
        var flag = true;
        var valueStartTime = $("#gioBatDau").val();
        var valueEndTime = $("#gioKetThuc").val();
        var valueStartTimeHaft = $("#thoiGianNghiGiuaCa").val();
        var startTimeSplit = valueStartTime.split(':');
        var endTimeSplit = valueEndTime.split(':');
        var startTimeHaftSplit = valueStartTimeHaft.split(':');

        //so sanh voi gio bat dau tang ca
        if (startTimeHaftSplit[0] != '') {
            if (parseFloat(startTimeHaftSplit[0]) < parseFloat(startTimeSplit[0])) {
                $("#thoiGianNghiGiuaCa").focus();
                $("#thoiGianNghiGiuaCa").addClass("error").attr("title", "Giờ bắt đầu nghỉ giữa ca không được nhỏ hơn giờ bắt đầu");
                flag = false;
            }
            else {
                if (parseFloat(startTimeHaftSplit[0]) == parseFloat(startTimeSplit[0])) {
                    if (parseFloat(startTimeHaftSplit[1]) < parseFloat(startTimeSplit[1])) {
                        $("#thoiGianNghiGiuaCa").focus();
                        $("#thoiGianNghiGiuaCa").addClass("error").attr("title", "Giờ bắt đầu nghỉ giữa ca không được nhỏ hơn giờ bắt đầu");
                        flag = false;
                    }
                }
            }
        }
        //so sanh voi gio ket thuc tang ca
        if (parseFloat(startTimeHaftSplit[0]) > parseFloat(endTimeSplit[0])) {
            $("#thoiGianNghiGiuaCa").focus();
            $("#thoiGianNghiGiuaCa").addClass("error").attr("title", "Giờ bắt đầu nghỉ giữa ca không được lớn hơn giờ kết thúc");
            flag = false;
        }
        else {
            if (getNumber(startTimeHaftSplit[0]) == getNumber(endTimeSplit[0])) {
                if (getNumber(startTimeHaftSplit[1]) > getNumber(endTimeSplit[1])) {
                    $("#thoiGianNghiGiuaCa").focus();
                    $("#thoiGianNghiGiuaCa").addClass("error").attr("title", "Giờ bắt đầu nghỉ giữa ca không được lớn hơn giờ kết thúc");
                    flag = false;
                }
            }
        }
        return flag;
    }

    //Hàm tính tự đồng thời gian nghỉ giữa ca khi chan
    function GenerateThoiGianNghiGiuaCa() {
        if ($("#thoiGianNghiGiuaCa").val() == '') {
            setInvalid($("#thoiGianNghiGiuaCa"), "");
            $("#thoiGianNghiKetThucGiuaCa").val('');
            return;
        }
        if (CheckThoiGianBatDauNghiGiuaCa()) {
            if (CheckThoiGianKetThucNghiGiuaCa()) {
                var valueStartTime = $("#thoiGianNghiGiuaCa").val();
                var valueEndTime = $("#thoiGianNghiKetThucGiuaCa").val();
                var startTimeSplit = valueStartTime.split(':');
                var endTimeSplit = valueEndTime.split(':');
                var starDateGio = getNumber(startTimeSplit[0]);
                var startDatePhut = getNumber(startTimeSplit[1]);
                var endDateGio = getNumber(endTimeSplit[0]);
                var endDatePhut = getNumber(endTimeSplit[1]);
                var soGio = 0;
                var soPhut = 0;
                var soPhutNew = 0;
                if (endDateGio >= starDateGio) {
                    if (endDatePhut >= startDatePhut) {
                        soGio = endDateGio - starDateGio;
                        soPhut = endDatePhut - startDatePhut;
                        soPhutNew = soGio * 60 + soPhut;
                        $("#soGioNghiGiuaCa").val(soPhutNew);
                    }
                    else {
                        soGio = endDateGio - starDateGio - 1;
                        soPhut = 60 - startDatePhut + endDatePhut;
                        soPhutNew = soGio * 60 + soPhut;
                        $("#soGioNghiGiuaCa").val(soPhutNew);
                    }

                }
                GenerateSoGioTangCa();
            }
            else {
                alert("Xin vui lòng chọn lại thời gian kết thúc nghĩ giữa ca");
            }
        }
        else {
            alert("Xin vui lòng chọn lại thời gian bắt đầu nghĩ giữa ca");
        }
    }

    function CheckThoiGianKetThucNghiGiuaCa() {
        var flag = true;

        var valueStartTimeHaft = $("#thoiGianNghiGiuaCa").val();
        var valueEndTimeHaft = $("#thoiGianNghiKetThucGiuaCa").val();

        var endTimeHaftSplit = valueEndTimeHaft.split(':');
        var startTimeHaftSplit = valueStartTimeHaft.split(':');
        if ($("#thoiGianNghiKetThucGiuaCa").val() != '') {
            //so sanh voi gio bat dau tang ca
            if (parseFloat(endTimeHaftSplit[0]) < parseFloat(startTimeHaftSplit[0])) {
                $("#thoiGianNghiKetThucGiuaCa").focus();
                $("#thoiGianNghiKetThucGiuaCa").addClass("error").attr("title", "Giờ kết thúc nghỉ giữa ca không được nhỏ hơn giờ bắt đầu nghĩ giữa ca");
                flag = false;
            }
            else {
                if (parseFloat(endTimeHaftSplit[0]) == parseFloat(startTimeHaftSplit[0])) {
                    if (parseFloat(endTimeHaftSplit[1]) < parseFloat(startTimeHaftSplit[1])) {
                        $("#thoiGianNghiKetThucGiuaCa").focus();
                        $("#thoiGianNghiKetThucGiuaCa").addClass("error").attr("title", "Giờ kết thúc nghỉ giữa ca không được nhỏ hơn giờ bắt đầu nghĩ giữa ca");
                        flag = false;
                    }
                }
            }
        }
        return flag;
    }



    function Generate() {
        var startDate = $("#ngayBatDau").val();
        var endDate = $("#ngayKetThuc").val();
        $.post('@Url.Action("Generate", "PhieuCongTac")', { dateOne: startDate, dateTwo: endDate }, function (data) {
            if (data != null) {
                $("#soNgayCongTac").val(data.soNgay);
            }
        });
    }
    function CheckForm() {
        var flag = true;
        if ($("#gioBatDau").val() == "") {
            $("#gioBatDau").addClass("error").attr("title", "Xin vui lòng chọn giờ bắt đầu");
            flag = false;
        }

        if ($("#gioKetThuc").val() == "") {
            $("#gioKetThuc").addClass("error").attr("title", "Xin vui lòng chọn giờ kết thúc");
            flag = false;

        }

        if ($("#maLoaiTangCa").val() == "0") {
            $("#maLoaiTangCa").addClass("error").attr("title", "Xin vui lòng chọn loại tăng ca");
            flag = false;

        }

        //if ($("#lyDo").val() == "") {
        //    $("#lyDo").addClass("error").attr("title", "Vui lòng nhập lý do.");
        //    flag = false;

        //}

        var ngayBD = $("#ngayLap").val();
        var ngayKT = $("#ngayTangCa").val();
        var d1 = Date.parse(convertDate(ngayBD));
        var d2 = Date.parse(convertDate(ngayKT));
        if (d2 < d1) {
            Alert.error("Ngày tăng ca > ngày lập. Vui lòng nhập lại.", "Thông báo", { displayDuration: 3000 });
            $("#ngayTangCa").val("");
            flag = false;
        }
        return flag;
    }

    function enterToSeacrh(event) {
        if (event.keyCode == 13)
            $("#btnSearch").click();
