@using BatDongSan.Models.PhieuDeNghi;
@model IPagedList<sp_NS_PhieuDangKyTangCaTheoNhom_IndexResult>
@{
    int i = 1;
}
@{
    var ls = ViewBag.listTangCaTrongNgay as List<sp_NS_PhieuDangKyTangCaTheoNhom_IndexResult>;
            if (ls != null && ls.Count > 0){
<table class="table table-striped table-hover table-condensed TableMobile IndexTangCaInNgay" >
    <thead>
        <tr>
            <th style="width: 45px">STT</th>
            <th style="width: 125px">Số phiếu</th>
            <th style="width: 100px">Ngày tăng ca</th>
            
            <th style="">Giờ</th>
            <th>Trạng thái</th>
            <th style="text-align:center">Lịch sử phiếu</th>
        </tr>
    </thead>
    <tbody>

            @{
             
              
    foreach (var item in ls.ToList())
    {
            <tr>
                <td style="text-align: center">@i</td>
                <td style="text-align: center"><i class="fa fa-clipboard"></i><a style="color:blue" href="@Url.Action("Details", "PhieuTangCa", new { id = item.soPhieu })" target="_blank">@item.soPhieu</a>
                    
                </td>
                
              
                <td style="text-align: center">@String.Format("{0: dd/MM/yyyy}", item.ngayTangCa)</td>
                <td style="text-align: center">
                    <i class="fa fa-calendar-o" aria-hidden="true"></i>Fr: @String.Format("{0:HH\\:mm}", @item.gioBatDau)
                   
                    <i class="fa fa-calendar" aria-hidden="true"></i>To: @String.Format("{0:HH\\:mm}", @item.gioKetThuc)
                   
                    <i class="fa fa-clock-o" aria-hidden="true"></i>SG: @item.soGioTangCa
                </td>
                <td style="text-align:center">@item.tenTrangThaiDuyet</td>
                <td  style="text-align:center">
                     <button  class="btn btn-info" type="button" onclick="ViewDetailHistoryLayout('@item.soPhieu','@item.maQuiTrinhDuyet')" title="Lịch sử phiếu"><i class="fa fa-circle-o-notch" aria-hidden="true"></i>Lịch sử phiếu</button>
                </td>
             
               
            </tr> 
            
                    i++;
                
            }
        }
        <tr>
 
</tr>
    </tbody>
</table>
}else{
            <div>Không tìm thấy dữ liệu.</div>
            }

}