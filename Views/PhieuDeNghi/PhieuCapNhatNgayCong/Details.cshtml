@using BatDongSan.Models.PhieuDeNghi;
@model PhieuCapNhatNgayCong
@{
    ViewBag.Title = "Đăng ký phiếu tăng ca";
    Layout = "~/Views/Shared/_Layout.cshtml";
    List<PhieuCapNhatNgayCongNhanVien> nhanVienThuocNhoms = ViewBag.ChiTietNhanVien;
    int i = 1;
}
<link rel="stylesheet" href="~/Content/summernote/summernote.css" />
<script src="~/Content/summernote/summernote.js"></script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/additional-methods.min.js"></script>
<script src="~/Scripts/autoNumeric.js"></script>
<script src="~/Scripts/batdongsan.validate.js"></script>
<script src="~/Scripts/moment.min.js"></script>
<script src="~/Scripts/vi.js"></script>
<script src="~/Scripts/bootstrap-datetimepicker.min.js"></script>
<link rel="stylesheet" href="~/Content/bootstrap-datetimepicker.min.css" />
<script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>

<script>
    $(document).ready(function () {
        $(".numberinput").autoNumeric('init', { mDec: 2, mNum: 3, lZero: 'deny', aSep: ',', aDec: '.', pSign: 's' });
        $(".numberinputInt").autoNumeric('init', { lZero: 'deny', mDec: 0, pSign: 's', aSep: ',', aDec: '.' });
        $("#btnTroVe").click(function () {
            var url = "@Url.Action("Index")";
            location.href = url;
        });
        $('#editor').summernote({
            height: 150,                 // set editor height
            minHeight: null,             // set minimum height of editor
            maxHeight: null             // set maximum height of editor
            //focus: true                  // set focus to editable area after initializing summernote
        });
        $(".timepicker").datetimepicker({
            locale: 'vi',
            format: 'HH:mm'
        });

        $(".datepicker").datetimepicker({
            locale: 'vi',
            format: 'DD/MM/YYYY',
            useCurrent: false
        });
        $("#btnSubmit").click(function () {
            if (CheckForm()) {
                var noiDung = $(".note-editable").html();
                $("#ghiChu").val(noiDung);
                $("#form-submit").submit();
            }
        });


        $('#btnNhanVien').click(function () {
            var url = '@Url.Action("DanhSachNhanVien", "PhieuCapNhatNgayCong")';
            showPopup(url, 980, 550);
        });

        $('#btnSearch').click(function () {
            var maPhongBan = $("#maPhongBan").val();
            var searchString = $("#searchString").val().replace(/ /gi, '+');
            var url = '@Url.Action("GetMoreUsers", "PhieuTangCa")' + "?maPB=" + maPhongBan + "&searchString=" + searchString;
            beginPaging();
            $('#filter-panel .panel-default').load(url, function () {
                successPaging();
            });
        });

        $(document).on("click", ".btnXoa", function () {
            $(this).closest("tr").remove();
        });

        $("#btnGuiDuyet").click(function () {
            chonNguoiDuyet();
        });

        $("#btnDuyetPhieu").click(function () {
            duyetPhieu();
        });


        $("#btnTraLai").click(function () {
            TraLai();
        });
    });

    function beginPaging(args) {
        // Animate         
        $('#content').fadeOut('fast');
    }

    function successPaging() {
        // Animate        
        $('#content').fadeIn('fast');
    }

    function CheckForm() {
        var flag = true;
        return flag;
    }

    function enterToSeacrh(event) {
        if (event.keyCode == 13)
            $("#btnSearch").click();
    }

    function DeleteRow(id_tbody, index, sTT) {
        var table = document.getElementById(id_tbody);
        var maNCC = $('#' + id_tbody + ' tr:eq(' + index + ')').find("a").html();
        var tenNCC = $('#' + id_tbody + ' tr:eq(' + index + ')').find("td:eq(" + 2 + ")").html();

        table.deleteRow(index);

        for (var i = 0; i < table.rows.length; i++) {
            if (sTT == null)
                $('#' + id_tbody + ' tr:eq(' + i + ')').find("td:last").html("<a href='javascript:void(0);' onclick='DeleteRow(\"" + id_tbody + "\"," + i + ")'>Xóa</a>");
            else {
                $('#' + id_tbody + ' tr:eq(' + i + ')').find("td:first").html(i + 1);
                $('#' + id_tbody + ' tr:eq(' + i + ')').find("td:last").html("<a href='javascript:void(0);' onclick='DeleteRow(\"" + id_tbody + "\"," + i + ", true)'>Xóa</a>");
            }
        }
    }

    function SetEvent() {
        $(".numberinput").autoNumeric('init', { mDec: 2, mNum: 3, lZero: 'deny', aSep: ',', aDec: '.', pSign: 's', vMin: '0' });
        $(".numberinputInt").autoNumeric('init', { lZero: 'deny', mDec: 0, pSign: 's', aSep: ',', aDec: '.' });
    }

    function chonNguoiDuyet() {
        var url = ('@Url.Action("SelectCapDuyetDong/", "DMNguoiDuyet")' + $('#maPhieuCapNhatNgayCong').val() + '?maCongViec=PhieuCapNhatNgayCong' + '&url=' + $('#url').val());
        PopUpManager(url, "DUYET", 1000, 300);
    }

    function duyetPhieu() {
        var url = ('@Url.Action("DuyetPhieu/", "DMNguoiDuyet")' + $('#maPhieuCapNhatNgayCong').val() + '?maCongViec=PhieuCapNhatNgayCong' + '&maQuiTrinhDuyet=' + $('#maQuiTrinhDuyet').val() + '&url=' + $('#url').val());
        PopUpManager(url, "DUYET", 1000, 300);
    }

    function TraLai() {
        var tenBD = $('#tenBuocDuyet').val().replace(/\ /g, '');
        var url = ('@Url.Action("TraLaiDong/", "DMNguoiDuyet")' + $('#maPhieuCapNhatNgayCong').val() + '?tenBuocDuyet=' + tenBD + '&maQuiTrinhDuyet=' + $('#maQuiTrinhDuyet').val() + '&maCongViec=PhieuCapNhatNgayCong' + '&url=' + $('#url').val());
        PopUpManager(url, "DUYET", 1000, 300);
    }

    function PopUpManager(url, title, w, h) {
        var left = (screen.width / 2) - (w / 2);
        var top = (screen.height / 2) - (h / 2);
        var targetWin = window.open(url, title, 'width=' + w + ', height=' + h + ', top=' + top + ', left=' + left);
    }

    function LoadLaiTrang() {
        location.href = '@Url.Action("Details/", "PhieuCapNhatNgayCong")' + $('#maPhieuCapNhatNgayCong').val();
    }

</script>
<style>
    #tbl-create td
    {
        border: none;
    }
</style>
@{    
    BatDongSan.Models.HeThong.Sys_User user = new BatDongSan.Models.HeThong.Sys_User();
    if (Session["User"] != null)
    {
        user = (BatDongSan.Models.HeThong.Sys_User)Session["User"];
    }  
}
<form id="form-submit" class="form-horizontal" method="post">
    <div id="container" class="custome_fieldSet">
        <fieldset class="removeBorderFieldset">
            <div id="tabs" style="width: 30%; height: auto; border: none; float: left; box-sizing: border-box; overflow: hidden; clear: none;" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                    <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active ">
                        <a><span><i class="fa fa-plus-square-o" aria-hidden="true"></i>Chi phiếu cập nhật ngày công</span></a></li>
                </ul>
            </div>
            <table class="table table-striped table-hover table-condensed" id="tbl-create" style="position: relative">
                <tr>
                    <td style="width: 15%" class="tdtitle">Số phiếu cập nhật ngày công</td>
                    <td style="width: 35%">@Html.DisplayFor(model => model.maPhieuCapNhatNgayCong, new { @class = "form-control", @readonly = true })
                        @Html.HiddenFor(model => model.maPhieuCapNhatNgayCong, new { @class = "form-control", @readonly = true })
                        @Html.HiddenFor(model => model.maQuiTrinhDuyet)
                        <input type="hidden" id="url" value="@ViewBag.URL" />
                        <input type="hidden" id="tenBuocDuyet" value="@ViewBag.TenBuocDuyet " />
                    </td>
                    <td style="width: 15%" class="tdtitle">Ngày lập</td>
                    <td style="width: 35%">
                        @Html.Encode(String.Format("{0:dd/MM/yyyy}", Model.ngayLap))
                    </td>
                </tr>
                <tr>
                    <td class="tdtitle">Mã nhân viên</td>
                    <td>
                        @Model.nguoiLap.maNhanVien
                    </td>
                    <td class="tdtitle">Người lập</td>
                    <td>
                        @Model.nguoiLap.hoVaTen
                    </td>
                </tr>
                <tr>
                    <td class="tdtitle">Áp dụng từ</td>
                    <td colspan="3">Tháng @Model.thang
                        Năm @Model.nam</td>

                </tr>
                <tr>
                    <td class="tdtitle">Nội dung cập nhật</td>
                    <td colspan="3">
                        @Html.Raw(Model.ghiChu)
                    </td>

                </tr>
            </table>
            <br />
            <label>
                <button class="btn btn-link btn-sm" id="btnNhanVien" type="button">Thêm nhân viên</button>
            </label>
            <div id="containerNhanVien">
                <table class="table table-striped table-hover table-condensed" id="tbl-users">
                    <thead>
                        <tr id="trtop">
                            <th style="width: 30px">STT</th>
                            <th style="width: 150px">Mã nhân viên<br />
                                Họ và tên</th>
                            <th style="width: 200px">Phòng ban<br />
                                Chức danh</th>
                            <th style="width: 100px">Số ngày công</th>
                            <th style="width: 100px">Số ngày phép</th>
                            <th style="width: 100px">Số ngày lễ</th>
                        </tr>
                    </thead>
                    <tbody id="tbody">
                        @if (nhanVienThuocNhoms != null)
                        {
                            foreach (var item in nhanVienThuocNhoms)
                            {
                            <tr>
                                <td class="sothutu" style="text-align: center">@i</td>
                                <td>@item.nhanVien.maNhanVien
                                    <input type="hidden" id="maNhanVien" name="maNhanVien" value="@item.nhanVien.maNhanVien"/><br />
                                    <i class="fa fa-user" aria-hidden="true" style="color: #519ee5"></i>&nbsp;@item.nhanVien.hoVaTen
                                </td>
                                <td>
                                    @item.nhanVien.tenPhongBan<br />
                                    <i class="fa fa-ticket" aria-hidden="true"></i>@item.nhanVien.tenChucDanh
                                </td>
                                <td style="text-align: right">
                                    @String.Format("{0:#,##0.##}", @item.soNgayCong)
                                </td>
                                <td style="text-align: right">
                                    @String.Format("{0:#,##0.##}", @item.soNgayNghiPhep)
                                </td>
                                <td style="text-align: right">
                                    @String.Format("{0:#,##0.##}", @item.soNgayLe)
                                </td>
                            </tr> 
                                i++;
                            }
                        }
                    </tbody>
                </table>
            </div>
            <br />
            <div style="text-align: right; margin-bottom: 10px">
                @if ((Model.Duyet == null || Model.Duyet.tinhTrang == 0) && Model.nguoiLap.maNhanVien == user.manv)
                {                         
                    <button class="btn btn-info" type="button" id="btnGuiDuyet">Gửi duyệt </button>
                }
                else if (Model.Duyet != null && (Model.Duyet.maBuocDuyet != "DTN" && Model.Duyet.maBuocDuyet != "DD") && Model.Duyet.nguoiDuyet.maNhanVien == user.manv)
                {                         
                    <button class="btn btn-info" type="button" id="btnDuyetPhieu">Duyệt phiếu này</button>
                    <button class="btn btn-info" type="button" id="btnTraLai">Trả lại</button>
                }
                <button class="btn btn-info" type="button" id="btnTroVe">Trở về </button>
            </div>
        </fieldset>

    </div>
</form>

<div id="myModal" class="modal fade" role="dialog">
    <div class="modal-dialog" style="width: 900px">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-body">
                <div class="container" style="width: 98%">
                    <div class="row">
                        <div style="position: relative">
                            <input type="text" id="searchString" class="form-control" style="padding-right: 30px; border-radius: 50px" placeholder="Search" onkeyup="enterToSeacrh(event)">
                            <i class="fa fa-search" id="btnSearch" style="position: absolute; cursor: pointer; top: 6px; right: 7px;"></i>
                        </div>
                        <div id="filter-panel" class="filter-panel" style="padding-top: 10px;">
                            <div class="panel panel-default" style="border: none">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary btn-sm" id="btnAccept">
                    <span class="glyphicon glyphicon-ok"></span>&nbsp;Đồng ý
                </button>
                <button type="button" class="btn btn-default" data-dismiss="modal" id="btnClose">Hủy</button>
            </div>
        </div>
    </div>
</div>


<div id="myModalChonPhongBan" class="modal fade" role="dialog">
    <div class="modal-dialog modal-lg">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title"></h4>
            </div>
            <div class="modal-body">
                <div class="container" style="width: 98%">
                    <div class="row">
                        <div id="filter-panelNV" class="filter-panel">
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
            </div>
        </div>

    </div>
</div>

