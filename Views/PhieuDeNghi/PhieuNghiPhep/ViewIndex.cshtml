@using BatDongSan.Models.PhieuDeNghi;
@model IPagedList<sp_NS_PhieuDangKyNghiPhep_IndexResult>
@{
    int i = 1;
    bool quyenDuyet = (bool)ViewBag.QuyenDuyet;
}
<style>
    .listNghiPhep {
    }

        .listNghiPhep li {
            display: block;
            line-height: 1.7;
            clear: both;
            float: none;
        }

            .listNghiPhep li span {
                float: left;
            }

                .listNghiPhep li span:nth-child(1) {
                    color: green;
                    min-width: 50px;
                }
</style>
<script>
    function beginPaging(args) {
        // Animate        
        $('#content').fadeOut('fast');
    }

    function successPaging() {
        // Animate
        $('#content').fadeIn('normal');
    }

    function failurePaging() {
        alert("Không thể tải dữ liệu");
    }
</script>
@{
    BatDongSan.Models.HeThong.Sys_User user1 = new BatDongSan.Models.HeThong.Sys_User();
    if (Session["User"] != null)
    {
        user1 = (BatDongSan.Models.HeThong.Sys_User)Session["User"];
    }
}
<table class="table table-striped table-hover table-condensed" id="maintable">
    <thead>
        <tr>
            <th style="width: 40px">STT</th>
            <th style="width: 150px">Số phiếu</th>
            <th style="width: 150px">Họ và tên</th>
            <th style="min-width: 200px;">Phòng ban</th>
            <th>Loại nghỉ</th>
            <th style="width: 150px">Ngày nghỉ</th>
            <th style="width: 100px">Trạng thái</th>
            <th style="width: 100px"></th>
        </tr>
    </thead>
    <tbody id="load">

        @foreach (var item in Model)
        {
            <tr>
                <td style="text-align: center">@i</td>
                <td>
                    <i class="fa fa-clipboard"></i><a style="color:blue" href="@Url.Action("Details", "PhieuNghiPhep", new { id = item.maPhieu })">@item.maPhieu</a><br />
                    <i class="fa fa-calendar" aria-hidden="true"></i>@String.Format("{0: dd/MM/yyyy}", item.ngaylap)
                </td>
                <td>
                    <i class="fa fa-user"></i>@item.hoTen<br />
                    <i class="fa fa-credit-card" aria-hidden="true"></i>@item.maNhanVien
                </td>
                <td>@item.tenPhongBan
                    <br />
                    <i class="fa fa-ticket" aria-hidden="true"></i>@item.TenChucDanh
                </td>
                <td>
                    <ul class="listNghiPhep">
                        <li>
                            <span>Tên: </span><span>@item.tenLoaiNghiPhep</span>
                        </li>
                        <li>
                            <span>Số ngày:</span><span>@String.Format("{0:##,0.#}", item.soNgayNghiPhepThucTe)</span>
                        </li>
                        <li>
                            <span>Lý do: </span><span>
                                <div style="max-width: 350px" class="ResponTal">@Html.Raw(item.lyDo)</div>
                            </span>
                        </li>
                    </ul>



                    <td>
                        <i class="fa fa-calendar-o" aria-hidden="true"></i>Fr: @String.Format("{0: dd/MM/yyyy}", @item.ngayBatDau)
                        <br />
                        <i class="fa fa-calendar" aria-hidden="true"></i>To: @String.Format("{0: dd/MM/yyyy}", @item.ngayKetThuc)

                    </td>
                <td style="text-align: center">
                    <a href="javascript:void(0);" onclick="ViewDetailHistory('@item.maPhieu','@item.maQuiTrinhDuyet')">
                        @item.tenTrangThaiDuyet</a>
                </td>
                <td style="text-align: center">
                     @if ((item.trangThai == 0 && item.nguoiLap == user1.manv) || ((string)ViewBag.Administrator == "true"))
                    {
                        <a href="@Url.Action("Edit", "PhieuNghiPhep", new { id = item.maPhieu })" title ="Sửa phiếu"><i class="fa fa-pencil-square-o" style="font-size: 30px; color: orange;" aria-hidden="true">| </i></a>                         
                        <a class="btnDelete" alt="@item.maPhieu" title ="Xoá phiếu"><i class="fa fa-trash" style="font-size: 30px; color: red; cursor: pointer;" aria-hidden="true"></i></a>                            
                    }

                </td>
            </tr> 
                    i++;
        }
    </tbody>
</table>
<div>
    Trang @Model.PageNumber của @Model.PageCount / @ViewBag.Count
</div>
<div>
    <ul class="pagination">
        @Html.Raw(Ajax.Pager(new AjaxOptions { UpdateTargetId = "content", OnBegin = "beginPaging", OnSuccess = "successPaging", OnFailure = "failurePaging" }, Model.PageSize, Model.PageNumber, Model.TotalItemCount, new { controller = "PhieuNghiPhep", action = "ViewIndex", qSearch = ViewBag.Search, tuNgay = ViewBag.tuNgay, denNgay = ViewBag.denNgay, loaiNghi = ViewBag.loaiNghi, trangThai = ViewBag.trangThai }))
    </ul>
</div>
