@{
    Layout = null;
    ViewBag.Title = "Đặt lại mật khẩu";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hệ thống nhân sự TV.WINDOW</title>
    <link rel="stylesheet" href="~/Content/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/Content/login.css" />
    <link href="~/favicon.ico" rel="shortcut icon" type="image/x-icon" />
    <script src="~/Scripts/jquery-2.1.4.min.js"></script>
    <script src="~/Content/bootstrap/js/bootstrap.min.js"></script>
    <script src="~/Scripts/login.js"></script>
    <link href="~/Scripts/pgwslider.css" rel="stylesheet" type="text/css">
    <script type="text/javascript" src="~/Scripts/pgwslider.js"></script>
    <script>
        $(document).ready(function () {
            $('.pgwSlider').pgwSlider({

                displayControls: true,
                autoSlide: true,
                transitionEffect: 'sliding',
                displayList: true,
                touchControls: true,
                adaptiveDuration: 200,
                transitionDuration: 600,
                intervalDuration: 2500

            }
            );
            $("#btnUpdatePW").click(function () {
                var passw = $("#password").val();
                var rePassw = $("#repassword").val();
                if (passw == "" || rePassw == "") {

                    $(".inforLoginFailed").html("Bạn phải nhập mật khẩu!").css("color", "red");
                    $("#password").focus();

                    return false;
                }
                if (passw != rePassw) {

                    $(".inforLoginFailed").html("Mật khẩu không khớp!").css("color", "red");
                    $("#password").focus();
                    return false;
                }
                else {
                    //Quen Mật khẩu
                    $.ajax({
                        url: "@Url.Action("DatLaiPassword", "TaiKhoan")",
                        data: {
                            maCode: $("#maCode").val(),
                            passwd: $("#password").val()
                        },
                        type: "POST",
                        success: function (data) {

                            if (data == "ok") {

                                $(".inforLoginFailed").html("Cập nhật mật khẩu thành công").css("color", "green");
                                setTimeout(function () {

                                    location.href = "@Url.Action("Index", "Home")";
                                }, 1000);
                            }
                            else {

                                $(".inforLoginFailed").html("Cập nhật mật khẩu thất bại").css("color", "red");
                            }

                        }
                    });
                    // End
                }
            });



        });
        function enterToSeacrh(event) {
            if (event.keyCode == 13)
                $("#btnUpdatePW").click();
        }

        $(document).ready(function () {
            $('#password').keyup(function () {
                $('#result').html(checkStrength($('#password').val()))
            })
            function checkStrength(password) {
                var strength = 0;
                var html = '';
                if (password.length < 6) {
                    $('#result').removeClass()
                    $('#result').addClass('short');
                    $(".btnUpdatePW").hide();
                    return 'Quá ngắn'
                }
                if (password.length > 7) { strength += 1; }
                // If password contains both lower and uppercase characters, increase strength value.
                if (password.match(/([a-z].*[A-Z])|([A-Z].*[a-z])/)) { strength += 1; }
                // If it has numbers and characters, increase strength value.
                if (password.match(/([a-zA-Z])/) && password.match(/([0-9])/)) { strength += 1; }
                // If it has one special character, increase strength value.
                if (password.match(/([!,%,&,@@,#,$,^,*,?,_,~])/)) { strength += 1 }
                // If it has two special characters, increase strength value.
                if (password.match(/(.*[!,%,&,@@,#,$,^,*,?,_,~].*[!,%,&,@@,#,$,^,*,?,_,~])/)) { strength += 1 }
                // Calculated strength value, we can return messages
                // If value is less than 2
                if (strength < 2) {
                    $('#result').removeClass()
                    $('#result').addClass('weak');
                    $(".btnUpdatePW").hide();

                    return 'Yếu'
                } else if (strength == 2) {
                    $('#result').removeClass()
                    $('#result').addClass('good');
                    $(".btnUpdatePW").show();
                    return 'Mạnh'
                } else {
                    $('#result').removeClass()
                    $('#result').addClass('strong');
                    $(".btnUpdatePW").show();
                    return 'Rất mạnh'
                }
            }
        });
    </script>
    <style>
          #register label
    {
        margin-right: 5px;
    }


    #register .short
    {
        font-weight: bold;
        color: #FF0000;
        font-size: larger;
    }

    #register .weak
    {
        font-weight: bold;
        color: orange;
        font-size: larger;
    }

    #register .good
    {
        font-weight: bold;
        color: #2D98F3;
        font-size: larger;
    }

    #register .strong
    {
        font-weight: bold;
        color: limegreen;
        font-size: larger;
    }
    </style>
</head>

<body>
