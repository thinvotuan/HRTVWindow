                                                    <div class="col-sm-12">
                                                        <input type="password" class="form-control" placeholder="Re-Password" id="repassword" onkeypress="enterToSeacrh(event)" required="required" name="repassword">
                                                    </div>
                                                </div>

                                                <div class="form-group">

                                                    <div class="col-sm-12">

                                                        <input class="btn btn-primary btnUpdatePW" type="button" id="btnUpdatePW" value="Cập nhật" style="display:none">
