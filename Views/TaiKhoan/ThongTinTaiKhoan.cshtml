@model BatDongSan.tbl_ThongTinDangNhap
@using BatDongSan.Helper.Common;
@{
    ViewBag.Title = "Thông tin tài khoản";
    Layout = "~/Views/Shared/_LayoutView.cshtml";
    var fileDinhKem = ViewBag.FileDinhKem as List<BatDongSan.Models.DanhMuc.FileDinhKemModel>;
}
<script src="~/Scripts/jquery-2.1.4.min.js"></script>
<script src="~/Content/bootstrap/js/bootstrap.min.js"></script>
<link rel="stylesheet" href="~/Content/bootstrap/css/bootstrap-theme.min.css" />
 <link rel="stylesheet" href="~/Content/menuMobile.css" type="text/css" />
 <link rel="stylesheet" href="~/Content/common.css" type="text/css" />
 <script src="/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/additional-methods.min.js"></script>
<script src="~/Scripts/batdongsan.validate.js"></script>
<link rel="stylesheet" href="~/Content/batdongsan-alert.css" />
<script src="~/Scripts/moment.min.js"></script>
<script src="~/Scripts/vi.js"></script>
<script src="~/Scripts/bootstrap-datetimepicker.min.js"></script>
<script src="~/Scripts/autoNumeric.js"></script>
<script src="~/Scripts/batdongsan.generals.js"></script>
<script src="~/Scripts/batdongsan.uploadfile.js"></script>
<script src="~/Scripts/ckeditor/ckeditor.js"></script>
@Styles.Render("~/Content/css")

<script type="text/javascript">
    $(document).ready(function () {
        CKEDITOR.replace("gioiThieuCongTy", {
            toolbar: 'DauThau',
        });
        CKEDITOR.replace("linhVucHoatDong", {
            toolbar: 'DauThau',
        });
        $("#btnTroVe").click(function () {
            location.href = '@Url.Action("Index","Home")';
        });
        $("#btnSubmit").click(function (event) {
            //if ($("#gioiThieuCongTy").val() == "") {
            //    $("#cke_contents_gioiThieuCongTy iframe").addClass("error");
            //}
            //else {
            //    $("#cke_contents_gioiThieuCongTy iframe").removeClass("error");
            //}
            //if ($("#linhVucHoatDong").val() == "") {
            //    $("#cke_contents_linhVucHoatDong iframe").addClass("error");

            //}
            $("#error-message").find("ul").empty();
            var passCuNhapVao = $("#MatKhauCuNhapVao").val();

            var usname = $("#userName").val();
            var pass = $("#matKhau").val();
            var passlen = pass.length;
            if (passlen > 0 && passlen < 6) {
                $("#error-message").find("ul").html(function () {
                    $(this).append("<li>Mật khẩu phải ít nhất 6 ký tự</li>");
                    //$('html, body').animate({
                    //    scrollTop: $("#removeBorderFieldset").offset().top
                    //}, 500);
                });
                event.preventDefault();
            }
            else {
                if (pass != $("[name='rePassword']").val()) {
                    $("#error-message").find("ul").html(function () {
                        $(this).append("<li>Xác nhận mật khẩu không đúng</li>");
                        //$('html, body').animate({
                        //    scrollTop: $("#removeBorderFieldset").offset().top
                        //}, 500);
                        event.preventDefault();

                    });
                }
            }
            if (passCuNhapVao != "") {
                if (passCuNhapVao != "@Model.matKhau") {
                    $("#error-message").find("ul").html(function () {
                        $(this).append("<li>Mật khẩu cũ không đúng.</li>");
                        //$('html, body').animate({
                        //    scrollTop: $("#removeBorderFieldset").offset().top
                        //}, 500);
                        event.preventDefault();

                    });
                }
            }

            if (pass != "") {
                if (passCuNhapVao == "") {
                    $("#error-message").find("ul").html(function () {
                        $(this).append("<li>Vui lòng nhập mật khẩu cũ.</li>");
                        //$('html, body').animate({
                        //    scrollTop: $("#removeBorderFieldset").offset().top
                        //}, 500);
                        event.preventDefault();

                    });
                }
            }

            if ($("#error-message").find("ul").html() != "") {
                $("#error-message").fadeIn("fast");
                var counter = 5;
                var timer = setInterval(function () {
                    counter--;
                    if (counter == 0) {
                        $("#error-message").fadeOut("slow");
                        clearInterval(timer);
                    }
                }, 1500);
            }
        });

        $(".btnDownload").click(function () {
            location.href = "/TaiKhoan/Download/" + this.value;
        })
    });

    function deleteImage(obj) {
        var id = $(obj).data("identity"),
            row = $(obj).closest('tr');
        $.ajax({
            url: "/TaiKhoan/DeleteImage/" + id,
            type: "POST",
            dataType: "json",
            success: function (html) {
                row.remove();
                Alert.success("Xóa thành công!", "Thông báo", { displayDuration: 2000 });
            },
            error: function () {
                Alert.error("Có lỗi xảy ra", "Lỗi", { displayDuration: 2000 });
            }
        })
    }

</script>

<style>
    .require
    {
        color: red;
    }

    .table td
    {
        border: none;
    }
</style>
<fieldset class="removeBorderFieldset">
    
    <div id="error-message" class="form-error alert alert-danger" style="display: none">
        <strong>Cập nhật không thành công!</strong>
        <ul>
        </ul>
    </div>
    <div class="filter-panel" id="custom-panel">
        <form method="post" id="form-submit" action="/TaiKhoan/ThongTinTaiKhoan" enctype="multipart/form-data">

            <div class="form-group bs-callout bs-callout-info" style="overflow: hidden; margin-top: 10px">
                <h4 class="col-md-12 tieudeGroup" style="color: #1b809e">Thông tin công ty</h4>
            </div>


            <div class="form-group">
                <label class="col-md-3">Tên công ty<span class="require">*</span></label>
                <label class="col-md-9">
                    @Html.TextBoxFor(m => m.tenCongTy, new { @class = "form-control", @required = "required",@maxlength="300" })
                </label>
            </div>
            <div class="form-group">
                <label class="col-md-3">Mã số thuế</label>
                <label class="col-md-9">
                    @Html.TextBoxFor(m => m.maSoThue, new { @class = "form-control",@maxlength="25" })
                </label>
            </div>
            <div class="form-group">
                <label class="col-md-3">Quy mô công ty<span class="require">*</span></label>
                <label class="col-md-9">
                    @Html.DropDownListFor(m => m.quiMoCongTy, ViewBag.quiMo as SelectList, new { @class = "form-control", @required = "required" })
                </label>
            </div>
            <div class="form-group">
                <label class="col-md-3">Giới thiệu về công ty</label>
                <label class="col-md-9">
                    @Html.TextAreaFor(m => m.gioiThieuCongTy, new { @class = "form-control", @placeholder = "Giới thiệu lịch sử.."})
                </label>
            </div>
            <div class="form-group">
                <label class="col-md-3">Lĩnh vực hoạt động</label>
                <label class="col-md-9">
                    @Html.TextAreaFor(m => m.linhVucHoatDong, new { @class = "form-control", @placeholder = "Lĩnh vực hoạt động.." })
                </label>
            </div>
            <div class="form-group bs-callout bs-callout-info" style="overflow: hidden; margin-top: 10px">
                <h4 class="col-md-12 tieudeGroup" style="color: #1b809e">Danh sách hồ sơ năng lực</h4>
            </div>
            <div class="form-group">
                <label class="col-md-3"></label>
                <div class="col-md-9">
                    <div id="container">
                        <table class="table" id="tbl-uploading">
                            <thead>
                                <tr>
                                    <th colspan="2">Tên hồ sơ</th>
                                    <th>Ngày upload</th>
                                    <th style="width: 100px">
                                        <input type="file" style="height: 30px; display: none" name="fileDinhKems" id="input-upload-NangLuc" class="form-control" multiple="multiple" value="" />
                                        <label class="btn btn-info btn-xs btn-link" style="font-size: 12px" for="input-upload-NangLuc">Chọn tập tin</label>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (fileDinhKem != null && fileDinhKem.Count > 0)
                                {
                                    foreach (var item in fileDinhKem)
                                    {
                                    <tr>
                                        <td style="text-align: left">
                                            <img style="width:32px; height: 32px" src="@item.ThumBailURL"></td>
                                        <td>@item.TenFileDinhKem</td>
                                        <td>@item.NgayUp.Value.ToString("dd/MM/yyyy hh:mm:ss tt")</td>
                                        <td style="text-align: right">
                                            <button class="btn btn-link btn-xs btnDownload" type="button" value="@item.Id"><i class="fa fa-download" aria-hidden="true"></i></button>
                                            <a href="javascript:void(0)" style="color: #519ee5" onclick="javascript:deleteImage(this)" data-identity="@item.Id">Xóa</a>
                                        </td>
                                    </tr> 
                                    }
                                }
                            </tbody>
                        </table>

                    </div>
                </div>
            </div>
            <div class="form-group bs-callout bs-callout-info" style="overflow: hidden; margin-top: 10px">
                <h4 class="col-md-12 tieudeGroup" style="color: #1b809e">Thông tin liên hệ</h4>
            </div>
            <div class="form-group">
                <label class="col-md-3">Giám đốc</label>
                <label class="col-md-9">
                    @Html.TextBoxFor(m => m.giamDoc, new { @class = "form-control" ,@maxlength="50"})
                </label>
            </div>
            <div class="form-group">
                <label class="col-md-3">Địa chỉ công ty<span class="require">*</span></label>
                <label class="col-md-9">
                    @Html.TextBoxFor(m => m.diaChiCongTy, new { @class = "form-control", @required = "required" ,@maxlength="400"})
                </label>
            </div>
            <div class="form-group">
                <label class="col-md-3">Điện thoại cố định<span class="require">*</span></label>
                <label class="col-md-9">
                    @Html.TextBoxFor(m => m.dienThoaiCongTy, new { @class = "form-control", @required = "required" ,@maxlength="30"})
                </label>
            </div>
            <div class="form-group">
                <label class="col-md-3">Fax công ty</label>
                <label class="col-md-9">
                    @Html.TextBoxFor(m => m.faxCongTy, new { @class = "form-control" ,@maxlength="30"})
                </label>
            </div>
            <div class="form-group">
                <label class="col-md-3">Mail công ty</label>
                <label class="col-md-9">
                    @Html.TextBoxFor(m => m.mailCongTy, new { @class = "form-control", @type = "email" ,@maxlength="40"})
                </label>
            </div>

            <div class="form-group">
                <label class="col-md-3">Website</label>
                <label class="col-md-9">
                    @Html.TextBoxFor(m => m.webSite, new { @class = "form-control" ,@maxlength="30"})
                </label>
            </div>
            <div class="form-group bs-callout bs-callout-info" style="overflow: hidden; margin-top: 10px">
                <h4 class="col-md-12 tieudeGroup" style="color: #1b809e">Thông tin ngân hàng</h4>
            </div>
            <div class="form-group">
                <label class="col-md-3">Ngân hàng</label>
                <label class="col-md-9">
                    @Html.TextBoxFor(m => m.tenNganHang, new { @class = "form-control" ,@maxlength="200"})
                </label>
            </div>
            <div class="form-group">
                <label class="col-md-3">Chi nhánh</label>
                <label class="col-md-9">
                    @Html.TextBoxFor(m => m.chiNhanhNganHang, new { @class = "form-control",@maxlength="300" })
                </label>
            </div>
            <div class="form-group">
                <label class="col-md-3">Số tài khoản</label>
                <label class="col-md-9">
                    @Html.TextBoxFor(m => m.soTaiKhoanNganHang, new { @class = "form-control" ,@maxlength="30"})
                </label>
            </div>
            <div class="form-group">
                <label class="col-md-3">Tên tài khoản</label>
                <label class="col-md-9">
                    @Html.TextBoxFor(m => m.tenTaiKhoanNganHang, new { @class = "form-control",@maxlength="50" })
                </label>
            </div>

            <div class="form-group bs-callout bs-callout-info" style="overflow: hidden; margin-top: 10px">
                <h4 class="col-md-12 tieudeGroup" style="color: #1b809e">Thông tin người đại diện</h4>
            </div>
            <div class="form-group">
                <label class="col-md-3">Tên người đại diện<span class="require">*</span></label>
                <label class="col-md-9">
                    @Html.TextBoxFor(m => m.tenNguoiDaiDien, new { @class = "form-control", @required = "required" ,@maxlength="100"})
                </label>
            </div>
            <div class="form-group">
                <label class="col-md-3">Số điện thoại liên hệ <span class="require">*</span></label>
                <label class="col-md-9">
                    @Html.TextBoxFor(m => m.soDienThoaiNguoiDaiDien, new { @class = "form-control", @required = "required",@maxlength="30" })
                </label>
            </div>
            <div class="form-group">
                <label class="col-md-3">Email liên hệ <span class="require">*</span></label>
                <label class="col-md-9">
                    @Html.TextBoxFor(m => m.mailNguoiDaiDien, new { @class = "form-control", @required = "required", @type = "email",@maxlength="40" })
                </label>
            </div>
            <div class="form-group bs-callout bs-callout-info" style="overflow: hidden; margin-top: 10px">
                <h4 class="col-md-12 tieudeGroup" style="color: #1b809e">Thông tin đăng nhập</h4>
            </div>
            <div class="form-group">
                <label class="col-md-3">Tên đăng nhập</label>
                <label class="col-md-9">
                    @Html.TextBoxFor(m => m.userName, new { @class = "form-control", @readonly = true, @style = "pointer-events: none;",@maxlength="50" })
                </label>

            </div>
            <div class="form-group">
                <label class="col-md-3">Mật khẩu cũ</label>
                <label class="col-md-9">
                    @Html.Hidden("MatKhauCu", Model.matKhau)
                    <input type="password" class="form-control" id="MatKhauCuNhapVao" maxlength="50" />

                </label>
            </div>
            <div class="form-group">
                <label class="col-md-3">Mật khẩu mới</label>
                <label class="col-md-9">
                    @Html.PasswordFor(m => m.matKhau, new { @class = "form-control",@maxlength="50" })
                </label>
            </div>
            <div class="form-group">
                <label class="col-md-3">Xác nhận lại mật khẩu</label>
                <label class="col-md-9">
                    <input type="password" class="form-control" name="rePassword" maxlength="50">
                </label>
            </div>
            <div class="form-group">
                <label class="col-md-12" style="text-align: right">
                    <button id="btnSubmit" type="submit" class="btn btn-info">Cập nhật</button>
                    <button id="btnTroVe" type="button" class="btn btn-info">Trở về</button>

                </label>
            </div>

        </form>
    </div>
</fieldset>

