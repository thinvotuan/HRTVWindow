@using BatDongSan.Models.NhanSu;
@model IPagedList<sp_NS_ThuNhapKhac_IndexResult>
@{
    int i = 1;
}
<script>
    function beginPaging(args) {
        // Animate        
        $('#content').fadeOut('fast');
    }

    function successPaging() {
        // Animate
        $('#content').fadeIn('normal');
    }

    function failurePaging() {
        alert("Không thể tải dữ liệu");
    }

</script>
@{
    BatDongSan.Models.HeThong.Sys_User user1 = new BatDongSan.Models.HeThong.Sys_User();
    if (Session["User"] != null)
    {
        user1 = (BatDongSan.Models.HeThong.Sys_User)Session["User"];
    }
}
<table class="table table-striped table-hover table-condensed" id="maintable">
    <thead>
        <tr>
            <th style="width: 35px">STT</th>
            <th style="width: 150px">Số phiếu</th>
            @*<th style="width: 170px">Phòng ban</th>*@
            <th style="width: 150px">Người lập</th>
            <th style="width: 50px">Tháng</th>
            <th style="width: 50px">Năm</th>
            <th style="width: 100px">Loại thu nhập</th>
            <th style="width: 80px">Số tiền</th>
            <th style="width: 180px">Lý do</th>
            <th style="width: 80px">Trạng thái</th>
            <th style="width: 80px"></th>
        </tr>
    </thead>
    <tbody id="load">

        @foreach (var item in Model)
        {
            <tr>
                <td style="text-align: center">@i</td>
                <td>
                    <i class="fa fa-user"></i><a style="color:blue" href="@Url.Action("Details", "ThuNhapKhac", new { id = item.id })">@item.id</a>
                    @{
            if (item.LapLai == 1) { 
             <br />
            <a href="javascript:void(0);" onclick="XuatExcelFailed('@item.id')">
                     <i class="fa fa-arrow-down" aria-hidden="true"></i> Danh sách không import</a>
            }
                        }
                   
                    
                    
                </td>
               @* <td>@item.tenPhongBan
                    <br />
                    <i class="fa fa-ticket" aria-hidden="true"></i>@item.TenChucDanh
                </td>*@
                <td>
                    <i class="fa fa-user"></i>@item.nguoiLap
                    <br />
                    <i class="fa fa-calendar" aria-hidden="true"></i>@String.Format("{0: dd/MM/yyyy}", item.ngayLap)


                </td>
                <td style="text-align: center">@item.thang</td>
                <td style="text-align: center">@item.nam</td>
                <td>
                    @item.tenLoaiThuNhapKhac
                </td>
                <td style="text-align: right">
                    @String.Format("{0:#,##0}", item.soTien)
                </td>
                <td>@Html.Raw(item.LyDo)</td>
                <td style="text-align: center">
                    <a href="javascript:void(0);" onclick="ViewDetailHistory('@item.id','@item.maQuiTrinhDuyet')">
                        @item.tenTrangThaiDuyet</a>
                </td>
                <td style="text-align: center">
                    @if (item.maNVL == user1.manv && item.trangThai == 0)
                    {
                        <a href="@Url.Action("Edit", "ThuNhapKhac", new { id = item.id })" title ="Sửa phiếu"><i class="fa fa-pencil-square-o" style="font-size: 30px; color: orange;" aria-hidden="true">| </i></a>
                        <a class="btnDelete" alt="@item.id" title ="Xoá phiếu"><i class="fa fa-trash" style="font-size: 30px; color: red; cursor: pointer;" aria-hidden="true"></i></a>
                    }
                </td>
            </tr> 
                    i++;
        }
    </tbody>
</table>
<div>
    Trang @Model.PageNumber của @Model.PageCount / @ViewBag.Count
</div>
<div>
    <ul class="pagination">
        @Html.Raw(Ajax.Pager(new AjaxOptions { UpdateTargetId = "content", OnBegin = "beginPaging", OnSuccess = "successPaging", OnFailure = "failurePaging" }, Model.PageSize, Model.PageNumber, Model.TotalItemCount, new { controller = "ThuNhapKhac", action = "ViewIndex", qSearch = ViewBag.Search, thang = ViewBag.thang, nam = ViewBag.nam, trangThai = ViewBag.trangThai }))
    </ul>
</div>
