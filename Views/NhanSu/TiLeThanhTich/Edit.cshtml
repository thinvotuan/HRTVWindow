<form id="form-submit" class="form-horizontal" method="post">
    <div id="container" class="custome_fieldSet">
        <fieldset class="removeBorderFieldset">
            <div id="tabs" style="width: 30%; height: auto; border: none; float: left; box-sizing: border-box; overflow: hidden; clear: none;" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                    <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active ">
                        <a><span><i class="fa fa-plus-square-o" aria-hidden="true"></i>Sửa tỉ lệ thành tích</span></a></li>
                </ul>
            </div>
            <table class="table table-striped table-hover table-condensed" id="tbl-create" style="position: relative">
                <tr>
                    <td style="width: 15%" class="tdtitle">Mã nhân viên
                         <input type="hidden" id="url" value="@ViewBag.URL" />

                    </td>
                    <td style="width: 35%">@Html.TextBoxFor(model => model.NhanVien.maNhanVien, new { @class = "form-control", @readonly = true })</td>
                    <td style="width: 15%" class="tdtitle">Tên nhân viên </td>
                    <td style="width: 35%">@Html.TextBoxFor(model => model.NhanVien.hoVaTen, new { @class = "form-control", @readonly = true })</td>
                </tr>
                <tr>
                    <td class="tdtitle">Số phiếu </td>
                    <td>@Html.TextBoxFor(model => model.maPhieu, new { @class = "form-control", @readonly = true })</td>
                    <td class="tdtitle">Phòng ban </td>
                    <td>@Html.TextBoxFor(model => model.tenPhongBan, new { @class = "form-control", @readonly = true, @Style = "width:100%;  margin-right: 5px;   float: left;" })
                        @Html.HiddenFor(model => model.maPhongBan)
                    </td>

                </tr>

                <tr>
                    <td class="tdtitle">Áp dụng từ</td>
                    <td colspan="3">
                        <span style="float: left">Tháng:@Html.DropDownList("quy", ViewData["Quys"] as SelectList, new { @style = "width:150px" })
                            Năm:@Html.DropDownList("nam", ViewData["Nams"] as SelectList, new { @style = "width:150px" })
                        </span>
                        <span style="float: left; color: red; background: yellow; margin-left: 50px; padding: 2px; display: none" class="showQuyNam"></span>
                    </td>
                </tr>


                <tr>
                    <td class="tdtitle">Nội dung</td>
                    <td colspan="3">
                        <div id="editor">@Html.Raw(Model.noiDung)</div>
                        @Html.HiddenFor(model => model.noiDung, new { @class = "form-control" })
                    </td>

                </tr>
            </table>
            <br />
            <label>
                @*<button class="btn btn-link btn-sm" id="btnNhanVien" type="button" data-toggle="modal" data-target="#myModal">Thêm nhân viên</button>*@
                <button class="btn btn-link btn-sm" id="btnNhanVien" type="button">Thêm nhân viên</button>
            </label>
            <div id="containerNhanVien">
                <table class="table table-striped table-hover table-condensed" id="tbl-users">
                    <thead>
                        <tr id="trtop">
                            <th>STT</th>
                            <th  style="width: 100px">Mã nhân viên</th>
                            <th style="width: 200px">Họ và tên</th>
                            <th>Phòng ban</th>
                            <th style="width: 80px; text-align: center">Tỷ lệ</th>

                            <th style="width: 150px">Lương thành tích</th>

                            <th style="width: 150px">Khoản bổ sung lương</th>
                            <th style="width: 150px">Thuế</th>
                            <th style="width: 150px">Thực lãnh</th>
                            <th style="width: 40px"></th>
                        </tr>
                    </thead>
                    <tbody id="tbodyNV">
                        @if (nhanVienThuocNhoms != null)
                        {
                            foreach (var item in nhanVienThuocNhoms)
                            {
                            <tr id="rowNV_@item.maNhanVien" class="rowHienTaiNV">
                                <td>@(i++)</td>
                                <td>@item.maNhanVien
                                    <input type="hidden" value="@item.maNhanVien" name="ValmaNhanVien" />
                                </td>
                                <td>@item.hoVaTen</td>
                                <td>@item.tenPhongBan</td>
                                <td>
                                    <input name="tyLe" class="numperInput valTyLe" style="width: 50px; float: left; background-color: rgba(226, 226, 66, 0.26); text-align: right" type="text" value="@item.tyle">%</td>
                                <td><span class="numberinput lbThanhTich" style="float: right">@item.ThanhTich</span>
                                    <input type="hidden" value="@item.ThanhTich" name="valThanhTichBD" class="valThanhTichBD"   />
                                    <input type="hidden" value="@item.ThanhTich" name="valThanhTich" class="valThanhTich"   />

                                </td>
                                <td>
                                   <input type="text" value="@item.khoanBoSungLuong" name="valKhoanBSLuongBD" class="numberinput valKhoanBSLuongBD" style="text-align:right"   />
                   <input type="hidden" value="@item.khoanBoSungLuong" name="valKhoanBSLuong" class="valKhoanBSLuong" />

                                </td>
                                <td><span class="numberinput lbThue" style="float: right">@item.Thue</span>
                                    <input type="hidden" value="@item.Thue" name="valThue" class="valThue" />
                                </td>
                                <td>
                                    <span class="numberinput labThucNhan" style="float: right">@item.TienThucNhan</span>
                                    <input type="hidden" value="@item.TienThucNhan" name="valThucNhan"class="valThucNhan" />
                                </td>

                                <td style="text-align: center">
                                    <a href="javascript:void(0);" class="clsXoa" style="color: Blue">Xóa</a>
                                </td>

                            </tr> 
                              
                            }
                        }
                    </tbody>
                </table>
            </div>
            <br />
            <div style="text-align: right; margin-bottom: 10px">
                <label class="checkbox-inline">@Html.CheckBoxFor(model => model.xacNhan, new { style = "width:auto" })Hoàn tất?</label>
                <button class="btn btn-info" id="btnSubmit" type="button">Lưu </button>


                <button class="btn btn-info" type="button" id="btnTroVe">Trở về </button>
            </div>
        </fieldset>

    </div>
</form>

<div id="myModal" class="modal fade" role="dialog">
    <div class="modal-dialog" style="width: 900px">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-body">
                <div class="container" style="width: 98%">
                    <div class="row">
                        <div style="position: relative">
                            <input type="text" id="searchString" class="form-control" style="padding-right: 30px; border-radius: 50px" placeholder="Search" onkeyup="enterToSeacrh(event)">
                            <i class="fa fa-search" id="btnSearch" style="position: absolute; cursor: pointer; top: 6px; right: 7px;"></i>
                        </div>
                        <div id="filter-panel" class="filter-panel" style="padding-top: 10px;">
                            <div class="panel panel-default" style="border: none">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary btn-sm" id="btnAccept">
                    <span class="glyphicon glyphicon-ok"></span>&nbsp;Đồng ý
                </button>
                <button type="button" class="btn btn-default" data-dismiss="modal" id="btnClose">Hủy</button>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript" src="~/Scripts/JQuery/calendar/include/ui-1.10.0/jquery-1.9.0.min.js"></script>
<link rel="stylesheet" href="~/Scripts/JQuery/calendar/include/ui-1.10.0/ui-lightness/jquery-ui-1.10.0.custom.min.css" />
<link rel="stylesheet" href="~/Scripts/JQuery/calendar/include/jquery.ui.timepicker.css" />

<script type="text/javascript" src="~/Scripts/JQuery/calendar/include/ui-1.10.0/jquery.ui.core.min.js"></script>
<script type="text/javascript" src="~/Scripts/JQuery/calendar/include/jquery.ui.timepicker.js"></script>
<script type="text/javascript" src="~/Scripts/JQuery/select2.full.js"></script>
<link rel="stylesheet" href="~/Content/css/select2.min.css" />

<script type="text/javascript">        jQuery.noConflict(); </script>


<script>
    jQuery(document).ready(function ($) {
        $('#gioBatDau').timepicker({
            showAnim: 'blind'
        });

        $('#gioKetThuc').timepicker({
            showAnim: 'blind'
        });

        $('#thoiGianNghiGiuaCa').timepicker({
            showAnim: 'blind'
        });

        $('#thoiGianNghiKetThucGiuaCa').timepicker({
            showAnim: 'blind'
        });

        $("#gioKetThuc").change(function () {
            checkEndTime();
        });

        $("#gioBatDau").change(function () {
            checkEndTime();
        });

        $("#thoiGianNghiGiuaCa").change(function () {
            CheckThoiGianBatDauNghiGiuaCa();
            if ($("#thoiGianNghiKetThucGiuaCa").val() != "") {
                GenerateThoiGianNghiGiuaCa();
            }

        });

        $("#thoiGianNghiKetThucGiuaCa").change(function () {
            CheckThoiGianBatDauNghiGiuaCa();
            if ($("#thoiGianNghiKetThucGiuaCa").val() != "") {
                GenerateThoiGianNghiGiuaCa();
            }

        });
    });

</script>
