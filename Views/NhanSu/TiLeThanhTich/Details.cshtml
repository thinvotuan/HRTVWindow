@using BatDongSan.Models.NhanSu;
@model TiLeThanhTich
@{
    ViewBag.Title = "Cập nhật tỉ lệ thành tích";
    Layout = "~/Views/Shared/_Layout.cshtml";
    List<BatDongSan.Models.NhanSu.NhanVienModel> nhanVienThuocNhoms = ViewBag.ChiTietNhanVien;
    int i = 1;
}
<link rel="stylesheet" href="~/Content/summernote/summernote.css" />
<script src="~/Content/summernote/summernote.js"></script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/additional-methods.min.js"></script>
<script src="~/Scripts/autoNumeric.js"></script>
<script src="~/Scripts/batdongsan.validate.js"></script>
<script src="~/Scripts/moment.min.js"></script>
<script src="~/Scripts/vi.js"></script>
<script src="~/Scripts/bootstrap-datetimepicker.min.js"></script>
<link rel="stylesheet" href="~/Content/bootstrap-datetimepicker.min.css" />
<script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>


<script>
    $(document).ready(function () {
        $(".numberinput").autoNumeric('init', { mDec: 1, mNum: 3, lZero: 'deny', aSep: ',', aDec: '.', pSign: 's', vMin: '0' });
        $(".numberinputInt").autoNumeric('init', { lZero: 'deny', mDec: 0, pSign: 's', aSep: ',', aDec: '.' });
        $("#btnTroVe").click(function () {
            var url = "@Url.Action("Index")";
            location.href = url;
        });
        $('#editor').summernote({
            height: 150,                 // set editor height
            minHeight: null,             // set minimum height of editor
            maxHeight: null             // set maximum height of editor
            //focus: true                  // set focus to editable area after initializing summernote
        });
        $(".timepicker").datetimepicker({
            locale: 'vi',
            format: 'HH:mm'
        });












    });

    function beginPaging(args) {
        // Animate         
        $('#content').fadeOut('fast');
    }

    function successPaging() {
        // Animate        
        $('#content').fadeIn('fast');
    }
















    function Generate() {
        var startDate = $("#ngayBatDau").val();
        var endDate = $("#ngayKetThuc").val();
        $.post('@Url.Action("Generate", "PhieuCongTac")', { dateOne: startDate, dateTwo: endDate }, function (data) {
            if (data != null) {
                $("#soNgayCongTac").val(data.soNgay);
            }
        });
    }
    function CheckForm() {
        var flag = true;

        //if ($("#lyDo").val() == "") {
        //    $("#lyDo").addClass("error").attr("title", "Vui lòng nhập lý do.");
        //    flag = false;

        //}


        if ($("#tbody tr").length == 0) {
            Alert.error("Bạn phải nhập ít nhất 1 nhân viên.", "Thông báo", { displayDuration: 3000 });
            flag = false;
        }
        return flag;
    }

    function enterToSeacrh(event) {
        if (event.keyCode == 13)
            $("#btnSearch").click();
    }

    function PopUpManager(url, title, w, h) {
        var left = (screen.width / 2) - (w / 2);
        var top = (screen.height / 2) - (h / 2);
        var targetWin = window.open(url, title, 'width=' + w + ', height=' + h + ', top=' + top + ', left=' + left);
    }

    function LoadLaiTrang() {
        location.href = '@Url.Action("Details/", "TiLeThanhTich")' + $('#maPhieu').val();
    }

    function DeleteRow(id_tbody, index, sTT) {
        var table = document.getElementById(id_tbody);
        table.deleteRow(index);
        for (var i = 0; i < table.rows.length; i++) {
            if (sTT == null)
                $('#' + id_tbody + ' tr:eq(' + i + ')').find("td:last").html("<a href='javascript:void(0);' onclick='DeleteRow(\"" + id_tbody + "\"," + i + ")'>Xóa</a>");
            else {
                $('#' + id_tbody + ' tr:eq(' + i + ')').find("td:first").html(i + 1);
                $('#' + id_tbody + ' tr:eq(' + i + ')').find("td:last").html("<a href='javascript:void(0);' onclick='DeleteRow(\"" + id_tbody + "\"," + i + ", true)'>Xóa</a>");
            }
        }
    }

</script>
<style>
    #tbl-create td
    {
        border: none;
    }
</style>
@{
    BatDongSan.Models.HeThong.Sys_User user1 = new BatDongSan.Models.HeThong.Sys_User();
    if (Session["User"] != null)
    {
        user1 = (BatDongSan.Models.HeThong.Sys_User)Session["User"];
    }
}

<form id="form-submit" class="form-horizontal" method="post">
    <div id="container" class="custome_fieldSet">
        <fieldset class="removeBorderFieldset">
            <div id="tabs" style="width: 30%; height: auto; border: none; float: left; box-sizing: border-box; overflow: hidden; clear: none;" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                    <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active ">
                        <a><span><i class="fa fa-plus-square-o" aria-hidden="true"></i>Chi tiết tỉ lệ thành tích</span></a></li>
                </ul>
            </div>
            <table class="table table-striped table-hover table-condensed" id="tbl-create" style="position: relative">
                <tr>
                    <td style="width: 15%" class="tdtitle">Mã nhân viên
                         <input type="hidden" id="url" value="@ViewBag.URL" />

                    </td>
                    <td style="width: 35%">@Html.TextBoxFor(model => model.NhanVien.maNhanVien, new { @class = "form-control", @readonly = true })</td>
                    <td style="width: 15%" class="tdtitle">Tên nhân viên </td>
                    <td style="width: 35%">@Html.TextBoxFor(model => model.NhanVien.hoVaTen, new { @class = "form-control", @readonly = true })</td>
                </tr>
                <tr>
                    <td class="tdtitle">Số phiếu </td>
                    <td>@Html.TextBoxFor(model => model.maPhieu, new { @class = "form-control", @readonly = true })</td>
                    <td class="tdtitle">Phòng ban </td>
                    <td>@Html.TextBoxFor(model => model.tenPhongBan, new { @class = "form-control", @readonly = true, @Style = "width:100%;  margin-right: 5px;   float: left;" })
                        @Html.HiddenFor(model => model.maPhongBan)
                    </td>

                </tr>

                <tr>
                    <td class="tdtitle">Áp dụng từ</td>
                    <td colspan="3">Tháng:@Html.DropDownList("quy", ViewData["Quys"] as SelectList, new { @style = "width:150px" })
                        Năm:@Html.DropDownList("nam", ViewData["Nams"] as SelectList, new { @style = "width:150px" })</td>

                </tr>


                <tr>
                    <td class="tdtitle">Nội dung</td>
                    <td colspan="3">
                        <div id="editor">@Html.Raw(Model.noiDung)</div>
                        @Html.HiddenFor(model => model.noiDung, new { @class = "form-control" })
                    </td>

                </tr>
            </table>
            <br />
            <label>
            </label>
            <div id="containerNhanVien">
                <table class="table table-striped table-hover table-condensed" id="tbl-users">
                    <thead>
                        <tr id="trtop">

                            <th>STT</th>
                            <th  style="width: 100px">Mã nhân viên</th>
                            <th style="width: 200px">Họ và tên</th>
                            <th>Phòng ban</th>
                            <th style="width: 80px; text-align: center">Tỷ lệ</th>

                            <th style="width: 150px">Lương thành tích</th>
                            
                            <th style="width: 150px">Khoản bổ sung lương</th>
                            <th style="width: 150px">Thuế</th>
                            <th style="width: 150px">Thực lãnh</th>

                        </tr>
                    </thead>
                    <tbody id="tbody">
                        @if (nhanVienThuocNhoms != null)
                        {
                            foreach (var item in nhanVienThuocNhoms)
                            {
                            <tr id="rowNV_@item.maNhanVien" class="rowHienTaiNV">
                                <td style="text-align: center">@(i++)</td>
                                <td>@item.maNhanVien
                                    <input type="hidden" value="@item.maNhanVien" name="ValmaNhanVien" />
                                </td>
                                <td>@item.hoVaTen</td>
                                <td>@item.tenPhongBan</td>
                                <td style="text-align: right">
                                    <span>@item.tyle %</span></td>
                                <td><span class="numberinput lbThanhTich" style="float: right">@item.ThanhTich</span>


                                </td>
                                <td><span class="numberinput lbBoSungLuong" style="float: right">@item.khoanBoSungLuong</span>

                                </td>
                                <td><span class="numberinput lbThue" style="float: right">@item.Thue</span>

                                </td>
                                <td>
                                    <span class="numberinput labThucNhan" style="float: right">@item.TienThucNhan</span>
                                </td>


                            </tr> 
                                
                            }
                        }
                    </tbody>
                </table>
            </div>
            <br />
            <div style="text-align: right; margin-bottom: 10px">
                <label class="checkbox-inline">@Html.CheckBoxFor(model => model.xacNhan, new { style = "width:auto" })Hoàn tất</label>



                <button class="btn btn-info" type="button" id="btnTroVe">Trở về </button>
            </div>
        </fieldset>

    </div>
</form>



<script type="text/javascript" src="~/Scripts/JQuery/calendar/include/ui-1.10.0/jquery-1.9.0.min.js"></script>
<link rel="stylesheet" href="~/Scripts/JQuery/calendar/include/ui-1.10.0/ui-lightness/jquery-ui-1.10.0.custom.min.css" />
<link rel="stylesheet" href="~/Scripts/JQuery/calendar/include/jquery.ui.timepicker.css" />

<script type="text/javascript" src="~/Scripts/JQuery/calendar/include/ui-1.10.0/jquery.ui.core.min.js"></script>
<script type="text/javascript" src="~/Scripts/JQuery/calendar/include/jquery.ui.timepicker.js"></script>
<script type="text/javascript" src="~/Scripts/JQuery/select2.full.js"></script>
<link rel="stylesheet" href="~/Content/css/select2.min.css" />

<script type="text/javascript">        jQuery.noConflict(); </script>


<script>
    jQuery(document).ready(function ($) {
        $('#gioBatDau').timepicker({
            showAnim: 'blind'
        });

        $('#gioKetThuc').timepicker({
            showAnim: 'blind'
        });

        $('#thoiGianNghiGiuaCa').timepicker({
            showAnim: 'blind'
        });

        $('#thoiGianNghiKetThucGiuaCa').timepicker({
            showAnim: 'blind'
        });

        $("#gioKetThuc").change(function () {
            checkEndTime();
        });

        $("#gioBatDau").change(function () {
            checkEndTime();
        });

        $("#thoiGianNghiGiuaCa").change(function () {
            CheckThoiGianBatDauNghiGiuaCa();
            if ($("#thoiGianNghiKetThucGiuaCa").val() != "") {
                GenerateThoiGianNghiGiuaCa();
            }

        });

        $("#thoiGianNghiKetThucGiuaCa").change(function () {
            CheckThoiGianBatDauNghiGiuaCa();
            if ($("#thoiGianNghiKetThucGiuaCa").val() != "") {
                GenerateThoiGianNghiGiuaCa();
            }

        });
    });

</script>
