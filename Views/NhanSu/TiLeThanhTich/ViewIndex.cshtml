@using BatDongSan.Models.NhanSu;
@model IPagedList<sp_NS_TiLeThanhTich_IndexResult>
@{
    int i = 1;
}
<script>
    function beginPaging(args) {
        // Animate        
        $('#content').fadeOut('fast');
    }

    function successPaging() {
        // Animate
        $('#content').fadeIn('normal');
    }

    function failurePaging() {
        alert("Không thể tải dữ liệu");
    }

</script>

@{
    BatDongSan.Models.HeThong.Sys_User user1 = new BatDongSan.Models.HeThong.Sys_User();
    if (Session["User"] != null)
    {
        user1 = (BatDongSan.Models.HeThong.Sys_User)Session["User"];
    }
}
<table class="table table-striped table-hover table-condensed" id="maintable">
    <thead>
        <tr>
            <th style="width: 45px">STT</th>
            <th style="width: 125px">Số phiếu</th>
            <th style="width: 120px">Nhân viên</th>
            <th style="width: 135px">Phòng ban</th>
            <th style="width: 80px; text-align:center">Tháng/Quý - Năm</th>
            <th style="width: 80px">Trạng thái</th>
        </tr>
    </thead>
    <tbody id="load">

        @foreach (var item in Model)
        {
            <tr>
                <td style="text-align: center">@i</td>
                <td><i class="fa fa-clipboard"></i><a style="color:blue" href="@Url.Action("Details", "TiLeThanhTich", new { id = item.soPhieu })">@item.soPhieu</a>
                    <br />
                    <i class="fa fa-calendar" aria-hidden="true"></i>@String.Format("{0: dd/MM/yyyy}", item.ngaylap)
                </td>
                <td><i class="fa fa-user"></i>@item.hoTen
                    <br />
                    <i class="fa fa-credit-card" aria-hidden="true"></i>@item.nguoiLap
                </td>
                <td>@item.tenPhongBan
                    <br />
                    <i class="fa fa-ticket" aria-hidden="true"></i>@item.TenChucDanh
                </td>
                
               
                <td style="text-align: center">
                    @item.quy - @item.nam
                    <br />
                </td>
               
                <td style="text-align: center">
                    @if (item.xacNhan == false || item.xacNhan == null)
                    {   <a href="@Url.Action("Edit", "TiLeThanhTich", new { id = item.soPhieu })" title ="Sửa phiếu"><i class="fa fa-pencil-square-o" style="font-size: 30px; color: orange;" aria-hidden="true"> | </i></a>                         
                        <a class="btnDelete" alt="@item.soPhieu" title ="Xoá phiếu"><i class="fa fa-trash" style="font-size: 30px; color: red; cursor: pointer;" aria-hidden="true"></i></a>
                      
                    }
                </td>
            </tr> 
                    i++;
        }
    </tbody>
</table>
<div>
    Trang @Model.PageNumber của @Model.PageCount / @ViewBag.Count
</div>
<div>
    <ul class="pagination">
        @Html.Raw(Ajax.Pager(new AjaxOptions { UpdateTargetId = "content", OnBegin = "beginPaging", OnSuccess = "successPaging", OnFailure = "failurePaging" }, Model.PageSize, Model.PageNumber, Model.TotalItemCount, new { controller = "TiLeThanhTich", action = "ViewIndex", qSearch = ViewBag.Search, quy = ViewBag.quy, nam = ViewBag.nam }))
    </ul>
</div>
