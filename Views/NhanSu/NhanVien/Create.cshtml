<style>
    .successOk
    {
        color: green;
    }
</style>
<script type="text/javascript">
    $(document).ready(function () {
        $("#maChamCong").on("input", function () {
            if ($("#maChamCong").val() != "") {
                $.ajax({
                    type: "POST",
                    url: "/DanhSachCongNhan/CheckMaChamCong",
                    data: {

                        maChamCong: $("#maChamCong").val()

                    },
                    error: function () {
                        alert("Error");
                        return false;
                    },
                    success: function (result) {

                        if (result == 1) {

                            $(".maCCInfor").html('Mã chấm công này đã tồn tại').addClass('error').removeClass("successOk");
                            $("#maChamCong").addClass("error");

                            $("#btnSubmit").hide();

                        }
                        else {
                            $(".maCCInfor").html('Mã chấm công này có thể sử dụng').removeClass('error').addClass("successOk");
                            $("#maChamCong").removeClass("error");
                            if ($("#maCongNhan").hasClass("error") == false && $("#maChamCong").hasClass("error") == false) {
                                $("#btnSubmit").show();
                            }
                        }


                    }
                });
            }
            else {
                $(".maCCInfor").html('').removeClass('error').addClass("successOk");
                $("#maChamCong").removeClass("error");
                if ($("#maCongNhan").hasClass("error") == false && $("#maChamCong").hasClass("error") == false) {
                    $("#btnSubmit").show();
                }
            }

        });
        $("#btnSubmit").click(function () {
            var maPhanCa = $("#maPhanCa").val();
            if (maPhanCa == 0 || maPhanCa == '') {
                Alert.warning("Vui lòng chọn phân ca.", "Thông báo", { displayDuration: 2000 });
                return false;
            }
            var maPhongBan = $("#maPhongBan").val();
            if (maPhongBan == '') {
                Alert.warning("Vui lòng chọn phòng ban.", "Thông báo", { displayDuration: 2000 });
                return false;
            }

        });
        $('#btnSearch').click(function () {
            var searchText = $('#searchString').val().replace(/\ /g, '+');
            var url = "@Url.Action("Index", "NhanVien")" + "?searchString=" + searchText;
            beginPaging();
            $('#content').html('<h4>Loading...</h4>').load(url);
            successPaging();
        });

        $('#btnPhongBan').click(function () {
            var url = '/NhanVien/PhongBanListTree';
            $('#phongban-panel').load(url);
        })

        $(".datepicker").datetimepicker({
            locale: 'vi',
            format: 'DD/MM/YYYY'
        });

        $("#hinhAnh").change(function (evt) {
            var img = document.getElementById("mgAvartar");
            img.src = URL.createObjectURL(evt.target.files[0])
        })

        $("#phongBanModal").on("hide.bs.modal", function () {
            $("#phongban-panel").html("");
        });

        $("#btnTroVe").click(function () {
            location.href = "/NhanVien";
        })

        $("#tamTruTinhThanh, #thuongTruTinhThanh").change(function () {
            var quanHuyen = $(this).parent().next().find("select");
            quanHuyen.empty();
            $.ajax({
                url: "/NhanVien/GetQuanHuyen/" + this.value,
                type: "POST",
                dataType: "json",
                success: function (data) {
                    var textAppend = "<option value=''>[Chọn quận huyện]</option>";
                    $.each(data, function (i, quanHuyen) {
                        textAppend += "<option value=" + quanHuyen.id + ">" + quanHuyen.tenQuanHuyen + "</option>";
                    });
                    quanHuyen.append(textAppend);
                }
            })
        })
    })

    function beginPaging(args) {
        // Animate        
        $('#content').fadeOut('fast');
    }

    function successPaging() {
        // Animate
        $('#content').fadeIn('normal');
    }

    function failurePaging() {
        alert("Không thể tải dữ liệu");
    }

    function enterToSeacrh(event) {
        if (event.keyCode == 13)
            $("#btnSearch").click();
    }


</script>
