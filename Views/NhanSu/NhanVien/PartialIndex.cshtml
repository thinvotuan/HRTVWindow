@using BatDongSan.Models.NhanSu;
@model IPagedList<sp_NS_NhanVien_Index2Result>
@{
    Layout = null;
    int i = 1;
    string[] parameters = TempData["Params"].ToString().Split(',');
}
<style>
    td
    {
        border: none;
    }
</style>
<script type="text/javascript">
    $(document).ready(function () {
        $('#btnSearch').click(function () {
            var searchText = $('#searchString').val().replace(/\ /g, '+');
            var url = "@Url.Action("Index", "NhanVien")" + "?searchString=" + searchText;
            beginPaging();
            $('#content').html('<h4>Loading...</h4>').load(url);
            successPaging();
        });

        $('.btnChon').click(function () {
            var selected = $(this).parent();
            if (selected.length != 0) {
                var hoten = selected.find('#hoten').val();
                var manv = selected.find('#manhanvien').val();
                $('#nhanvien').val(hoten);
                $('#manv').val(manv);
                //$('.panel-default').html('');
            }
            //$('#filter-panel').removeClass('in');
        })
    })
</script>
<table class="table table-striped table-hover table-condensed" id="maintable">
    <thead>
        <tr>
            <th style="text-align: center; width: 40px">STT</th>
            <th style="width: 170px">Mã nhân viên</th>
            <th style="min-width: 250px">Liên hệ</th>
            <th style="width: 100px">Ngày vào làm</th>
            <th>Phòng ban</th>
            <th style="width: 90px">Loại</th>
            <th style="width: 110px">Tình trạng làm việc</th>
            <th style="width: 100px">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {                                                        
            <tr>
                <td style="text-align: center">@i</td>
                <td style="text-align: left">
                    <a style="color:#519ee5" href="@Url.Action("Details", "NhanVien", new { id = item.maNhanVien })">@item.maNhanVien</a><br />
                    <i class="fa fa-user" aria-hidden="true"></i>@item.hoVaTen
                </td>
                <td style="text-align: left"><i class="fa fa-phone" aria-hidden="true"></i>@item.phoneNumber1<br />
                    <i class="fa fa-envelope-o" aria-hidden="true"></i>@item.email
                </td>
                <td>@Html.Raw(item.ngayVaoLam.HasValue ? item.ngayVaoLam.Value.ToString("dd/MM/yyyy") : string.Empty)</td>
                <td style="text-align: left">@item.tenPhongBan<br />
                    <i class="fa fa-ticket" aria-hidden="true"></i>@item.TenChucDanh
                </td>
                <td>@item.tenLoaiNhanVien</td>
                <td>@item.trangThaiHoatDong</td>
                <td style="text-align: center">
                    <div class="buttons">
                        <a href="@Url.Action("Edit", "NhanVien", new { id = item.maNhanVien })" title ="Sửa phiếu"><i class="fa fa-pencil-square-o" style="font-size: 30px; color: orange;" aria-hidden="true"></i></a>
                        @{     
            if (item.userName == null)
            {
                            <span style="font-size: 30px; color: orange;">|</span><a class="btnDelete" alt="@item.maNhanVien" title ="Xoá phiếu"><i class="fa fa-trash" style="font-size: 30px; color: red; cursor: pointer;" aria-hidden="true"></i></a>
            }}
                    </div>
                </td>
            </tr> 
            i++;
        }
    </tbody>
</table>
<div>
    Trang @Model.PageNumber của @Model.PageCount / @ViewBag.Count
</div>
<div>
    <ul class="pagination">
        @Html.Raw(Ajax.Pager(new AjaxOptions { UpdateTargetId = "content", OnBegin = "beginPaging", OnSuccess = "successPaging", OnFailure = "failurePaging" }, Model.PageSize, Model.PageNumber, Model.TotalItemCount,
        new
        {
            controller = "NhanVien",
            action = "Index",
            searchString = parameters[0],
            maPhongBan = parameters[1],
            trangThai = parameters[2]
        }))
    </ul>
</div>

