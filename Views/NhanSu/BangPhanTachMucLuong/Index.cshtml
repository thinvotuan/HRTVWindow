@using BatDongSan.Models.NhanSu
@model IList<tbl_NS_BangPhanTachMucLuong>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int i = 1;    
}
<link rel="stylesheet" href="~/Content/batdongsan-alert.css" />
<script src="~/Scripts/batdongsan.generals.js"></script>
<script src="~/Scripts/autoNumeric.js"></script>
<style>
    #content td, th
    {
        border-bottom: 1px inset #ADC2D6;
        position: relative;
        text-align: center;
    }

    #phucap-details td, #phucap-details th
    {
        border: none;
    }

    .numberinput
    {
        text-align: right;
    }
</style>
<script type="text/javascript">
    $(document).ready(function () {
        $("#btnModalCreate").click(function () {
            var url = "@Url.Action("Create", "BangPhanTachMucLuong")";
            var form = document.getElementById("form-submit");
            form.action = url;
            $("#custom-panel").load(url)
        })

        $(".numberinput").autoNumeric('init', { mDec: 2, lZero: 'deny', aSep: ',', aDec: '.', pSign: 's', vMin: '0' });

        $("#customModal").on("hide.bs.modal", function () {
            $("#custom-panel").html("");
        });

        $(document).on("click", ".btnEdit", function () {
            var url = "@Url.Action("Edit", "BangPhanTachMucLuong")" + "/" + this.value;
            var form = document.getElementById("form-submit");
            form.action = url;
            $("#custom-panel").load(url);
        })

        $(".btnChiTietPB").click(function () {
            var url = "/BangPhanTachMucLuong/PhanBoChiTiet/" + this.value;
            beginPaging();
            $("#phucap-details").load(url, function () {
                successPaging();
            })
        })

        $(document).on("click", ".btnDelete", function () {
            var url = "@Url.Action("Delete", "BangPhanTachMucLuong")" + "/" + this.value;
            bootbox.confirm("Bạn có muốn xóa không", function (result) {
                if (result) {
                    var form = document.getElementById("form-listview");
                    form.method = "post";
                    form.action = url;
                    form.submit();
                }
            });
        })

    })

        function beginPaging(args) {
            // Animate        
            $('#phucap-details').fadeOut('fast');
        }

        function successPaging() {
            // Animate
            $('#phucap-details').fadeIn('fast');
        }

        var rowTemp, rowAdd;
        function getPhuCapList(obj) {
            rowTemp = "";
            rowAdd = "";
            rowAdd = $(obj).closest("tr");
            rowTemp = $(obj).closest("tr").next().clone();
            rowTemp.show();
            rowTemp.removeClass("noPostRow");
            var url = "@Url.Action("GetPhuCapList", "BangPhanTachMucLuong")";
            $("#phucap-panel").load(url);
        }

        function addRow() {
            var rowLoop,
                arrPhuCap = [],
                arrRowAdding = [];

            rowLoop = rowAdd.nextUntil(".rowTypePhuCap");

            $(rowLoop).each(function () {
                var maPhucap = $(this).find("[name=maPhuCap]").val();
                arrPhuCap.push(maPhucap);
            });

            $("[name=phucap]:checked").each(function () {
                var rowModify = rowTemp.clone();
                var maPhucap = $(this).closest("tr").find("[name=maPhuCap]").val(),
                    tenPhuCap = $(this).closest("tr").find("td:eq(2)").text().trim(),
                    loaiPhuCap = $(this).closest("tr").find("td:eq(3)").text().trim();
                if ($.inArray(maPhucap, arrPhuCap) == -1) {
                    rowModify.find(".salaryTemplateTypeI").val(this.value);
                    rowModify.find(".tyLeTypeII").val(0);
                    rowModify.find("td:eq(0)").text(maPhucap);
                    rowModify.find("[name=maPhuCap]").val(maPhucap);
                    rowModify.find("td:eq(1)").text(tenPhuCap);
                    rowModify.find("td:eq(2)").text(loaiPhuCap);
                    rowModify.find(".thanhTien").html("");
                    arrRowAdding.push(rowModify[0]);
                }
            });

            $(arrRowAdding).insertAfter(rowAdd[0]);

            $(".numberinput").autoNumeric("init");
            $(".numberinput").autoNumeric('update', { mDec: 2, lZero: 'deny', aSep: ',', aDec: '.', pSign: 's', vMin: '0' });
            //if (rowNext.length > 0) {
            //    $(arrAddingRowC1).insertBefore(rowNext[0]);
            //}
            //else {
            //    $(arrAddingRowC2).insertBefore(rowTemp[0]);
            //}
        }
</script>
<form id="form-listview">
    <div id="container">
        <fieldset class="removeBorderFieldset">
            <div id="tabs" style="" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                    <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active"><a><span>Bảng phân tách mức lương</span></a></li>
                </ul>
            </div>
            <div class="panel-body background_top">
                <div class="form-inline">
                    <div class="form-group" style="float: right">
                        <button class="btn btn-info" id="btnModalCreate" type="button" data-toggle="modal" data-target="#customModal">Thêm </button>
                    </div>
                </div>
            </div>
            <div id="content">
                <table class="table table-striped table-hover table-condensed" id="maintable">
                    <thead>
                        <tr>
                            <th rowspan="2" style="text-align: center; width: 45px; border-right: 1px solid #DADEE4; border-left: 1px solid #DADEE4">STT</th>
                            <th colspan="4" style="border-right: 1px solid #DADEE4; border-left: 1px solid #DADEE4">Mức lương</th>
                            <th colspan="2" style="border-right: 1px solid #DADEE4; border-left: 1px solid #DADEE4">Phân bổ</th>
                            <th rowspan="2" style="width:130px; border-right: 1px solid #DADEE4; border-left: 1px solid #DADEE4"></th>
                        </tr>
                        <tr>
                            <th>Mã mức lương</th>
                            <th>Tên mức lương</th>
                            <th>Từ</th>
                            <th style="border-right: 1px solid #DADEE4;">Đến</th>
                            <th>Mức đóng BHXH</th>
                            <th>Tổng phụ cấp</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {                            
                            <tr>
                                <td style="text-align: center">@i</td>
                                <td style="text-align: left">@item.maMucLuong</td>
                                <td style="text-align: left;">@item.tenMucLuong</td>
                                <td class="numberinput" style="text-align: right;">@item.mucLuongTu</td>
                                <td class="numberinput" style="text-align: right;">@item.mucLuongDen</td>
                                <td class="numberinput" style="text-align: right;">@item.luongCoBan</td>
                                <td>
                                    <button class="btn btn-xs btn-link btnChiTietPB" type="button" value="@item.maMucLuong">Chi tiết phân bổ</button></td>
                                <td style="text-align: right">
                                    <button class="btn btn-primary btn-xs btnEdit" type="button" data-toggle="modal" data-target="#customModal" value="@item.maMucLuong">Sửa</button>
                                    <button class="btn btn-warning btn-xs btnDelete" type="button" value="@item.maMucLuong">Xóa</button>
                                </td>
                            </tr> 
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        </fieldset>
    </div>
</form>
<div class="alert alert-danger" id="alertPhanBo" style="margin-top: 20px; display: none">
    <strong>Phân bổ không hợp lệ!</strong> <span id="error-info"></span>
</div>
<form method="post" id="phucap-form">
    <div id="container">
        <fieldset class="removeBorderFieldset">
            <div style="padding-top: 15px" id="phucap-details">
                <!-- /.tab-content -->
            </div>
        </fieldset>
    </div>
</form>
<form id="form-submit" method="post">
    <!--------------------------- Modal - Thêm Sửa Modal Form ------------------------>
    <div id="customModal" class="modal fade" role="dialog">
        <div class="modal-dialog">
            <!-- Modal content-->
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title"></h4>
                  </div>
                <div class="modal-body">
                    <div class="container" style="width: 100%">
                        <div class="row">
                            <div id="custom-panel" class="filter-panel">
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">                        
                        <button type="button" class="btn btn-default" data-dismiss="modal" id="btnCloseEmail">Đóng</button>
                        <button class="btn btn-primary" id="btnSubmit">Lưu</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<div id="phuCapModal" class="modal fade" role="dialog">
    <div class="modal-dialog">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title"></h4>
                  </div>
            <div class="modal-body">
                <div class="container" style="width: 100%">
                    <div class="row">
                        <div id="phucap-panel" class="filter-panel" style="overflow: auto; max-height: 650px">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-dismiss="modal" id="btnCloseModal">Đóng</button>
                    <button class="btn btn-primary" type="button" onclick="addRow()">Đồng ý</button>                    
                </div>
            </div>
        </div>
    </div>
</div>
