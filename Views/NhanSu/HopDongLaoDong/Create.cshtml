<script type="text/javascript">
    $(document).ready(function () {
        $(".datepicker").datetimepicker({
            locale: 'vi',
            format: 'DD/MM/YYYY'
        });

        $(".numberinput").autoNumeric('init', { mDec: 2, lZero: 'deny', aSep: ',', aDec: '.', pSign: 's', vMin: '0' });
        $(".numberinputInt").autoNumeric('init', { mDec: 0, lZero: 'deny', aSep: ',', aDec: '.', pSign: 's', vMin: '0' });
        $(".numberinputNega").autoNumeric('init', { mDec: 2, lZero: 'deny', aSep: ',', aDec: '.', pSign: 's', vMin: '-999999999' });

        $('#bac').change(function () {
            if ($('#bac').val() != 0) {
                $('#bacChucVu').empty();
                $('#luongCoBan, #luongThanhTich, #tongLuong').val(0);
                var url = '@Url.Action("GetBacChucVu", "HopDongLaoDong")' + '/' + this.value;
                $.ajax({
                    url: url,
                    type: 'POST',
                    data: 'json',
                    success: function (data) {
                        var textAppend = '';
                        textAppend += '<option value="0">--Chọn--</option>';
                        $.each(data, function (i, n) {
                            textAppend += '<option value="' + n.capBacChucVu + '">' + n.capBacChucVu + '</option>'
                        })
                        $('#bacChucVu').append(textAppend);
                    }, error: function () {
                        Alert.error("Có lỗi xảy ra", "Lỗi", { displayDuration: 2000 });
                    }
                })
            }
            else {
                $('#bacChucVu').empty();
                $('#bacChucVu').prepend("<option value='0' selected='selected'>--Chọn--</option>");
            }
        });

        $('#bac,#bacChucVu').prepend("<option value='0' selected='selected'>--Chọn--</option>");
        //$('#bac').prepend($('<option selected="selected">', {
        //    value: "0",
        //    text: "--Chọn--"
        //}));


        $('#bacChucVu').change(function () {
            $('#luongCoBan, #luongThanhTich, #tongLuong').val(0);
        })

        $("#btnNhanVien").click(function () {
            @*var url = "@Url.Action("GetNhanVienInfo", "User")";*@
            $("#customModal .modal-dialog").addClass("modal-lg");
            var url = "@Url.Action("NhanVienChuaKy", "HopDongLaoDong")";
            $("#custom-panel").load(url);
        });

        $(document).on("click", ".btnChonNVPB", function () {
            var selected = $(this).parent();
            if (selected.length != 0) {
                var hoten = selected.find('#hotenNVPB').val(),
                    manv = selected.find('#maNVPB').val(),
                    chucDanh = selected.find("#chucVuNVPB").val();;
                $('#tenNhanVien').val(hoten);
                $('#maNhanVien').val(manv);
                $("#tenChucDanh").val(chucDanh);
                //$('.panel-default').html('');
            }
        });

        $("#tongLuong").on("keyup keydown", function () {
            var luongThoaThuan = $("#luongThoaThuan").autoNumeric("get"),
                    tongLuong = $("#tongLuong").autoNumeric("get");

            var tyLeHuong = parseFloat(tongLuong) / parseFloat(luongThoaThuan) * 100;
            if (parseFloat(tongLuong) > parseFloat(luongThoaThuan)) {
                $("#tongLuong").autoNumeric("set", luongThoaThuan);
                $("#tyLeHuong").autoNumeric("set", 100);
            }
            else {
                $("#tyLeHuong").autoNumeric("set", tyLeHuong.toFixed(2));
            }
        });

        $("#luongCoBan, #luongThanhTich").on("keyup keydown", function () {
            //var luongThoaThuan = $("#luongThoaThuan").autoNumeric("get");
            //var phuCapLuong = $("#phuCapLuong").autoNumeric("get");
            //var khoanBoSungLuong = $("#khoanBoSungLuong").autoNumeric("get");

            //var luongDongBH = parseFloat(luongThoaThuan) + parseFloat(phuCapLuong);
            //$("#luongDongBH").autoNumeric("set", luongDongBH.toFixed(2));
            //var tongLuong = 0;
            //tongLuong = parseFloat(luongDongBH) + parseFloat(khoanBoSungLuong);
            //$("#tongLuong").autoNumeric("set", tongLuong.toFixed(2));
            tinhTongLuong()
        });



        $("#idThoiHanHopDong").change(function () {
            if ($("#idThoiHanHopDong").val() != 0) {
                $("#idThoiHanHopDong").removeClass('error');
            }
        });

        $("#customModal").on("hide.bs.modal", function () {
            $("#custom-panel").html("");
        });

        $("#btnTroVe").click(function () {
            location.href = "/HopDongLaoDong";
        });

        $("#maLoaiHopDong").change(function () {
            if (this.value == "THUVIEC") {
                $("#tyLeHuong").autoNumeric("set", 85);
            } else {
                $("#tyLeHuong").autoNumeric("set", 100);
            }
            $("#tyLeHuong").trigger("keyup");
        });

        $("#idThoiHanHopDong").change(function () {
            $.ajax({
                url: "/HopDongLaoDong/GetThoiHanInfo/" + this.value,
                type: "POST",
                dataType: "json",
                data: $("#phucap-form").serialize(),
                success: function (data) {
                    $("#soThang").val(data.soThang)
                    var soThang = parseFloat(data.soThang),
                        ngayKy = $("#ngayBatDau").val();

                    var ngayKetThuc = moment(ngayKy, "DD-MM-YYYY").add(soThang, "month").subtract(1, 'd');

                    $("#ngayKetThuc").val(moment(ngayKetThuc).format("DD/MM/YYYY"));
                    if (data.loaiThoiHan == false) {
                        $("#ngayKetThuc").val('');
                    }
                }
            })
        });
        $(document).on("dp.hide", "#ngayBatDau", function (e) {
            $.ajax({
                url: "/HopDongLaoDong/GetThoiHanInfo/" + $("#idThoiHanHopDong").val(),
                type: "POST",
                dataType: "json",
                data: $("#phucap-form").serialize(),
                success: function (data) {
                    $("#soThang").val(data.soThang)
                    var soThang = parseFloat(data.soThang),
                        ngayKy = $("#ngayBatDau").val();

                    var ngayKetThuc = moment(ngayKy, "DD-MM-YYYY").add(soThang, "month").subtract(1, 'd');

                    $("#ngayKetThuc").val(moment(ngayKetThuc).format("DD/MM/YYYY"));
                    if (data.loaiThoiHan == false) {
                        $("#ngayKetThuc").val('');
                    }
                }
            })
        });


        var luong_option = null;
        $('.btnThangLuong').click(function () {
            luong_option = $(this).closest('div');
            var url = '@Url.Action("GetThangLuong", "HopDongLaoDong")' + '?bac=' + $('#bac').val()
                                                                       + '&bacChucVu=' + $('#bacChucVu').val();
            $('#thangluong-panel').load(url);
        })

        $(document).on('click', '#thangluong-panel input[type=text]', function () {
            var row = $(this).closest('tr'),
                bac = row.find('#bacLuong').val(),
                bacchucvu = row.find('#capBacChucVu').val();
            if (luong_option.find('#luongCoBan').length > 0) {
                luong_option.find('#luongCoBan').val(this.value);
                //$('#bac').val('', bac);
                //$('#bacChucVu ').autoNumeric('set', bacchucvu);
            } else if (luong_option.find('#luongThanhTich').length > 0) {
                luong_option.find('#luongThanhTich').val(this.value);
            }
            tinhTongLuong();
        });

        $("#checkPhuCapDiLai").click(function () {
            if ($(this).is(":checked")) {
                $("#phuCapDiLaiNew").autoNumeric("set", 200000);
            }
            else {
                $("#phuCapDiLaiNew").autoNumeric("set", 0);
            }
        });
    });

    function tinhTongLuong() {
        var luongcoban = $('#luongCoBan').autoNumeric('get'),
            luongthanhtich = $('#luongThanhTich').autoNumeric('get');
        var tongLuong = parseFloat(luongcoban) + parseFloat(luongthanhtich);
        $('#tongLuong').autoNumeric('set', tongLuong.toFixed(2));
    }

    function beginPaging(args) {
        // Animate        
        $('#content').fadeOut('fast');
    }

    function successPaging() {
        // Animate
        $('#content').fadeIn('normal');
    }

    function failurePaging() {
        alert("Không thể tải dữ liệu");
    }

    function enterToSeacrh(event) {
        if (event.keyCode == 13)
            $("#btnSearch").click();
    }

    function checkValid() {
        //var tongLoaiI = 0, tongLoaiII = 0;
        //var phuCapKhongTheoTiLe = parseFloat($("#tongPhuCapKhongTheoTyLe").val()),
        //    phuCapTheoTiLe = parseFloat($("#tongPhuCapTheoTyLe").val());
        //$(".loaiI").each(function () {
        //    tongLoaiI += parseFloat($(this).autoNumeric("get"));
        //})

        //$(".loaiII").each(function () {
        //    tongLoaiII += parseFloat($(this).autoNumeric("get"));
        //})

        //if (isNaN(tongLoaiI) || (tongLoaiI != phuCapKhongTheoTiLe)) {
        //    $("#error-info").html("Tổng số tiền phụ cấp không theo tỷ lệ phải bằng " + phuCapKhongTheoTiLe);
        //    $("#alertPhanBo").fadeIn("fast");
        //    setTimeout(function () { $("#alertPhanBo").fadeOut("slow"); }, 4000);
        //    return false;
        //}

        //if (isNaN(tongLoaiII) || (tongLoaiII != phuCapTheoTiLe)) {
        //    $("#error-info").html("Tổng số tiền phụ cấp theo tỷ lệ phải bằng " + phuCapTheoTiLe);
        //    $("#alertPhanBo").fadeIn("fast");
        //    setTimeout(function () { $("#alertPhanBo").fadeOut("slow"); }, 4000);
        //    return false;
        //}

        return true;
    }

</script>
<style>
    td
    {
        border: none!important;
    }

    .input-group-btn
    {
        position: absolute;
        font-size: 0;
    }

    .numberinput, .numberinputNega, .numberinputInt
    {
        text-align: right;
    }
