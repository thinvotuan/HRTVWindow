                    </tr>
                    <tr>
                        <td class="tdtitle">Loại hợp đồng</td>
                        <td>@Html.DropDownListFor(model => model.maLoaiHopDong, ViewBag.LoaiHopDongs as SelectList, new { @class = "form-control", required = "required" })</td>

                        <td class="tdtitle">Ngày ký hợp đồng <span style="font-style: italic; float: right; color: red">*</span></td>
                        <td>
                            @Html.TextBoxFor(model => model.ngayKy, "{0:dd/MM/yyyy}", new { @class = "form-control datepicker", required = "required" })

                        </td>

                        @*  <td class="form-inline tdtitle">Tỉ lệ hưởng lương</td>
                        <td>@Html.TextBoxFor(model => model.tyLeHuong, new { @class = "form-control numberinput", style = "width: 100%", data_v_max = "100", data_a_sign = " %", required = "required" })</td>*@
                    </tr>
                    <tr>
                        <td class="tdtitle">Thời hạn hợp đồng <span style="font-style: italic; float: right; color: red">*</span></td>
                        <td>@Html.DropDownListFor(model => model.idThoiHanHopDong, ViewBag.ThoiHanHopDongs as SelectList, new { @class = "form-control", required = "required" })</td>

                        <td class="tdtitle">Thời hạn</td>
                        <td class="form-inline">
                            <input type="text" name="soThang" id="soThang" required="required" class="form-control numberinput" style="width: 85%" readonly="readonly" />
                            Tháng
                        </td>
                    </tr>
                    <tr>
                        <td class="tdtitle">Ngày bắt đầu <span style="font-style: italic; float: right; color: red">*</span></td>
                        <td>@Html.TextBoxFor(model => model.ngayBatDau, "{0:dd/MM/yyyy}", new { @class = "form-control datepicker", required = "required" })</td>

                        <td class="tdtitle">Ngày kết thúc</td>
                        <td>@Html.TextBoxFor(model => model.ngayKetThuc, "{0:dd/MM/yyyy}", new { @class = "form-control datepicker" })</td>
                    </tr>
                    <tr>
                        <td class="tdtitle">Bậc lương</td>
                        <td>
                            @Html.DropDownListFor(model => model.bac, ViewBag.Bacs as SelectList, new { @class = "form-control" })</td>
                        <td class="tdtitle">Cấp bậc chức vụ</td>
                        <td>
                            @Html.DropDownListFor(model => model.bacChucVu, ViewBag.BacChucVus as SelectList, new { @class = "form-control" })
                        </td>
                    </tr>
                    <tr>
                        <td class="tdtitle">Hình thức lương
                        </td>
                        <td>
                            @Html.DropDownListFor(model => model.maHinhThuc, ViewBag.HinhThucLuongs as SelectList, new { @class = "form-control" })
                            

                        </td>
                        <td class="tdtitle">Ngày bắt đầu tính phép<span style="font-style: italic; float: right; color: red"></span></td>
                        <td>@Html.TextBoxFor(model => model.ngayBatDauTinhPhep, "{0:dd/MM/yyyy}", new { @class = "form-control datepicker" })</td>
                    </tr>
                    <tr>
                       
                         <td class="tdtitle">Bảo hiểm
                        </td>
                        <td>
                            @Html.DropDownListFor(model => model.maBaoHiem, ViewBag.BaoHiems as SelectList, new { @class = "form-control" })
                            

                        </td>
                         <td class="tdtitle">Thuế
                        </td>
                        <td>
                            @Html.DropDownListFor(model => model.maThue, ViewBag.DMThues as SelectList, new { @class = "form-control" })
                            

                        </td>
                        
                    </tr>
                    <tr>
                        <td class="tdtitle">Lương cơ bản(1) <span style="font-style: italic; float: right; color: red">*</span></td>
                        <td>
                            <div style="display: inline-flex; width: 100%;">
                                @Html.TextBoxFor(model => model.luongCoBan, new { @class = "form-control numberinput", required = "required" })
                                <input style="width: 50px;" type="button" class="btn btn-primary btn-sm btnThangLuong" data-toggle="modal" data-target="#thangLuongModal" value="..." />
                            </div>
                        </td>
                        @*<td class="tdtitle">Phụ cấp lương (2) <span style="font-style: italic; float: right; color: red">*</span></td>
                        <td>
                            @Html.TextBoxFor(model => model.phuCapLuong, new { @class = "form-control numberinput", required = "required" })
                        </td>*@
                        <td class="tdtitle">Lương thành tích (2)</td>
                        <td>
                            <div style="display: inline-flex; width: 100%;">
                                @Html.TextBoxFor(model => model.luongThanhTich, new { @class = "form-control numberinput", required = "required" })
                                <input style="width: 50px;" type="button" class="btn btn-primary btn-sm btnThangLuong" data-toggle="modal" data-target="#thangLuongModal" value="..." />
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td class="tdtitle">Tổng lương (3=1+2) <span style="font-style: italic; float: right; color: red">*</span></td>
                        <td>@Html.TextBoxFor(model => model.tongLuong, new { @class = "form-control numberinput", required = "required", @readonly = "readonly" })</td>
                        <td class="tdtitle">Lương đóng BH<span style="font-style: italic; float: right; color: red">*</span></td>
                        <td>
                            @Html.TextBoxFor(model => model.luongDongBH, new { @class = "form-control numberinput", required = "required" })
                        </td>
                    </tr>
                    <tr>
                        <td class="tdtitle">Quỹ nội bộ</td>
                        <td>@Html.TextBoxFor(model => model.doanPhi, new { @class = "form-control numberinput", style = "width: 100%", data_v_max = "100", data_a_sign = " %", required = "required" })</td>
                        <td class="tdtitle">Phụ cấp thu hút</td>
                        <td>
                            @Html.TextBoxFor(model => model.khoanBoSungLuong, new { @class = "form-control numberinputNega", required = "required" })
                        </td>
                    </tr>
                    @*<tr>
                        <td class="tdtitle">Lương đóng BH (3=1+2) <span style="font-style: italic; float: right; color: red">*</span></td>
                        <td>
                            @Html.TextBoxFor(model => model.luongDongBH, new { @class = "form-control numberinput", required = "required", @readonly = "readonly" })
                        </td>

                        <td class="tdtitle">Khoản bổ sung lương (4)</td>
                        <td>
                            @Html.TextBoxFor(model => model.khoanBoSungLuong, new { @class = "form-control numberinputNega", required = "required" })
                        </td>
                        <td class="tdtitle">Tính lương phân bổ</td>
                        <td>
                            <button class="btn btn-info btn-xs btn-link" id="btnPhanBo" type="button" style="width: 120px; height: 24px; color: white;">Tính phân bổ lương</button>
                        </td>
                    </tr>*@

                    @*<tr>
                        <td class="tdtitle">Tiền xăng</td>
                        <td>@Html.TextBoxFor(model => model.tienXang, new { @class = "form-control numberinput", required = "required" })</td>

                        <td class="form-inline tdtitle">Tiền đi lại</td>
                        <td>@Html.TextBoxFor(model => model.tienDiLai, new { @class = "form-control numberinput", required = "required" })</td>
                    </tr>*@
                    <tr>
                        <td class="tdtitle">Tiền điện thoại</td>
                        <td>
                            @Html.TextBoxFor(model => model.tienDienThoai, new { @class = "form-control numberinput", required = "required" })
                        </td>
                        <td class="tdtitle">Tiền ăn giữa ca</td>
                        <td>
                            @Html.CheckBoxFor(model => model.tienAnGiuaCa)
                        </td>
                    </tr>
                    <tr>
                        <td class="tdtitle">Phụ cấp đi lại</td>
                        <td> @Html.CheckBoxFor(model => model.checkPhuCapDiLai)</td>
                         <td class="tdtitle">Tiền phụ cấp đi lại</td>
                        <td>
                            @Html.TextBoxFor(model => model.phuCapDiLaiNew, new { @class = "form-control numberinput", @readonly="readonly" })
                        </td>
                    </tr>
                    <tr>
                          <td class="tdtitle">Hợp đồng hết hiệu lực</td>
                        <td> @Html.CheckBoxFor(model => model.hopDongHetHieuLuc)</td>
                        <td class="tdtitle">Ghi chú</td>
                        <td>
                            <textarea class="form-control" name="ghiChuMain" id="ghiChuMain"></textarea></td>
                    </tr>
                </table>
            </div>
        </div>
        <div class="alert alert-danger" id="alertPhanBo" style="margin-top: 20px; display: none">
            <strong>Phân bổ không hợp lệ!</strong> <span id="error-info"></span>
        </div>
        <div id="phanbo-div" style="padding-top: 0px;">
        </div>
        <div class="form-group" style="float: right">
            <button class="btn btn-info" id="btnSubmit">Lưu </button>
            <button class="btn btn-info btnTroVe" type="button" id="btnTroVe">Trở về </button>
        </div>
    </fieldset>
</form>
<div id="customModal" class="modal fade" role="dialog">
    <div class="modal-dialog">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title"></h4>
            </div>
            <div class="modal-body">
                <div class="container" style="width: 100%">
                    <div class="row">
                        <div id="custom-panel" class="filter-panel">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="thangLuongModal" class="modal fade" role="dialog">
    <div class="modal-dialog modal-lg">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title"></h4>
            </div>
            <div class="modal-body">
                <div class="container">
                    <div class="row">
                        <div id="thangluong-panel" class="filter-panel">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
