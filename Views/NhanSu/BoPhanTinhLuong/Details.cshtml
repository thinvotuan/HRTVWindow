@using BatDongSan.Models.NhanSu;
@{
    ViewBag.Title = "Chi tiết bộ phận tính lương ";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var ls = ViewBag.ListBP as List<BoPhanTinhLuong>;
}
<script src="~/Scripts/jquery-2.1.4.min.js"></script>
<script src="~/Content/bootstrap/js/bootstrap.min.js"></script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/additional-methods.min.js"></script>
<script src="~/Scripts/batdongsan.validate.js"></script>
<link rel="stylesheet" href="~/Content/batdongsan-alert.css" />
<script src="~/Scripts/batdongsan.generals.js"></script>
<script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>

<script>
    $(document).ready(function () {
        $("#btnTroVe").click(function () {
            location.href = '@Url.Action("Index","BoPhanTinhLuong")';
        });
    });

</script>
@{
    var boPhan = ls.FirstOrDefault();
}
<form id="form-submit" class="form-horizontal" method="post">
    <div id="container" class="custome_fieldSet">
        <fieldset class="removeBorderFieldset">
            <div id="tabs" style="width: 30%; height: auto; border: none; float: left; box-sizing: border-box; overflow: hidden; clear: none;" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                    <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active ">
                        <a><span><i class="fa fa-plus-square-o" aria-hidden="true"></i>Cập nhật bộ phận tính lương</span></a></li>
                </ul>
            </div>
        </fieldset>
        <table class="table table-striped table-hover table-condensed" id="tbl-create" style="position: relative">
            <tr>
                <td class="tdtitle">Mã bộ phận </td>
                <td>
                    <div style="width: 100%; display: inline-flex">
                        <input class="form-control" id="maBoPhan" name="maBoPhan" readonly="readonly" type="text" value="@boPhan.MaBoPhan">
                    </div>
                </td>
                <td class="tdtitle">Tên bộ phận </td>
                <td>
                    <div style="width: 100%; display: inline-flex">
                        <input class="form-control" id="tenBoPhan" name="tenBoPhan" readonly="readonly" type="text" value="@boPhan.TenBoPhan">
                    </div>
                </td>
            </tr>
        </table>
        <table class="table table-striped table-hover table-condensed" id="maintable">
            <thead>                
                <tr>
                    <th style="width: 45px; text-align: center">STT</th>
                    <th style="width: 100px; text-align: center">Mã nhân viên</th>
                    <th style="width: 120px; text-align: center">Tên nhân viên</th>
                    <th style="width: 120px; text-align: center">Phòng ban</th>
                    <th style="width: 110px; text-align: center">Chức danh</th>
                </tr>
            </thead>
            <tbody id="load">
                @{
                    var cout = 0;
                    foreach (var item in ls)
                    {
                    <tr>
                        <td style="text-align: center">@(++cout)</td>
                        <td style="text-align: center">
                            @item.MaNhanVien
                            @Html.Hidden("maNhanVien", item.MaNhanVien)
                        </td>
                        <td>@item.TenNhanVien</td>
                        <td>@item.TenPhongBan</td>
                        <td>@item.TenChucDanh</td>
                        
                    </tr>
                    }
                }
            </tbody>
        </table>
        <div style="text-align: right; margin: 10px 0">
            <button class="btn btn-info" type="button" id="btnTroVe">Trở về </button>
        </div>
    </div>
</form>
