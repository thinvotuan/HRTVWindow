@{
    ViewBag.Title = "Thêm mới bộ phận tính lương";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/Scripts/jquery-2.1.4.min.js"></script>
<script src="~/Content/bootstrap/js/bootstrap.min.js"></script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/additional-methods.min.js"></script>
<script src="~/Scripts/batdongsan.validate.js"></script>
<link rel="stylesheet" href="~/Content/batdongsan-alert.css" />
<script src="~/Scripts/batdongsan.generals.js"></script>
<script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>
<script>
    $(document).ready(function () {
        $("#btnSubmit").click(function () {
            if (CheckForm()) {
                var url = '@Url.Action("CheckBoPhanTinhLuong","BoPhanTinhLuong")';
                $.ajax({
                    type: "POST",
                    url: url,
                    data: {maBP:$("#maBoPhan").val()},
                    dataType: "json",
                    success: function (resultData) {
                        if (resultData == "") {
                            $("#form-submit").submit();
                        }
                        else {
                            Alert.error("Mã bộ phận tính lương đã tồn tại.", "Thông báo", { displayDuration: 3000 });
                        }
                    }
                });
                
            }
        });
        $("#btnTroVe").click(function () {
            location.href = '@Url.Action("Index","BoPhanTinhLuong")';
        });
    });
    function ChonNhanVien() {
        $('#myModalChonPhongBan').modal();
        var Url = '@Url.Action("ChonNhanVien", "BoPhanTinhLuong")';
        $('#filter-panel').load(Url);
    }
    function Delete(obj) {
        $(obj).parent().parent().remove();
        for (var i = 0; i < $("#load").find("tr").length; i++) {
            $("#load tr:eq(" + i + ")").find("td").first().html(i + 1);
        }
    }
    function CheckForm() {
        var flag = true;
        if ($("#maBoPhan").val() == "") {
            $("#maBoPhan").addClass("error").attr("title", "Vui lòng nhập mã bộ phận");
            flag = false;

        }

        if ($("#tenBoPhan").val() == "") {
            $("#tenBoPhan").addClass("error").attr("title", "Vui lòng nhập tên bộ phận.");
            flag = false;

        }
        var rowNV=$("#load").find("tr").length;
        if (rowNV == 0) {
            Alert.error("Vui lòng chọn nhân viên.", "Thông báo", { displayDuration: 3000 });
            flag = false;
        }
        return flag;
    }
</script>
<form id="form-submit" class="form-horizontal" method="post">
    <div id="container" class="custome_fieldSet">
        <fieldset class="removeBorderFieldset">
            <div id="tabs" style="width: 30%; height: auto; border: none; float: left; box-sizing: border-box; overflow: hidden; clear: none;" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                    <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active ">
                        <a><span><i class="fa fa-plus-square-o" aria-hidden="true"></i>Thêm mới bộ phận tính lương</span></a></li>
                </ul>
            </div>
        </fieldset>
        <table class="table table-striped table-hover table-condensed" id="tbl-create" style="position: relative">
            <tr>
                <td class="tdtitle">Mã bộ phận </td>
                <td>
                    <div style="width: 100%; display: inline-flex">
                        <input class="form-control" id="maBoPhan" name="maBoPhan" required="required" type="text">
                    </div>
                </td>
                <td class="tdtitle">Tên bộ phận </td>
                <td>
                    <div style="width: 100%; display: inline-flex">
                        <input class="form-control" id="tenBoPhan" name="tenBoPhan" required="required" type="text">
                    </div>
                </td>
            </tr>
        </table>
        <table class="table table-striped table-hover table-condensed" id="maintable">
            <thead>
                <tr>
                    <th colspan="12">
                        <button type="button" class="btn btn-warning btnChonNhanVien" style="color: #020202;" onclick="ChonNhanVien()"><i class="fa fa-users" aria-hidden="true"></i>Chọn nhân viên</button>
                    </th>
                </tr>
                <tr>
                    <th style="width: 45px; text-align: center">STT</th>
                    <th style="width: 100px; text-align: center">Mã nhân viên</th>
                    <th style="width: 120px; text-align: center">Tên nhân viên</th>
                    <th style="width: 120px; text-align: center">Phòng ban</th>
                    <th style="width: 110px; text-align: center">Chức danh</th>
                    <th style="width: 30px"></th>
                </tr>
            </thead>
            <tbody id="load">
            </tbody>
        </table>
        <div style="text-align: right; margin: 10px 0">
            <button class="btn btn-info" id="btnSubmit" type="button">Lưu </button>
            <button class="btn btn-info" type="button" id="btnTroVe">Trở về </button>
        </div>
    </div>
    <div id="myModalChonPhongBan" class="modal fade" role="dialog">
        <div class="modal-dialog modal-lg" >
            <!-- Modal content-->
            <div class="modal-content">
                <div class="modal-header" style="background:#f7f7f7">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        <h4 class="modal-title">Chọn nhân viên</h4>
      </div>
                <div class="modal-body">
                    <div class="container" style="width: 98%">
                        <div class="row">
                            <div id="filter-panel" class="filter-panel">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                </div>
            </div>

        </div>
    </div>
</form>
