@using BatDongSan.Models.NhanSu;
@model PhepNamNhanVien
@*@{
    ViewBag.Title = "Tính phép năm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}*@
@{
    ViewBag.Title = "Index";
    Layout = null;
    Layout = "~/Views/Shared/_Popup.cshtml";
   
}
<script src="~/Scripts/jquery-2.1.4.min.js"></script>
<script src="~/Content/bootstrap/js/bootstrap.min.js"></script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/additional-methods.min.js"></script>
<script src="~/Scripts/batdongsan.validate.js"></script>
<link rel="stylesheet" href="~/Content/batdongsan-alert.css" />
<script src="~/Scripts/batdongsan.generals.js"></script>
<script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>
<script>
    var obj = window.opener;
    $(document).ready(function () {        
        $("#Nam").change(function () {
            $("#load").html("");
        });
        $("#btnSubmit").click(function () {
            if (CheckForm()) {
                $("#form-submit").submit();
                window.close();
                obj.$("#btnTimKiem_Tab3").click();
            }
        });
        $("#btnClose").click(function () {
            @*location.href = '@Url.Action("Index")';*@
            obj.$("#btnTimKiem_Tab3").click();
            window.close();
        });


    });

    function ChonNhanVien() {
        $('#myModalChonPhongBan').modal();
        var Url = '@Url.Action("ChonNhanVien", "PhepNamNhanVien")';
        $('#filter-panel').load(Url);
    }
    function Delete(obj) {
        $(obj).parent().parent().remove();
        for (var i = 0; i < $("#load").find("tr").length; i++) {
            $("#load tr:eq(" + i + ")").find("td").first().html(i + 1);
        }
    }
    function CheckForm() {
        var flag = true;
        if ($("[name='soNgayPhepTonDuocDuyet']").length == 0) {
            Alert.error("Vui lòng chọn nhân viên.", "Thông báo", { displayDuration: 3000 });
            flag = false;
        }
        $.each($("[name='soNgayPhepTonDuocDuyet']"), function (e) {

            var index = $("[name='soNgayPhepTonDuocDuyet']").index(this);
            if ($("[name='soNgayPhepTonDuocDuyet']:eq(" + index + ")").val() == "") {
                $("[name='soNgayPhepTonDuocDuyet']:eq(" + index + ")").addClass("error").attr("title", "Số ngày duyệt không được rỗng.");
                flag = false;
            }

        });

        return flag;
    }   

</script>
<style>
    #tbl-create td
    {
        border: none;
        line-height: 35px;
    }
</style>
<form id="form-submit" class="form-horizontal" method="post">
    <div id="container" class="custome_fieldSet">
        <fieldset class="removeBorderFieldset">
            <div id="tabs" style="width: 30%; height: auto; border: none; float: left; box-sizing: border-box; overflow: hidden; clear: none;" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                    <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active ">
                        <a><span><i class="fa fa-yelp" aria-hidden="true"></i>Cấp phép năm</span></a></li>
                </ul>
            </div>
            <table class="table table-striped table-hover table-condensed" id="tbl-create" style="position: relative">

                <tr class="background_tr">
                    <td>Năm tồn đầu
                    </td>
                    <td>
                        <input type="text" value="@ViewBag.namTon"  name="Nam" id="Nam" class = "form-control" readonly="readonly" style = "width:150px"/>
                       @* @Html.DropDownList("Nam", ViewBag.namLamViec as SelectList, new { @class = "form-control", @style = "width:150px" })*@
                    </td>
                    <td style="">Ngày cập nhật</td>
                    <td style="">@String.Format("{0: dd/MM/yyyy}", Model.ngayLap)</td>
                    <td style="">Người cập nhật </td>
                    <td style="">@Model.NhanVien.hoVaTen</td>
                </tr>

            </table>
            <table class="table table-striped table-hover table-condensed" id="maintable">
                <thead>
                    <tr>
                        <th colspan="12">
                            <button type="button" class="btn btn-warning btnChonNhanVien" style="color: #020202; float: right" onclick="ChonNhanVien()"><i class="fa fa-users" aria-hidden="true"></i>Chọn nhân viên</button>
                        </th>
                    </tr>
                    <tr>
                        <th style="width: 45px; text-align: center">STT</th>
                        <th style="width: 105px; text-align: center">Bộ phận</th>
                        <th style="width: 120px; text-align: center">Tên nhân viên</th>
                        <th style="width: 110px; text-align: center">Cấp bậc quản lý</th>
                        <th style="width: 90px; text-align: center">Số ngày phép<br />
                            tồn năm trước</th>
                        <th style="width: 90px; text-align: center">Phép tồn<br />
                            được duyệt</th>
                        <th style="width: 90px; text-align: center">Phép năm<br />
                            theo quy định</th>
                        <th style="width: 90px; text-align: center">Số ngày phép<br />
                            thâm niên</th>
                        <th style="width: 90px; text-align: center">Số ngày phép<br />
                            đặc biệt</th>
                        <th style="width: 90px; text-align: center">Tổng số ngày<br />
                            phép năm</th>
                        <th style="width: 30px"></th>
                    </tr>
                </thead>
                <tbody id="load">
                </tbody>
            </table>
            <div style="text-align: right; margin: 10px 0">
                <button class="btn btn-info" id="btnSubmit" type="button">Lưu </button>
                <button class="btn btn-info" type="button" id="btnClose">Đóng </button>
            </div>
        </fieldset>

    </div>
    <div id="myModalChonPhongBan" class="modal fade" role="dialog">
        <div class="modal-dialog modal-lg">
            <!-- Modal content-->
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title">Chọn nhân viên</h4>
                </div>
                <div class="modal-body">
                    <div class="container" style="width: 98%">
                        <div class="row">
                            <div id="filter-panel" class="filter-panel">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                </div>
            </div>

        </div>
    </div>
</form>
