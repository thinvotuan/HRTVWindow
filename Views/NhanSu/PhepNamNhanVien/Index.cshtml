    ViewBag.Title = "Danh sách phép năm nhân viên";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/Content/bootstrap-datetimepicker.min.css" />
<script src="~/Scripts/batdongsan.utils.js"></script>
<script type="text/javascript" src="~/Scripts/Jquery.treeview/jquery.treeview.js"></script>
<link rel="stylesheet" href="~/Scripts/Jquery.treeview/jquery.treeview.css" />
<script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>
<script src="~/Scripts/bootstrap-datetimepicker.min.js"></script>
@*<script src="~/Scripts/jquery.fixedtableheader.min.js"></script*@
@*<script src="~/Scripts/FixedHeaderAll.js"></script>*@
<script>
    $(document).ready(function () {
        //  FixedAll($("#maintable"), 1);
        // $("#maintable").fixedtableheader({ highlightrow: true, headerrowsize: 1 });
        //setting phong ban//
        $(".navigation1").treeview({
            persist: "location",
            unique: false,
            collapsed: true
        }).find(".expandable-hitarea").click();


        $(".tabToggle").click(function () {
            $(".tabToggle").removeClass("ui-tabs-selected ui-state-active activeColorTab");
            $(".contentToggle").hide(600);
            var index = $(".tabToggle").index(this);
            $(".tabToggle").eq(index).addClass("ui-tabs-selected ui-state-active activeColorTab");
            $(".contentToggle").eq(index).show(600);
        });

        $('ul.dropdown-menu .hitarea').on('click', function (event) {
            event.stopPropagation();
        });

        $('#txtsearch, #txtsearch_Tab2, #txtsearch_Tab3').on("input", function () {
            var navigation1 = $(this).closest(".dropdown-menu").find(".navigation1");
            $(navigation1).filterLink($(this).val());
        });

        $("#phongban-dropdown-menu").removeAttr("style");
        $("#phongban-dropdown-menu_Tab2").removeAttr("style");
        $("#phongban-dropdown-menu_Tab3").removeAttr("style");

        $("#customModal").on("hide.bs.modal", function () {
            $("#custom-panel").html("");
        });

        $(document).on("click", "#phongban-dropdown-menu li a", function () {

            $("#btnPhongBan").val($(this).attr('alt'));
            $(this).parents(".dropdown").find('.btn').html($(this).text() + ' &nbsp;<span class="caret"></span>');
            $("#btnTimKiem").click();
        })

        $(document).on("click", "#phongban-dropdown-menu_Tab2 li a", function () {

            $("#btnPhongBan_Tab2").val($(this).attr('alt'));
            $(this).parents(".dropdown").find('.btn').html($(this).text() + ' &nbsp;<span class="caret"></span>');
            $("#btnTimKiem_Tab2").click();
        })

        $(document).on("click", "#phongban-dropdown-menu_Tab3 li a", function () {

            $("#btnPhongBan_Tab3").val($(this).attr('alt'));
            $(this).parents(".dropdown").find('.btn').html($(this).text() + ' &nbsp;<span class="caret"></span>');
            $("#btnTimKiem_Tab3").click();
        })

        //End
        $("#btnModalCreate").click(function () {
            var url = "@Url.Action("Create", "PhepNamNhanVien")";
            showPopup(url, 980, 550);
        });
        $('#btnTimKiem').click(function () {
            var searchText = $('#searchString').val().replace(/\ /g, '+');
            var valPhongBan = $("#btnPhongBan").val().replace(/ /gi, '+');
            var url = "@Url.Action("Index", "PhepNamNhanVien")" + "?searchString=" + searchText + "&maPhongBan=" + valPhongBan + "&Nam=" + $("#Nam").val();
            var imageUrl = '<div id="divMsg" align="center"><img src="@Url.Content("~/Content/images/loading.gif")"/></div>';
            $('#content').html(imageUrl);
            $('#content').load(url);
        });

        @*$('#btnTimKiem_Tab2').click(function () {
            var searchText = $('#searchString_Tab2').val().replace(/\ /g, '+');
            var valPhongBan = $("#btnPhongBan_Tab2").val().replace(/ /gi, '+');
            var url = "@Url.Action("Index_Tab2", "PhepNamNhanVien")" + "?searchString=" + searchText + "&maPhongBan=" + valPhongBan + "&ngayKiemTra=" + $("#ngayKiemTra").val();
            var imageUrl = '<div id="divMsg" align="center"><img src="@Url.Content("~/Content/images/loading.gif")"/></div>';
            $('#content_Tab2').html(imageUrl);
            $('#content_Tab2').load(url);
            //OnCriteria_Tab2(1);
        });*@

        $("#Nam").change(function () {
            $("#btnTimKiem").click();
        });
        $("#btnChonPB").click(function () {
            $('#myModalChonPhongBan').modal();
            var Url = '@Url.Action("ChonPhongBan", "PhieuCongTac")';
            $('#filter-panel1').load(Url);
        });

        $("#btnChonPB_Tab2").click(function () {
            $('#myModalChonPhongBan').modal();
            var Url = '@Url.Action("ChonPhongBan", "PhieuCongTac")';
            $('#filter-panel1').load(Url);
        });

        $("#btnChonPB_Tab3").click(function () {
            $('#myModalChonPhongBan').modal();
            var Url = '@Url.Action("ChonPhongBan", "PhieuCongTac")';
            $('#filter-panel1').load(Url);
        });

        $("#btnRes").click(function () {
            $("#phongBanCongTac").val("");
            $("#tenPhongBan").val("");
            $("#searchString").val("");
            $("#Nam").val(new Date().getFullYear());
            $("#btnTimKiem").click();
        });

        $('#btnResetPhepTon').click(function () {
            if ($('#ngayReset').val() == '') {
                Alert.error("Vui lòng chọn thời điểm bạn muốn cập nhật.", "Thông báo", { displayDuration: 2000 });
                return;
            }

            bootbox.confirm({
                message: "Bạn có chắc chắn muốn reset toàn bộ phép tồn?",
                buttons: {
                    confirm: {
                        label: 'Xác nhận',
                        className: 'btn-success'
                    },
                    cancel: {
                        label: 'Đóng',
                        className: 'btn-danger'
                    }
                },
                callback: function (result) {
                    if (result) {
                        var url = '@Url.Action("ResetPhepTon", "PhepNamNhanVien")' + '?nam=' + $('#Nam').val();
                        $.ajax({
                            url: url,
                            type: 'POST',
                            data: 'json',
                            success: function () {
                                Alert.success("Cập nhật thành công", "Thông báo", { displayDuration: 2000 });
                            },
                            error: function () {
                                Alert.error("Có lỗi xảy ra", "Thông báo", { displayDuration: 2000 });
                            }
                        })
                    }
                }
            });
        });

        $("#btnModalXuatFile").click(function () {

            var searchText = $('#searchString_Tab2').val().replace(/\ /g, '+');
            var valPhongBan = $("#btnPhongBan_Tab2").val().replace(/ /gi, '+');

            location.href = "@Url.Action("XuatFilePhepNam", "PhepNamNhanVien")" + "?ngayKiemTra=" + $("#ngayKiemTra").val() + "&qSearch=" + searchText + "&maPhongBan=" + valPhongBan;
        });

        $(".datepicker").datetimepicker({
            locale: 'vi',
            format: 'DD/MM/YYYY'
        });

        $("#idTab2").click(function () {
            OnCriteria_Tab2(1);
        });

        $("#idTab3").click(function () {
            OnCriteria_Tab3(1);
        });
    });

    function functionUpdateNghiPhep(maNhanVien, tenNhanVien, soNgayPhepConLaiTrongNam) {
        $('#myModalUpdatePhepTonConLai').modal();
        $("#lblUDPT_SoNgayPhepNamConLai").html("Số ngày phép bổ sung của năm: " + $("#Nam").val());
        $("#lblUDPT_TenNhanVien").html(tenNhanVien);
        $("#txtUDPT_soNgayPhepNamConLai").val(soNgayPhepConLaiTrongNam);

        $("#hdUDPT_maNhanVien").val(maNhanVien);
    }

    function ketChuyenSoDuPhep() {
        if ($('#Nam').val() == '') {
            Alert.error("Vui lòng chọn năm để kết chuyển số dư phép năm cũ qua năm mới.", "Thông báo", { displayDuration: 2000 });
            return;
        }
        bootbox.confirm({
            message: "Bạn có chắc chắn muốn kết chuyển tồn năm cũ qua năm mới?",
            buttons: {
                confirm: {
                    label: 'Xác nhận',
                    className: 'btn-success'
                },
                cancel: {
                    label: 'Đóng',
                    className: 'btn-danger'
                }
            },
            callback: function (result) {
                if (result) {
                    var url = '@Url.Action("CapNhatPhepTon", "PhepNamNhanVien")' + '?nam=' + $('#Nam').val();
                    $.ajax({
                        url: url,
                        type: 'POST',
                        data: 'json',
                        success: function (data) {
                            if (data == "") {
                                Alert.success("Kết chuyển số dư phép năm cũ qua năm mới thành công", "Thông báo", { displayDuration: 3000 });
                                $("#btnTimKiem").click();
                            }
                            else if (data == "-1") {
                                Alert.error("Bạn chỉ được phép kết chuyển số dư năm hiện tại", "Thông báo", { displayDuration: 3000 });
                            }
                            else {
                                Alert.error("Có lỗi xảy ra", "Thông báo", { displayDuration: 3000 });
                            }
                        },
                        error: function () {
                            Alert.error("Có lỗi xảy ra", "Thông báo", { displayDuration: 3000 });
                        }
                    });
                }
            }
        });
    }

    function Update(maNhanVien, Nam) {
        var url = "@Url.Action("Edit", "PhepNamNhanVien")" + "?maNhanVien=" + maNhanVien + "&Nam=" + Nam;
        @*var url = '@Url.Action("DanhSachNhanVien", "PhieuTangCa")';*@
        showPopup(url, 980, 550);
    }
    function enterToSeacrh(event) {
        if (event.keyCode == 13)
            $("#btnTimKiem").click();
    }

    function enterToSeacrh_Tab2(event) {
        if (event.keyCode == 13)
            $("#btnTimKiem_Tab2").click();
    }

    function enterToSeacrh_Tab3(event) {
        if (event.keyCode == 13)
            $("#btnTimKiem_Tab3").click();
    }

    function OnCriteria_Tab2(page) {
        var searchText = $('#searchString_Tab2').val().replace(/\ /g, '+');
        var valPhongBan = $("#btnPhongBan_Tab2").val().replace(/ /gi, '+');
        var url = "@Url.Action("Index_Tab2", "PhepNamNhanVien")" + "?searchString=" + searchText + "&maPhongBan=" + valPhongBan + "&ngayKiemTra=" + $("#ngayKiemTra").val() + "&page=" + page;
        var imageUrl = '<div id="divMsg" align="center"><img src="@Url.Content("~/Content/Images/loading.gif") "/></div>';
        $('#content_Tab2').html(imageUrl);
        $('#content_Tab2').load(url, function () {
        });
    }

    function OnCriteria_Tab3(page) {
        alert(page);
        var searchText = $('#searchString_Tab3').val().replace(/\ /g, '+');
        var valPhongBan = $("#btnPhongBan_Tab3").val().replace(/ /gi, '+');
        var url = "@Url.Action("Index_Tab3", "PhepNamNhanVien")" + "?searchString=" + searchText + "&maPhongBan=" + valPhongBan + "&page=" + page;
        var imageUrl = '<div id="divMsg" align="center"><img src="@Url.Content("~/Content/Images/loading.gif") "/></div>';
        $('#content_Tab3').html(imageUrl);
        $('#content_Tab3').load(url, function () {
        });
    }
    function close_UDPT() {
        $("#btnUDPT_CloseHead").click();
    }

    function save_UDPT() {
        //post về
        bootbox.confirm({
            message: "Bạn có muốn lưu dữ liệu này?",
            buttons: {
                confirm: {
                    label: 'Xác nhận',
                    className: 'btn-success'
                },
                cancel: {
                    label: 'Đóng',
                    className: 'btn-danger'
                }
            },
            callback: function (result) {
                if (result) {
                    var url = '@Url.Action("UpdateNgayPhepConLaiNhanVien", "PhepNamNhanVien")' + '?maNhanVien=' + $('#hdUDPT_maNhanVien').val()
                                + "&nam=" + $("#Nam").val()
                                + "&soNgayPhepNamHienTai=" + $("#txtUDPT_soNgayPhepNamConLai").val();
                    $.ajax({
                        url: url,
                        type: 'POST',
                        data: 'json',
                        success: function () {
                            Alert.success("Cập nhật thành công", "Thông báo", { displayDuration: 2000 });
                            var searchText = $('#searchString').val().replace(/\ /g, '+');
                            var valPhongBan = $("#btnPhongBan").val().replace(/ /gi, '+');
                            var url = "@Url.Action("Index", "PhepNamNhanVien")" + "?searchString=" + searchText + "&maPhongBan=" + valPhongBan + "&Nam=" + $("#Nam").val();
                            var imageUrl = '<div id="divMsg" align="center"><img src="@Url.Content("~/Content/images/loading.gif")"/></div>';
                            $('#content').html(imageUrl);
                            $('#content').load(url);
                        },
                        error: function () {
                            Alert.error("Có lỗi xảy ra", "Thông báo", { displayDuration: 2000 });
                        }
                    })
                }
            }
        });
    }

    function moveScroll() {
        var scroll = $(window).scrollTop();
        var header_top = $("header").height();

        var anchor_top = $("#maintable").offset().top;
        var anchor_bottom = $("#bottom_anchor").offset().top;
        if (scroll > anchor_top && scroll < anchor_bottom) {
            clone_table = $("#clone");
            if (clone_table.length == 0) {
                clone_table = $("#maintable").clone();
                clone_table.attr('id', 'clone');
                clone_table.css({
                    position: 'fixed',
                    'pointer-events': 'none',
                    top: 93,

                });
                clone_table.width($("#maintable").width());
                $("#content").append(clone_table);
                $("#clone").css({ visibility: 'hidden' });
                $("#clone thead").css({ visibility: 'visible' });
            }
        } else {
            $("#clone").remove();
        }
    }
    $(window).scroll(moveScroll);
</script>
