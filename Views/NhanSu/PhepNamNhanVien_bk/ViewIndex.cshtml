@using BatDongSan.Models.NhanSu;
@model IPagedList<sp_PhepNamNhanVien_IndexResult>
@{
    int i = 1;
}
<script>
    function beginPaging(args) {
        // Animate        
        $('#content').fadeOut('fast');
    }

    function successPaging() {
        // Animate
        $('#content').fadeIn('normal');
    }

    function failurePaging() {
        alert("Không thể tải dữ liệu");
    }

</script>
<table class="table table-striped table-hover table-condensed" id="maintable">
    <thead>
        <tr>
            <th style=" width: 45px">STT</th>
            <th style="width: 130px">Mã nhân viên</th>
            <th style="width: 200px">Phòng ban/Chức vụ</th>
            
           @* <th style="width: 80px">Số ngày phép tồn<br />năm trước</th>
            <th style="width: 80px">Phép tồn<br />được duyệt</th>*@
            <th style="width: 80px">Phép năm<br />theo quy định</th>
            <th style="width: 80px">Số ngày phép<br />tồn được duyệt</th>
            <th style="width: 80px">Số ngày phép<br />thâm niên</th>
            <th style="width: 80px">Số ngày phép<br />đặc biệt</th>
            <th style="width: 80px">Tổng số ngày<br />phép năm</th>
            <th style="width: 80px">Ngày cập nhật</th>
            <th style="width: 80px"></th>
          
        </tr>
    </thead>
    <tbody id="load">

        @foreach (var item in Model)
        {
            <tr>
                <td style="text-align: center">@i</td>
               
                <td  style="text-align:left"><a style="color:#519ee5" href="/NhanVien/Details/@item.maNhanVien">@item.maNhanVien</a><br /><i class="fa fa-user" aria-hidden="true"></i>@item.tenNhanVien</td>
                 <td>@item.tenBoPhan<br /><i class="fa fa-ticket" aria-hidden="true"></i>@item.tenCapBac</td>
                
                @*<td style="text-align:right">@String.Format("{0:#,#0.#}",item.soNgayTonNamTruoc)</td>
                <td style="text-align:right">@String.Format("{0:#,#0.#}",item.phepTonDuocDuyet)</td>*@
                <td style="text-align:right">@String.Format("{0:#,#0.#}",item.phepNamQuyDinh)</td>
                <td style="text-align:right">@String.Format("{0:#,#0.#}",item.phepTonDuocDuyet)</td>
                <td style="text-align:right">@String.Format("{0:#,#0.#}",item.ngayPhepThamNien)</td>
                <td style="text-align:right">@String.Format("{0:#,#0.#}",item.soNgayPhepTonDacBiet)</td>
                <td style="text-align:right">@String.Format("{0:#,#0.#}",item.tongSoNgayPhep)</td>
                <td style="text-align:center">@String.Format("{0:dd/MM/yyyy}", item.ngayCapNhat)</td>               
                <td style="text-align: center">
                   <a title="Cập nhật" href="javascript:void(0)" onclick="Update('@item.maNhanVien.Trim()',@item.nam)" style="color: black;
                            cursor: pointer; background: #53CFE9;border: 1px solid #3EC6E0; padding: 0 2px; border-radius: 2px;"><i class="fa fa-pencil" aria-hidden="true"></i></a>
                </td>
            </tr> 
            i++;
        }
    </tbody>
</table>
<div>
    Trang @Model.PageNumber của @Model.PageCount / @ViewBag.Count
</div>
<div>
    <ul class="pagination" >
        @Html.Raw(Ajax.Pager(new AjaxOptions { UpdateTargetId = "content", OnBegin = "beginPaging", OnSuccess = "successPaging", OnFailure = "failurePaging" }, Model.PageSize, Model.PageNumber, Model.TotalItemCount, new { controller = "PhepNamNhanVien", action = "Index", searchString = ViewBag.searchString, maPhongBan = ViewBag.maPhongBan, Nam = ViewBag.Nam }))
    </ul>
</div>
