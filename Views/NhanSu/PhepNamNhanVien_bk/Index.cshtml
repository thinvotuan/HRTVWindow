@using BatDongSan.Models.NhanSu;
@model IPagedList<sp_PhepNamNhanVien_IndexResult>
@{
    ViewBag.Title = "Danh sách phép năm nhân viên";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/Content/bootstrap-datetimepicker.min.css" />
<script src="~/Scripts/batdongsan.utils.js"></script>
<script type="text/javascript" src="~/Scripts/Jquery.treeview/jquery.treeview.js"></script>
<link rel="stylesheet" href="~/Scripts/Jquery.treeview/jquery.treeview.css" />
<script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>
<script src="~/Scripts/bootstrap-datetimepicker.min.js"></script>

<script>
    $(document).ready(function () {


        //setting phong ban//
        $("#navigation1").treeview({
            persist: "location",
            unique: false,
            collapsed: true
        }).find(".expandable-hitarea").click();


        $('ul.dropdown-menu .hitarea').on('click', function (event) {
            event.stopPropagation();
        });

        $('#txtsearch').on("input", function () {

            $('#navigation1').filterLink($('#txtsearch').val());
        });

        $("#phongban-dropdown-menu").removeAttr("style");

        $("#customModal").on("hide.bs.modal", function () {
            $("#custom-panel").html("");
        });

        $(document).on("click", "#phongban-dropdown-menu li a", function () {

            $("#btnPhongBan").val($(this).attr('alt'));
            $(this).parents(".dropdown").find('.btn').html($(this).text() + ' &nbsp;<span class="caret"></span>');
            $("#btnTimKiem").click();
        })
        //End
        $("#btnModalCreate").click(function () {
            location.href = "@Url.Action("Create", "PhepNamNhanVien")";
        });

        $("#btnModalXuatFile").click(function () {
            if ($('#ngayReset').val() == '') {
                Alert.error("Vui lòng chọn thời điểm bạn muốn cập nhật.", "Thông báo", { displayDuration: 2000 });
                return;
            }

            location.href = "@Url.Action("XuatFilePhepNam", "PhepNamNhanVien")" + "?ngayReset=" + $("#ngayReset").val();
        });

        $('#btnTimKiem').click(function () {
            var searchText = $('#searchString').val().replace(/\ /g, '+');
            var valPhongBan = $("#btnPhongBan").val().replace(/ /gi, '+');
            var url = "@Url.Action("Index", "PhepNamNhanVien")" + "?searchString=" + searchText + "&maPhongBan=" + valPhongBan + "&Nam=" + $("#Nam").val();
            beginPaging();
            $('#content').load(url);
            successPaging();
        });

        $("#Nam").change(function () {
            $("#btnTimKiem").click();
        });
        $("#btnChonPB").click(function () {
            $('#myModalChonPhongBan').modal();
            var Url = '@Url.Action("ChonPhongBan", "PhieuCongTac")';
            $('#filter-panel1').load(Url);
        });
        $("#btnRes").click(function () {
            $("#phongBanCongTac").val("");
            $("#tenPhongBan").val("");
            $("#searchString").val("");
            $("#Nam").val(new Date().getFullYear());
            $("#btnTimKiem").click();
        });

        $('#btnResetPhepTon').click(function () {
            if ($('#ngayReset').val() == '')
            {
                Alert.error("Vui lòng chọn thời điểm bạn muốn cập nhật.", "Thông báo", { displayDuration: 2000 });
                return;
            }

            bootbox.prompt({
                title: "Bạn có chắc chắn muốn reset toàn bộ phép tồn về 0? Việc thực hiện chức năng này sẽ không thể quay lại",
                inputType: 'checkbox',
                inputOptions: [
                    {
                        text: 'Nhấn vào đây nếu bạn đã chắc chắn',
                        value: 'true',
                    }
                ],
                callback: function (result) {
                    if (result[0] == 'true') {
                        var url = '@Url.Action("ResetPhepTon", "PhepNamNhanVien")' + '?ngayReset=' + $('#ngayReset').val();
                            $.ajax({
                                url: url,
                                type: 'POST',
                                data: 'json',
                                success: function (data) {
                                    if (data == '') {
                                        Alert.success("Cập nhật thành công", "Thông báo", { displayDuration: 2000 });
                                    }
                                    else {
                                        Alert.error(data, "Thông báo", { displayDuration: 2000 });
                                    }
                                },
                                error: function () {
                                    Alert.error("Có lỗi xảy ra", "Thông báo", { displayDuration: 2000 });
                                }
                            })
                        } else {
                            alert('Không thể thực hiện. Bạn vui lòng đồng ý là bạn đã chắc chắn');
                        }
                }
            })
        });
        $(".datepicker").datetimepicker({
            locale: 'vi',
            format: 'DD/MM/YYYY'
        });
    });
        function Update(maNhanVien, Nam) {
            var url = "@Url.Action("Edit", "PhepNamNhanVien")" + "?maNhanVien=" + maNhanVien + "&Nam=" + Nam;
            location.href = url;
        }
        function enterToSeacrh(event) {
            if (event.keyCode == 13)
                $("#btnTimKiem").click();
        }
</script>
<style>
    #content td {
        border-bottom: 1px inset #ADC2D6;
        position: relative;
    }

    #content th {
        text-align: center;
    }

    #filter-panel td {
        border: none;
    }

    #navigation1 {
        overflow: auto;
        height: 600px;
    }

    .dropdown-menu {
        min-width: 420px;
    }

    .background_top td {
        float: left;
        min-width: 170px;
    }
</style>
<form id="form-listview">
    <div id="container">
        <fieldset class="removeBorderFieldset">
            <div id="tabs" style="" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                    <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active"><a><span>Danh sách phép năm nhân viên</span></a></li>
                </ul>
            </div>
            <div id="filter-panel" class="collapse filter-panel" style="display: block; position: relative">
                <div class="panel panel-default">

                    <table class="table table-striped table-hover table-condensed">
                        <tr class="background_tr">
                            <td><span style="float: left">Năm:</span><span style="float: left">@Html.DropDownList("Nam", ViewBag.namLamViec as SelectList, new { @class = "form-control", @style = "width:100px;" })</span>
                            </td>
                            <td>
                                <div class="form-group" id="phongban-div">
                                    <div class="dropdown">
                                        <button class="btn btn-primary btn-sm dropdown-toggle" id="btnPhongBan" type="button" data-toggle="dropdown">
                                            Danh sách phòng ban&nbsp;<span class="caret"></span>
                                        </button>
                                        <ul class="dropdown-menu" id="phongban-dropdown-menu">
                                            <li role="presentation">
                                                <div class="form-group has-feedback" style="width: 90%; margin: 5px auto;">
                                                    <input type="text" class="form-control input-sm" id="txtsearch" placeholder="Search" style="width: 100%" />
                                                    <span class="glyphicon glyphicon-search form-control-feedback"></span>
                                                </div>
                                            </li>
                                            <li role="presentation">
                                                @Html.Raw(ViewBag.PhongBans)
                                            </li>
                                        </ul>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="input-group" style="width: 300px; float: left;">

                                    <input type="text" id="searchString" value="@ViewBag.Search" class="form-control" style="float:left" placeholder="Nhập giá trị tìm kiếm" onkeypress="enterToSeacrh(event);" />

                                    <span class="input-group-btn">
                                        <input type="button" id="btnTimKiem" value="Tìm kiếm">
                                    </span>
                                </div>


                            </td>
                            <td style="text-align: right; width: 30%;">
                                <div>
                                    <input type="text" id="ngayReset" class="form-control datepicker" placeholder="Chọn ngày reset phép" style="width: 150px;    float: left;" />
                                    <button class="btn btn-info" id="btnResetPhepTon" type="button">Reset phép tồn</button>
                                    <button class="btn btn-info" id="btnModalXuatFile" type="button">Xuất file</button>
                                    <button class="btn btn-info" id="btnModalCreate" type="button">Thêm</button>
                                </div>
                            </td>
                        </tr>
                    </table>


                </div>
            </div>
            <div id="content">
                @{Html.RenderPartial("ViewIndex");}
            </div>

            <div id="myModalChonPhongBan" class="modal fade" role="dialog">
                <div class="modal-dialog modal-lg">
                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-header">
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                            <h4 class="modal-title">Nhân viên</h4>
                        </div>
                        <div class="modal-body">
                            <div class="container" style="width: 98%">
                                <div class="row">
                                    <div id="filter-panel1" class="filter-panel">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                        </div>
                    </div>

                </div>
            </div>
        </fieldset>
    </div>
</form>
