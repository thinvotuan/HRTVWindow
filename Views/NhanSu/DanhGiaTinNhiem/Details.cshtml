@using BatDongSan.Models.NhanSu
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var ls = ViewBag.lsDanhSach as List<sp_NS_PhieuDanhGia_IndexResult>; 
   
}

<link rel="stylesheet" href="~/Content/table.css" />
<style>
     header
    {
        z-index: 1;
    }
     header:hover {
   
    z-index:2;
   
}
</style>
<style>
    input#maPhieuTinNhiem
    {
        border: none;
        cursor: no-drop;
        background-color: transparent;
    }
</style>

<script type="text/javascript" src="@Url.Content("~/Scripts/worldsoft/tabs/jquery.ui.tabs.js")"></script>

<script type="text/javascript" src="@Url.Content("~/Scripts/JQuery/jquery.treetable/javascripts/jquery.treeTable.js")"></script>

<link rel="Stylesheet" href="@Url.Content("~/Scripts/JQuery/jquery.treetable/stylesheets/jquery.treeTable.css")"
        type="text/css">
<link rel="stylesheet" href="~/Content/table.css" />
<script type="text/javascript">
    $().ready(function () {
        $(".mouseOver2 img.smallImg").hover(function () {
          
            $(".Img1").remove();

            var valImg = $(this).attr("src");
            $(this).after('<img src="' + valImg + '" class="Img1">');

        });
        $(".backLink").click(function (event) {
            event.preventDefault();
            history.back(1);
        });


        setTimeout(function () { $("#divMsg").hide() }, 5000);
    });

    function checkForm() {
        var flag = true;
        if (isEmpty($("#Name"), ""))
            flag = false;
        return flag;
    }
    function moveScroll() {
        var scroll = $(window).scrollTop();
        var anchor_top = $("#gridSource").offset().top;
        var anchor_bottom = $("#bottom_anchor").offset().top;
        if (scroll > anchor_top && scroll < anchor_bottom) {
            clone_table = $("#clone");
            if (clone_table.length == 0) {
                clone_table = $("#gridSource").clone();
                clone_table.attr('id', 'clone');
                clone_table.css({
                    position: 'fixed',
                    'pointer-events': 'none',
                    top: 0,

                });
                clone_table.width($("#gridSource").width());
                $("#table-container").append(clone_table);
                $("#clone").css({ visibility: 'hidden' });
                $("#clone thead").css({ visibility: 'visible' });
            }
        } else {
            $("#clone").remove();
        }
    }
    $(window).scroll(moveScroll);


    function goBack() {
        window.history.back();
    }

</script>

<style type="text/css">
    #clone thead
    {
        background: #bcd475;
    }
</style>
<div id="divMsg" style="color: Red; width: 900px; text-align: center">
    @{if ((string)ViewData["Message"] != "")
      { 
        <span>@ViewData["Message"]</span>
      } 
    }
</div>
@{
        
    using (Html.BeginForm())
    {
         
    
    <div class="custome_fieldSet WrapperPhieuDG">
        <div class="myatable03 mtxxs">

            <fieldset class="removeBorderFieldset">

                <div class="titleBorderPhieu">
                    <div class="colorCommonBieuNgu">
                        Xem chi tiết phiếu đánh giá<br />
                        <span>Trách Nhiệm</span> – <span>Công Tâm</span> – <span>Đúng Sự Thật</span>
                    </div>
                </div>
                <table style="width: 100%" class="WorkTicketForm">
                    @{
        var CapUser = Convert.ToInt32(ViewData["CapBacUser"]);
        var lsCapBac = ViewData["lsCapBac"] as List<DanhSachNhanVienDaChonModel>;
        var lsNV = ViewData["lsNhanVienPhongBan"] as List<DanhSachNhanVienDaChonModel>;
        List<tbl_NS_TieuChi> lsTieuChi = ViewData["lsDanhMucTieuChi"] as List<tbl_NS_TieuChi>;
        List<sp_NS_PhieuDanhGia_EditResult> lsDanhGiaChiTiet = ViewData["lsDanhGiaChiTiet"] as
                           List<sp_NS_PhieuDanhGia_EditResult>;
                    }
                    <tr>
                        <td colspan="4" style="padding: 0px;">
                            <div style="float: right">

                                <a href="javascript: history.go(1)" class="backLink">
                                    <button type="button" class="btnBlack"><i class="fa fa-reply-all" aria-hidden="true"></i>Quay về</button>
                                </a>
                            </div>
                        </td>
                    </tr>
                    <tr style="display: none">
                        <td colspan="4">
                            @Html.TextBox("maPhieuTinNhiem", lsDanhGiaChiTiet.FirstOrDefault().maPhieuDanhGia)

                        </td>

                    </tr>


                    <tr style="background: #C17A7A; color: #fff; font-size: 14px;">

                        <td style="width: 50%" colspan="2">Phiếu Đánh giá 6 tháng đầu năm 2016
                        </td>

                        <td style="width: 25%">Người lập:  @ViewData["tenNguoiLap"]
                        </td>
                        <td style="width: 25%">Ngày lập:   @lsDanhGiaChiTiet.FirstOrDefault().ngayLap.Value.ToString("dd/MM/yyyy")
                        </td>
                    </tr>
                </table>
                @{      
        var stt = 1;
        Dictionary<int, string> lsDiem = new Dictionary<int, string>();
        lsDiem[0] = "0";
        lsDiem[1] = "10";
        lsDiem[2] = "20";
        lsDiem[3] = "30";
        lsDiem[4] = "40";
        lsDiem[5] = "50";
        lsDiem[6] = "60";
        lsDiem[7] = "70";
        lsDiem[8] = "80";
        lsDiem[9] = "90";
        lsDiem[10] = "100";
                }

                <div class="noteDanhGia">
                    <div>
                        <span>Lưu ý:</span><span>Thang điểm đánh giá là 100/ 1 tiêu chí.</span>
                    </div>
                </div>

                <div id="table-container">
                    <table id="gridSource" class="tbl WorkTicket" style="width: 100%">
                        <thead>
                            <tr style="color: #000099; font-weight: 700">
                                <td style="width: 30px; text-align: center">STT
                                </td>
                                <td style="width: 260px">Tên NV
                                </td>
                                <td style="width: 400px">Phòng ban / Chức danh
                                </td>
                                @{foreach (var tc in lsTieuChi)
                                  {
                                    <td style="width: 220px">
                                        <b style="color: red;">
                                            @tc.tenTieuChi
                                        </b>
                                        <br />
                                        <p style="margin: 0px;">
                                            (Hệ số :
                                    @tc.heSoDiem )
                                        </p>
                                        @Html.Hidden("maTieuChi", tc.id)
                                    </td>
                                  } 
                                }
                                <td style="width: 90px; text-align: right">Điểm TB
                                </td>
                            </tr>
                        </thead>
                        <tbody>
                            @{ 
                                  stt = 1;
                                  var dem = 1;
                                  foreach (var it in lsCapBac)
                                  {
                                      int count = 1;
                                      foreach (var nv in lsNV.Where(t => t.CapBac == it.CapBac))
                                      {
                                          dem++;
                                          var HinhAnh = nv.MaNhanVien + ".jpg"; 
                        
                                <tr>
                                    <td data-label="STT" style="text-align: center" rowspan="2">
                                        @(count++)
                                    </td>
                                    <td style="color: #006600; font-weight: 700" data-label="Tiêu chí" rowspan="2">
                                        <div class="asideMNV">
                                            @nv.TenNhanVien
                                            @Html.Hidden("maNhanVien", nv.MaNhanVien)
                                            @Html.Hidden("maPhongBan", it.CapBac)
                                        </div>
                                        <div class="asideImg">
                                            <div class="mouseOver mouseOver2">
                                                <img class="smallImg" onerror="imgError(this);" accept="image/*" src="/UploadFiles/QLNV/@HinhAnh" />
                                            </div>
                                        </div>
                                    </td>
                                    <td data-label="Phòng ban" class="customePhongBan" rowspan="2">
                                        <span><i class="fa fa-object-group" aria-hidden="true"></i>
                                            @nv.TenPhongBan  </span>
                                        <br />
                                        <span><i class="fa fa-user-secret" aria-hidden="true"></i>
                                            @nv.TenChucDanh </span>
                                    </td>
                                    @{
                                          var countTieuChi = 1;
                                          foreach (var tc in lsTieuChi)
                                          {
                                              countTieuChi++;
                                        
                                        
                                        <td data-label="@tc.tenTieuChi (Hệ số : @tc.heSoDiem  )">
                                            @{
                                              double key = 0;
                                              var diemSo1 = lsDanhGiaChiTiet.Where(dt => dt.maNhanVienDanhGia.Equals(nv.MaNhanVien) && dt.idTieuChi == tc.id).
                                             FirstOrDefault();
                                              if (diemSo1 != null)
                                              { key = (double)diemSo1.diemSo; }
                                              if (key == 0)
                                              {
                                                <span>-</span>
                                              }
                                              else
                                              { 
                                   
                                                <span>@key</span>
                                   
                                              }
                                            }

                                        </td>
                                          }
                                    }
                                    @{
                                          double tongDiem = 0;
                                          var td1 = lsDanhGiaChiTiet.Where(dt => dt.maNhanVienDanhGia.Equals(nv.MaNhanVien)).
                                                    FirstOrDefault();
                                          if (td1 != null)
                                          { tongDiem = (double)td1.tongDiem; }
                                    }
                                    <td align="right" data-label="Điểm TB" style="background: #c17a7a; color: #fff;">
                                        @tongDiem
                                    </td>
                                    @Html.Hidden(nv.MaNhanVien + "_heSoCap", it.CapBac)
                                </tr>
                                <tr>
                                    @{
                                          string txtNhanXet = "";
                                          var NhanXet = lsDanhGiaChiTiet.Where(dt => dt.maNhanVienDanhGia.Equals(nv.MaNhanVien)).FirstOrDefault();
                                          txtNhanXet = NhanXet != null ? NhanXet.nhanXet : "";
                                          if (txtNhanXet != null && txtNhanXet != "")
                                          {
                                
                                
                                        <td colspan="@countTieuChi" style="text-align:left; line-height:1.6; background:#ddd">@txtNhanXet </td>
                                          }
                                          else
                                          { 
                            
                                        <td colspan="@countTieuChi"></td>
                                          }
                                    }

                                </tr>
                                      }
                     
                      
                                <tr>
                                    <td colspan="9">
                                        <hr style="text-align: center; height: 6px; width: 100%; margin: 5px auto; border-radius: 10px;"
                                            class="getLine" />
                                    </td>
                                </tr>
                                  }
                            }
                        </tbody>
                        @{stt++;}

                    </table>
                </div>
                <div id="bottom_anchor">
                </div>
                <br />
                <i style="float: left"><i class="fa fa-quote-left" aria-hidden="true"></i>Nếu có phát hiện nhầm lẫn, sai sót, tiêu cực vui lòng liên hệ email: <span>danhgianhanvien@thuanviet.com.vn</span> <i class="fa fa-quote-right" aria-hidden="true"></i></i>
                <div style="float: right">

                    <a href="javascript: history.go(1)" class="backLink">
                        <button type="button" class="btnBlack"><i class="fa fa-reply-all" aria-hidden="true"></i>Quay về</button>
                    </a>
                </div>
            </fieldset>
        </div>
    </div>
    } 
}