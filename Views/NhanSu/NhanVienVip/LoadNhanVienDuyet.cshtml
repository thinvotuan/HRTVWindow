@using BatDongSan.Models.DanhMuc;
@model IPagedList<sp_PB_DanhSachNhanVienResult>
@{
    Layout = null;
    int i = 1;
}
<script src="~/Scripts/moment.min.js"></script>
<script src="~/Scripts/vi.js"></script>
<script src="~/Scripts/bootstrap-datetimepicker.min.js"></script>
<script src="~/Scripts/autoNumeric.js"></script>
<script src="~/Scripts/batdongsan.uploadfile.js"></script>
<script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>
<script>
    $(document).ready(function () {
        $('#btnSearchNhanVienPhongBan').click(function () {
            var searchText = $('#searchString').val().replace(/\ /g, '+');
            var url = "@Url.Action("LoadNhanVienDuyet", "NhanVienVip")" + "?searchString=" + searchText + '&maPhongBan=' + "@ViewBag.MaPhongBan";
            beginPaging();
            $('#TabNV').html('<h4>Loading...</h4>').load(url);
            successPaging();
        });

        $('.btnChonNVPB').click(function () {
            var selected = $(this).parent();
            if (selected.length != 0) {
                var tenNV = selected.find('#hotenNVPB').val();
                var maNV = selected.find('#maNVPB').val();
                var emailNVPB = selected.find('#emailNVPB').val();
                //Check MaNV co hay chua.
                if ($("#maNhanVienOld").val()=="create") {
                    $.ajax({
                        type: "POST",
                        url: "/NhanVienVip/CheckMaNhanVien",
                        data: {
                            maNhanVien: maNV

                        },
                        error: function () {
                            alert("Error");
                            return false;
                        },
                        success: function (result) {
                            if (result == 1) {
                                $("#maNhanVien").addClass("error");
                                bdsConfirm.alert("Nhân viên đã được tạo", "Thông báo");
                                $("#btnSubmit").hide();

                            }
                            else {
                                $("#maNhanVien").removeClass("error");

                                $("#btnSubmit").show();

                            }


                        }
                    });
                }
             
                // End check
              
                $('#maNhanVien').val(maNV);
                $('#tenNhanVien').val(tenNV);
                $("#email").val(emailNVPB);
                var ngayVaoLamNVPB2 = selected.find('#ngayVaoLamNVPB').val();
                
                var onlyNgayVaoLam = ngayVaoLamNVPB2.split(" ")[0];
                var ngayVL = onlyNgayVaoLam.split("/");
                var ngayVL0 = ngayVL[0];
                var thangVL1 = ngayVL[1];
                if (ngayVL0 < 10) ngayVL0 = "0" + ngayVL0;
                if (thangVL1 < 10) thangVL1 = "0" + thangVL1;
                var ngayThangNamVL = ngayVL0 + "/" + thangVL1 + "/" + ngayVL[2];
                $("#ngayVaoLam").val(ngayThangNamVL);
                var parseNgayVL = parseDate(onlyNgayVaoLam);
                var ngayLap = $("#ngayLap").val();
                var onlyngayLap = ngayLap.split(" ")[0];
                var parseNgayLap = parseDate(onlyngayLap);
                var soNgayQuaHan = Date.daysBetween(parseNgayVL,parseNgayLap);
                
                $('#thoiGianCongTac').val(Math.round(soNgayQuaHan / 360));
                $.post('@Url.Action("ThongTinNhanVien")', { maNhanVien: maNV }, function (data) {
                    if (data != "False") {
                        $("#tongLuong, #luongCoBan").val(0);
                        $("#soHopDong").val(data.soHopDong);
                        $("#tenHopDong").val(data.tenHopDong);
                        $("#soPhuLuc").val(data.soPhuLuc);
                       
                        $("#luongCoBan").autoNumeric("set", data.tongLuong);
                        var tongLuong = 0;
                        $(".childSum").each(function (index) {

                            tongLuong = tongLuong + getNumber($(this).val());
                        });
                        $("#tongLuong").val(tongLuong);
                    }
                });
            }
        })
    });
    //Chuyển chuỗi kí tự (string) sang đối tượng Date()
    function parseDate(str) {
        var mdy = str.split('/');
        return new Date(mdy[2], mdy[1] - 1, mdy[0]);
    }
    // Xu ly ngay
    Date.daysBetween = function (date1, date2) {
        
        //Get 1 day in milliseconds
        var one_day = 1000 * 60 * 60 * 24;

        // Convert both dates to milliseconds
        var date1_ms = date1.getTime();
        var date2_ms = date2.getTime();

        // Calculate the difference in milliseconds
        var difference_ms = date2_ms - date1_ms;

        // Convert back to days and return
        return Math.round(difference_ms / one_day);
    }

    // End Xu ly ngay
    function beginPaging(args) {
        // Animate        
        $('.popupChonNVDuyet #container').fadeOut('fast');
    }

    function successPaging() {
        // Animate
        $('.popupChonNVDuyet #container').fadeIn('normal');
    }

    function failurePaging() {
        alert("Không thể tải dữ liệu");
    }
    function enterToSeacrh(event) {
        if (event.keyCode == 13)
            $("#btnSearchNhanVienPhongBan").click();
    }


</script>
<div class="panel-body">
    <div style="position: relative; margin-bottom: 5px;">
        <input type="text" id="searchString" value="@ViewBag.Search" class="form-control" style="padding-right: 30px; border-radius: 50px" placeholder="Search" onkeypress="enterToSeacrh(event);" />
        <i class="fa fa-search" id="btnSearchNhanVienPhongBan" style="position: absolute; top: 9px; right: 10px; cursor: pointer"></i>
    </div>
</div>
<div id="container">
    <table class="table table-striped table-hover table-condensed">
        <thead style="font-size: 13px">
            <tr>
                <th style="width: 45px">STT</th>
                <th>Hình ảnh
                </th>
                <th>Nhân viên
                </th>
                <th>Phòng ban
                </th>
                <th>Chức danh
                </th>
                <th style="width: 45px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var HinhAnh = item.maNhanVien + ".jpg";          
                <tr>
                    <td style="text-align: center">@i</td>
                    <td style="text-align: center">

                        <img class="Avatar imgSmall" onerror="imgError(this);" accept="image/*"src="/UploadFiles/QLNV/@HinhAnh" >
                    </td>
                    <td><i class="fa fa-user" style="color: blue"></i>@item.hoVaTen
                        @if (item.birthday != null)
                        { 
                            <p>
                                Ngày sinh: 
                                    @String.Format("{0:dd/MM}", item.birthday)
                            </p>
                        }

                    </td>
                    <td>@item.phongBan</td>
                    <td>@item.chucDanh</td>
                    <td style="color: #0b74d5; text-align: center">
                        <input type="hidden" id="hotenNVPB" value="@item.hoVaTen" />
                        <input type="hidden" id="maNVPB" value="@item.maNhanVien"/>
                        <input type="hidden" id="chucVuNVPB" value="@item.chucDanh"/>
                        <input type="hidden" id="emailNVPB" value="@item.email" />
                        <input type="hidden" id="ngayVaoLamNVPB" value="@item.ngayVaoLam" />
                        <button type="button" class="btn btn-primary btn-xs btnChonNVPB" data-dismiss="modal">Chọn</button>
                    </td>
                </tr>
                        i++;
            }
        </tbody>
    </table>
    <div>
        Trang @Model.PageNumber của @Model.PageCount / @ViewBag.Count
    </div>
    <div>
        <ul class="pagination">
            @Html.Raw(Ajax.Pager(new AjaxOptions { UpdateTargetId = "TabNV", OnBegin = "beginPaging", OnSuccess = "successPaging", OnFailure = "failurePaging" }, Model.PageSize, Model.PageNumber, Model.TotalItemCount, new { controller = "NhanVienVip", action = "LoadNhanVienDuyet", searchString = ViewBag.Search, maPhongBan = ViewBag.MaPhongBan }))
        </ul>
    </div>
</div>
