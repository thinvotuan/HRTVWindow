@using BatDongSan.Models.DanhMuc;
@model IPagedList<sp_PB_DanhSachNhanVienResult>
<script type="text/javascript" src="~/Scripts/Jquery.treeview/jquery.treeview.js"></script>
<link rel="stylesheet" href="~/Scripts/Jquery.treeview/jquery.treeview.css" />
<style>
    td
    {
        border: none;
    }
    #navigation1 a:link
    {
        color:#0000FF;
    }
</style>
<script>
    var maPhongban = "";
    $(document).ready(function () {

        var heightBrowser = $(window).height();
        var heightWrapper = $(".popupChonNVDuyet").height();

        var heightSet = heightBrowser - heightWrapper;
        heightSet = parseInt(heightSet);
        heightSet = heightSet - 50;

        $("#TabPB").css("height", heightSet);
        $("#TabPB #navigation1").treeview({
            persist: "location",
            collapsed: true,
            unique: false
        }).find(".expandable-hitarea").click();;
        $("#TabPB #navigation1 a").click(function () {
            beginPaging();            
            $.each($("#TabPB #navigation1 a"), function () {
                $(this).css("color", "");
            });
            $(this).css("color", "red");
            maPhongban = $(this).attr("alt");
            var url = "@Url.Action("LoadNhanVienDuyet", "NhanVienVip")" + "?searchString=" + "&maPhongBan=" + maPhongban;
            $(".popupChonNVDuyet #TabNV").load(url, function () {
                
            });
            successPaging();
        });       

    });

    function beginPaging(args) {
        // Animate        
        $('.popupChonNVDuyet #TabNV').fadeOut('fast');
    }

    function successPaging() {
        // Animate
        $('.popupChonNVDuyet #TabNV').fadeIn('fast');
    }

</script>

<div id="content" class="popupChonNVDuyet">
    <div id="tabs" style="width: 30%;margin-right:10px; height: auto; border: none; float: left; box-sizing: border-box; overflow: hidden; clear: none;" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                    <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active ">
                        <a><span><i class="fa fa-yelp" aria-hidden="true"></i>Danh sách Bộ phận</span></a></li>
                </ul>
            </div>
    <div id="tabs" style="width: 68%; height: auto; border: none; float: left; box-sizing: border-box; overflow: hidden; clear: none;" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                    <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active activeColorTab tabToggle">
                        <a href="#"><span><i class="fa fa-users" aria-hidden="true"></i>Danh sách nhân viên</span></a>

                    </li>
                    
                </ul>
            </div>
    <div style="clear:both"></div>
    <div style="width: 30%; float: left;overflow:auto;margin-right:10px;box-shadow: 0 0 6px #000; " id="TabPB">

        @Html.Raw(ViewBag.NVPB)
    </div>
    <div style="width: 68%; float: left;box-shadow: rgb(0, 0, 0) 0px 0px 5px;padding: 10px;border-radius:0 5px 5px 5px" id="TabNV">
        <div class="panel-body">
            <div style="position: relative;margin-bottom: 5px;">
                <input type="text" id="searchString" class="form-control" style="padding-right: 30px; border-radius: 50px" placeholder="Search" onkeypress="enterToSeacrh(event);" />
                <i class="fa fa-search" id="btnSearchNhanVienPhongBan" style="position: absolute; top: 9px; right: 10px; cursor: pointer"></i>
            </div>
        </div>
        <div id="container">
            <table class="table table-striped table-hover table-condensed">
                <thead style="font-size: 13px">
                    <tr>
                        <th style="width: 45px">STT</th>
                        <th>Hình ảnh
                        </th>
                        <th>Nhân viên
                        </th>
                        <th>Phòng ban
                        </th>
                        <th>Chức danh
                        </th>
                        <th style="width: 45px"></th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>

        </div>
    </div>

</div>
