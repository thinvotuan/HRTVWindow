@using BatDongSan.Models.NhanSu
@model IList<tbl_NS_ThanhTinhThueTNCN>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int i = 1;    
}
<link rel="stylesheet" href="~/Content/batdongsan-alert.css" />
<script src="~/Scripts/batdongsan.generals.js"></script>
<script src="~/Scripts/autoNumeric.js"></script>
<style>
    #content td, th
    {
        border-bottom: 1px inset #ADC2D6;
        position: relative;
        text-align: center;
    }
</style>
<script type="text/javascript">
    $(document).ready(function () {

        $(".numberinput").autoNumeric('init', { mDec: 2, lZero: 'deny', aSep: ',', aDec: '.', pSign: 's', vMin: '0' });

        $("#customModal").on("hide.bs.modal", function () {
            $("#custom-panel").html("");
        });

        $(document).on("click", ".btnDelete", function () {
            var url = "@Url.Action("Delete", "ThangTinhThueTNCN")" + "/" + this.value;
            bootbox.confirm("Bạn có muốn xóa không", function (result) {
                if (result) {
                    var form = document.getElementById("form-submit");
                    form.action = url;
                    form.submit();
                }
            })
        })

        $(document).on("click", ".btnEdit", function () {
            var url = "@Url.Action("Edit", "ThangTinhThueTNCN")" + "/" + this.value;
            location.href = url;
        })
    });
    function them() {
        location.href = "/ThangTinhThueTNCN/Create";
    }
</script>
<form id="form-submit" method="post">
    <div id="container">
        <fieldset class="removeBorderFieldset">
            <div id="tabs" class="ui-tabs">
                <ul class="ui-tabs-nav">
                    <li class="ui-tabs-selected ui-state-active"><a><span>Thang tính thuế TNCN</span></a></li>
                </ul>
            </div>
            <div class="panel-body background_top">
                <div class="form-inline">
                    <div class="form-group" style="float: right">
                        <button class="btn btn-info btnThemeAdd" onclick="them()" type="button">Thêm </button>
                    </div>
                </div>
            </div>
            <div id="content">
                <div id="filter-panel" class="collapse filter-panel background_top" style="display: block">
                    <table class="table table-striped table-hover table-condensed" id="maintable">
                        <thead>
                            <tr>
                                <th>STT</th>
                                <th>Mô tả chi tiêt</th>
                                <th>Ngày áp dụng</th>
                                <th>Ngày cập nhật</th>
                                <th>Giảm trừ cá nhân</th>
                                <th>Giảm trừ gia cảnh</th>
                                <th>Ghi chú</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {                            
                                <tr>
                                    <td style="text-align: center">@i</td>
                                    <td style="text-align: left">
                                        <a style="color:#519ee5" href="@Url.Action("Details", "ThangTinhThueTNCN", new { id = item.id })">@item.moTa</a></td>
                                    <td style="text-align: center">@item.ngayApDung.Value.ToString("dd/MM/yyyy")</td>
                                    <td style="text-align: center">@item.ngayCapNhat.Value.ToString("dd/MM/yyyy")</td>
                                    <td style="text-align: center" class="numberinput">@item.giamTruCaNhan</td>
                                    <td style="text-align: center" class="numberinput">@item.giamTruGiaCanh</td>
                                    <td style="text-align: center">@item.ghiChu</td>
                                    <td style="text-align: right">
                                        <button class="btn btn-primary btn-xs btnEdit" type="button" data-toggle="modal" data-target="#customModal" value="@item.id">Sửa</button>
                                        <button class="btn btn-warning btn-xs btnDelete" type="button" value="@item.id">Xóa</button>
                                    </td>
                                </tr> 
                                i++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </fieldset>
    </div>
</form>
