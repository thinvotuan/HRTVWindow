@using BatDongSan.Models.DanhMuc;
@model IPagedList<DMPhanCaNhanVien>
@{
    int i = 1;
}
<style>
    .contentND th
    {
            border: 1px solid #ccc !important;
        text-align:center;
        font-weight:normal;
        font-size:14px;
    }
</style>
<div id="loadNhanVienINPC" class="contentND">
    <table class="table table-striped table-hover table-condensed" id="maintable">
        <thead>
            <tr>
                <th style="width: 30px">STT</th>
                <th style="">Tên phân ca</th>
                <th style="">Nhân viên</th>
                 <th style="">Phòng ban - chức danh</th>
                <th style="">Ngày áp dụng</th>
                <th style="">Ngày vào làm</th>

            </tr>
        </thead>
      
        <tbody id="">




            @foreach (var item in Model)
            {
                <tr>
                    <td align="center">
                        @i
                    </td>
                    <td style="text-align: center">@ViewBag.TenCa</td>
                    <td><a style="color:#519ee5" href="@Url.Action("Details", "NhanVien", new { id = item.maNhanVien })">@item.maNhanVien</a>
                        <br />
                        <i class="fa fa-user" aria-hidden="true"></i>@item.hoVaTen</td>

                    <td>@item.tenPhongBan - @item.tenChucDanh
                    </td>

                    <td style="text-align: center">@String.Format("{0: dd/MM/yyyy HH:mm:ss}", item.ngayApDung)</td>
                    <td style="text-align: center">@String.Format("{0: dd/MM/yyyy HH:mm:ss}", item.ngayVaoLam)</td>






                </tr> 
                i++;
            }

        </tbody>
    </table>

    <div>
        Trang @Model.PageNumber của @Model.PageCount / @ViewBag.Count
    </div>
    <div>
        <ul class="pagination">
            @Html.Raw(Ajax.Pager(new AjaxOptions { UpdateTargetId = "loadNhanVienINPC", OnBegin = "beginPaging2", OnSuccess = "successPaging2", OnFailure = "failurePaging2" }, Model.PageSize, Model.PageNumber, Model.TotalItemCount, new { controller = "PhanCaNhanVien", action = "ListNhanVienTrongPhanCa", qSearch = ViewBag.Search, maPhanCa = ViewBag.maPhanCa }))
        </ul>
    </div>
</div>
<script>
    function beginPaging2(args) {
        // Animate        
        $('#loadNhanVienINPC').fadeOut('fast');
    }

    function successPaging2() {
        // Animate
        $('#loadNhanVienINPC').fadeIn('normal');
    }

    function failurePaging2() {
        alert("Không thể tải dữ liệu");
    }

</script>
