@using BatDongSan.Models.DanhMuc;
@model DMPhanca
@{
    ViewBag.Title = "Phân ca nhân viên";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/Scripts/jquery-2.1.4.min.js"></script>
<script src="~/Content/bootstrap/js/bootstrap.min.js"></script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/additional-methods.min.js"></script>
<script src="~/Scripts/batdongsan.validate.js"></script>
<link rel="stylesheet" href="~/Content/batdongsan-alert.css" />
<script src="~/Scripts/batdongsan.generals.js"></script>
<script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>
<script src="~/Scripts/moment.min.js"></script>
<script src="~/Scripts/vi.js"></script>
<script src="~/Scripts/bootstrap-datetimepicker.min.js"></script>
<link rel="stylesheet" href="~/Content/bootstrap-datetimepicker.min.css" />
<script>
    $(document).ready(function () {       
        $("#btnSubmit").click(function () {
            if (CheckForm()) {
                $("#form-submit").submit();
            }
        });
        $("#btnTroVe").click(function () {
            location.href = '@Url.Action("Index")';
        });
        $(".datepicker").datetimepicker({
            locale: 'vi',
            format: 'DD/MM/YYYY'
        });
        //$(document).on("dp.change", "#ngayApDung", function (e) {
        //    var dateTime = Date.parse(convertDate($(this).val()));
        //    var Dates = new Date(dateTime);
        //    var firstDay = new Date(Dates.getFullYear(), Dates.getMonth(), 1);
        //    if (Dates != firstDay) {
        //        Alert.error("Ngày áp dụng phải là ngày đầu tháng ví dụ (" + moment(firstDay).format("DD/MM/YYYY")+")", "Thông báo", { displayDuration: 4000 });
        //        //$(this).val(moment(firstDay).format("DD/MM/YYYY"));
        //    }
        //});
    });

    function ChonNhanVien() {
        $('#myModalChonPhongBan').modal();
        var Url = '@Url.Action("ChonNhanVien", "PhanCaNhanVien")';
        $('#filter-panel').load(Url);
    }
    function Delete(obj)
    {
        $(obj).parent().parent().remove();
        for (var i = 0; i < $("#load").find("tr").length; i++) {
            $("#load tr:eq(" + i + ")").find("td").first().html(i+1);
        }
    }
    function CheckForm() {
        var flag = true;
        if ($("#ngayApDung").val() == "") {
            $("#ngayApDung").addClass("error").attr("title", "Ngày áp dụng không được rỗng.");
            flag = false;
        }

        //var dateTime = Date.parse(convertDate($("#ngayApDung").val()));
        //var Dates = new Date(dateTime);
        //var firstDay = new Date(Dates.getFullYear(), Dates.getMonth(), 1);
        //if (Dates != firstDay) {
        //    $("#ngayApDung").addClass("error").attr("title", "Ngày áp dụng phải là ngày đầu tháng ví dụ (" + moment(firstDay).format("DD/MM/YYYY") + ")");
        //    flag = false;
        //    //$(this).val(moment(firstDay).format("DD/MM/YYYY"));
        //}

        return flag;
    }
</script>
<style>
    #tbl-create td
    {
        border: none;
    }
</style>

<form id="form-submit" class="form-horizontal" method="post">
    <div id="container" class="custome_fieldSet">
        <fieldset class="removeBorderFieldset">
            <div id="tabs" style="width: 30%; height: auto; border: none; float: left; box-sizing: border-box; overflow: hidden; clear: none;" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                    <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active ">
                        <a><span><i class="fa fa-yelp" aria-hidden="true"></i>Phân ca nhân viên</span></a></li>
                </ul>
            </div>
            <table class="table table-striped table-hover table-condensed" id="tbl-create" style="position: relative">
                
                <tr style="font-weight:bold">
                    <td style="width: 15%;line-height: 30px;">Ca làm việc</td>
                    <td style="width: 35%">@Model.tenPhanca
                        @Html.Hidden("maPhanCa",@Model.maPhanca)
                    </td>
                    <td></td>
                    <td></td>
                </tr>
                <tr>
                    <td style="line-height: 30px;">Ngày cập nhật</td>
                    <td>@String.Format("{0:dd/MM/yyyy}",DateTime.Now) </td>
                    <td style="width: 15%">
                        Người cập nhật
                    </td>
                    <td style="width: 35%">
                        @ViewBag.NguoiCapNhat
                    </td>
                    
                </tr>

            </table>
            <table class="table table-striped table-hover table-condensed" id="maintable">
                <thead>
                    <tr>
                        <th colspan="12">
                            <button type="button" class="btn btn-warning" style="color: #FFF;float :right " onclick="ChonNhanVien()" ><i class="fa fa-users" aria-hidden="true"></i> Chọn nhân viên</button>
                        </th>
                    </tr>
                    <tr>
                        <th style="width: 45px;text-align:center">STT</th>
                        <th style="width: 100px;text-align:center">Mã nhân viên</th>
                        <th style="width: 120px;text-align:center">Tên nhân viên</th>
                        <th style="width: 80px;text-align:center">Ngày vào làm</th>
                        <th style="width: 120px;text-align:center">Bộ phận</th>
                        <th style="width: 120px;text-align:center">Chức danh</th>
                        <th style="width: 80px;text-align:center">Ngày áp dụng</th>
                        <th style="width: 30px"></th>
                    </tr>
                </thead>
                <tbody id="load">     
                    @{Html.RenderPartial("DanhSachNhanVien",Model.ListNhanVien);}               
                </tbody>
            </table>
            <div style="text-align: right; margin: 10px 0">
                <button class="btn btn-info" id="btnSubmit" type="button">Lưu </button>
                <button class="btn btn-info" type="button" id="btnTroVe">Trở về </button>
            </div>
        </fieldset>

    </div>
    <div id="myModalChonPhongBan" class="modal fade" role="dialog">
        <div class="modal-dialog modal-lg">
            <!-- Modal content-->
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title"></h4>
                  </div>
                <div class="modal-body">
                    <div class="container" style="width: 98%">
                        <div class="row">
                            <div id="filter-panel" class="filter-panel">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                </div>
            </div>

        </div>
    </div>
</form>

