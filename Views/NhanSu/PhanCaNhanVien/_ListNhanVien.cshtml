@using BatDongSan.Models.DanhMuc;
@model IPagedList<DMPhanCaNhanVien>
@{
    Layout = null;
    int i = 1;
}
<style>
    #ListNV .table + div
    {
        float: left;
        line-height: 32px;
        margin-right: 10px;
        border: 1px solid #ddd;
        padding: 0 10px;
        border-radius: 4px;
        background: #0F4C99;
        color: #fff;
    }
</style>
<script>
    function beginPaging1(args) {
        // Animate        
        $('#ListNV').fadeOut('fast');
    }

    function successPaging1() {
        // Animate
        $('#ListNV').fadeIn('normal');
    }

    function failurePaging1() {
        alert("Không thể tải dữ liệu");
    }

</script>
<div id="ListNV">
    <div id="container" class="custome_fieldSet">
        <fieldset class="removeBorderFieldset">
            <div id="tabs" style="width: 100%; height: auto; border: none; float: left; box-sizing: border-box; overflow: hidden; clear: none;" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                    <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active ">
                        <a><span><i class="fa fa-yelp" aria-hidden="true"></i>Danh sách phân ca nhân viên của @ViewBag.TenCa</span></a></li>
                </ul>
            </div>

            <table class="table table-striped table-hover table-condensed" id="maintable">
                <thead>
                    <tr>
                        <th style="width: 45px; text-align: center">STT</th>
                        <th style="width: 100px; text-align: center">Mã nhân viên</th>
                        <th style="width: 120px; text-align: center">Tên nhân viên</th>
                        <th style="width: 80px; text-align: center">Ngày vào làm</th>
                        <th style="width: 120px; text-align: center">Bộ phận</th>
                        <th style="width: 120px; text-align: center">Chức danh</th>
                        <th style="width: 80px; text-align: center">Ngày áp dụng</th>
                    </tr>
                </thead>
                <tbody id="load">
                    @foreach (var item in Model)
                    {
                        if (!string.IsNullOrEmpty(item.maNhanVien))
                        {
                        <tr>
                            <td style="text-align: center">@i</td>
                            <td>@item.maNhanVien
                            </td>
                            <td>@item.hoVaTen</td>
                            <td style="text-align: center">@String.Format("{0:dd/MM/yyyy}", item.ngayVaoLam)</td>
                            <td>@item.tenPhongBan</td>
                            <td>@item.tenChucDanh</td>
                            <td style="text-align:center">@String.Format("{0:dd/MM/yyyy}", item.ngayApDung)</td>
                        </tr>
                            i++;
                        }
                    }
                </tbody>
            </table>
            <div>
                Trang @Model.PageNumber của @Model.PageCount / @ViewBag.Count
            </div>
            <div>
                <ul class="pagination">
                    @Html.Raw(Ajax.Pager(new AjaxOptions { UpdateTargetId = "ListNV", OnBegin = "beginPaging1", OnSuccess = "successPaging1", OnFailure = "failurePaging1" }, Model.PageSize, Model.PageNumber, Model.TotalItemCount, new { controller = "PhanCaNhanVien", action = "ListNhanVien", maPhanCa = ViewBag.maPhanCa }))
                </ul>
            </div>

        </fieldset>
    </div>
</div>
