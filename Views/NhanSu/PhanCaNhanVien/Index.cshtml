@using BatDongSan.Models.DanhMuc;
@model IPagedList<DMPhanca>
@{
    ViewBag.Title = "Phân ca nhân viên";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/additional-methods.min.js"></script>
<script src="~/Scripts/autoNumeric.js"></script>
<script src="~/Scripts/batdongsan.validate.js"></script>
<script src="~/Scripts/moment.min.js"></script>
<script src="~/Scripts/vi.js"></script>
<script src="~/Scripts/bootstrap-datetimepicker.min.js"></script>
<link rel="stylesheet" href="~/Content/bootstrap-datetimepicker.min.css" />
<script src="~/Scripts/batdongsan.utils.js"></script>
<link rel="stylesheet" href="~/Content/batdongsan-alert.css" />
<script type="text/javascript" src="~/Scripts/Jquery.treeview/jquery.treeview.js"></script>
<link rel="stylesheet" href="~/Scripts/Jquery.treeview/jquery.treeview.css" />
<script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>
<script>
    $(document).ready(function () {
        $('#btnTimKiem').click(function () {
            var searchText = $('#searchString').val().replace(/\ /g, '+');
            var url = "@Url.Action("Index", "PhanCaNhanVien")" + "?qSearch=" + searchText;
            beginPaging();
            $('#content').load(url);
            successPaging();
        });
        $('#btnSearchTC').click(function () {
            SearchTC()
        });
        $("#btnThem").click(function () {
            var Create = "@Url.Action("Create", "PhanCaNhanVien")";
            location.href = Create;
        });
        //setting phong ban//
        $("#navigation1").treeview({
            persist: "location",
            unique: false,
            collapsed: true
        }).find(".expandable-hitarea").click();


        $('ul.dropdown-menu .hitarea').on('click', function (event) {
            event.stopPropagation();
        });

        $('#txtsearch').on("input", function () {

            $('#navigation1').filterLink($('#txtsearch').val());
        });

        $("#phongban-dropdown-menu").removeAttr("style");

        $("#customModal").on("hide.bs.modal", function () {
            $("#custom-panel").html("");
        });


        $(document).on("click", "#phongban-dropdown-menu li a", function () {
            $("#btnPhongBan").val(this.id);
            $(this).parents(".dropdown").find('.btn').html($(this).text() + ' &nbsp;<span class="caret"></span>');
            $("#btnSearchTC").click();
        })
        //End
        $(".tabToggle").click(function () {
            $("#btnTimKiem").click();
            $(".tabToggle").removeClass("ui-tabs-selected ui-state-active activeColorTab");
            $(".contentToggle").hide(300);
            var index = $(".tabToggle").index(this);
            $(".tabToggle").eq(index).addClass("ui-tabs-selected ui-state-active activeColorTab");
            $(".contentToggle").eq(index).show(300);
        });
    });
    function Update(maPhanCa) {
        var url = "@Url.Action("Edit", "PhanCaNhanVien")" + "/" + maPhanCa;
        location.href = url;
    }
    function UpdateNhanVien(maPhanCa) {
        var url = "@Url.Action("EditNhanVien", "PhanCaNhanVien")" + "/" + maPhanCa;
        location.href = url;
    }
    function QuyDinhGio(maPhanCa) {
        var url = "@Url.Action("Details", "PhanCaNhanVien")" + "/" + maPhanCa;
        location.href = url;
    }
    function Delete(maPhanCa) {
        var url = "@Url.Action("Delete", "PhanCaNhanVien")" + "/" + maPhanCa;
        var form = document.getElementById("form-listview");
        form.method = "post";
        form.action = url;
        form.submit();
    }
    function enterToSeacrh(event) {
        if (event.keyCode == 13)
            $("#btnTimKiem").click();
    }
    function XemDanhSach(maPhanCa) {
        $('#myModalChonPhongBan').modal();
        var Url = '@Url.Action("ListNhanVienTrongPhanCa", "PhanCaNhanVien")' + "?maPhanCa=" + maPhanCa;
        $('#filter-panel1').load(Url);
    }
    function OnCriteriaPCTC(page) {
        var giatri = $("#qSearchTC").val().trim();
        giatri = giatri.replace(/ /gi, '+');
        var valPhongBan = $("#btnPhongBan").val().replace(/ /gi, '+');
        var url = '@Url.Action("LoadPhanCaNhanVienChiTiet", "PhanCaNhanVien")' + "?maPhongBan=" + valPhongBan + "&qSearch=" + giatri + "&_page=" + page;
        var imageUrl = '<div id="divMsgTC" align="center"><img src="@Url.Content("~/Content/Images/loading.gif") "/></div>';
        $('#contentPC').html(imageUrl);
        $('#contentPC').load(url, function () {
        });
    }

    function enterToSeacrhTC(event) {
        if (event.keyCode == 13)
            $("#btnSearchTC").click();
    }
    function SearchTC() {

        var giatri = $("#qSearchTC").val().trim();
        giatri = giatri.replace(/ /gi, '+');
        var valPhongBan = $("#btnPhongBan").val().replace(/ /gi, '+');

        var url = '@Url.Action("LoadPhanCaNhanVienChiTiet", "PhanCaNhanVien")' + "?maPhongBan=" + valPhongBan + "&qSearch=" + giatri + "&_page=0";

        var imageUrl = '<div id="divMsgTC" align="center"><img src="@Url.Content("~/Content/Images/loading.gif") "/></div>';
        $('#contentPC').html(imageUrl);
        $('#contentPC').load(url, function () {
        });
    }

    function submitFormPhanCaThu7() {
        bootbox.confirm("Bạn có chắc chắn áp dụng phân ca cho ngày thứ 7 của tháng này.", function (result) {
            if (result) {

                $.ajax({
                    type: 'POST',
                    dateType: 'json',
                    url: '/PhanCaNhanVien/PhanCaThu7TrongThang',
                    data: $("[name=pct7_chk]:checked").serialize(),
                    success: function (result) {
                        if (result == '') {
                            Alert.success("Đã cập nhật dữ liệu thành công!", "Thông báo", { displayDuration: 2000 });
                        }
                        else {
                            Alert.error(result, "Thông báo", { displayDuration: 2000 });
                        }
                    },
                    error: function (request, textStatus, errorThrown) {
                        Alert.error("Có lỗi xảy ra, vui lòng liên hệ bộ phận IT.", "Thông báo", { displayDuration: 0 });
                    }
                });
            }
        });
    }
</script>
<style>
    #content td, #contentPC td {
        border-bottom: 1px inset #ADC2D6;
        position: relative;
    }

    #content th, #contentPC th {
        text-align: center;
    }

    #filter-panel td {
        border: none;
    }

    #navigation1 {
        overflow: auto;
        height: 600px;
    }

    .pageActive, .pageCurrent:hover, .pageNext:hover, .pageLast:hover, .pageFirst:hover, .pagePrevious:hover {
        padding: 7px 11px;
        background-color: #4D8AFF;
        color: #FFFFFF;
        display: inline-block;
        border: 1px solid #80ABFF;
        border-radius: 20px;
        text-decoration: none;
        font-weight: bold;
    }

    .pageCurrent, .pageNext, .pageLast, .pageFirst, .pagePrevious {
        padding: 7px 11px;
        background-color: #fff;
        display: inline-block;
        border: 1px solid #80ABFF;
        border-radius: 20px;
        font-weight: bold;
    }
</style>
<form id="form-listview">
    <div id="container">
        <fieldset class="removeBorderFieldset">
            <div id="tabs" style="" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                    <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active activeColorTab tabToggle"><a><i class="fa fa-yelp" aria-hidden="true"></i><span>Danh sách phân ca</span></a></li>
                    <li class="ui-state-default ui-corner-top tabToggle">
                        <a href="#"><span><i class="fa fa-users" aria-hidden="true"></i>Danh sách phân ca nhân viên</span></a></li>

                    @*<li class="ui-state-default ui-corner-top tabToggle">
                        <a href="#"><span><i class="fa fa-users" aria-hidden="true">Phân ca ngày thứ 7 trong tháng</i></span></a></li>*@
                </ul>
            </div>
            <div class="contentToggle">
                <div id="filter-panel" class="collapse filter-panel" style="display: block; position: relative">
                    <div class="panel panel-default background_top">
                        <div class="panel-body">
                            <div>
                                <input type="text" id="searchString" value="@ViewBag.Search" class="form-control" style="width:300px;float:left" placeholder="Nhập giá trị tìm kiếm" onkeypress="enterToSeacrh(event);" />
                                <button class="btn btn-info" id="btnTimKiem" type="button" style="float: left; margin-left: 5px">Tìm kiếm</button>
                                <button class="btn btn-info" id="btnThem" type="button" style="float: right">Thêm</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div id="content">
                    @{Html.RenderPartial("ViewIndex");}
                </div>
            </div>
            <div class="contentToggle" style="display: none">
                <div class="form-inline">
                    <div class="panel-body background_top" style="padding-top: 3px !important;">
                        <div class="form-group">
                            <input type="text" class="form-control" id="qSearchTC" onkeypress="enterToSeacrhTC(event)" value="@ViewBag.Search" style="width:300px;" />
                        </div>
                        <div class="form-group">
                            <button id="btnSearchTC" type="button" class="btn btn-primary btn-sm">
                                <span class="glyphicon glyphicon-search" style="top: 2px;"></span>Tìm kiếm
                            </button>
                        </div>

                        <div class="form-group" id="phongban-div">
                            <div class="dropdown">
                                <button class="btn btn-primary btn-sm dropdown-toggle" id="btnPhongBan" type="button" data-toggle="dropdown">
                                    Danh sách phòng ban&nbsp;<span class="caret"></span>
                                </button>
                                <ul class="dropdown-menu" id="phongban-dropdown-menu">
                                    <li role="presentation">
                                        <div class="form-group has-feedback" style="width: 90%; margin: 5px auto !important; display: block;">
                                            <input type="text" class="form-control input-sm" id="txtsearch" placeholder="Search" style="width: 100%" />
                                            <span class="glyphicon glyphicon-search form-control-feedback"></span>
                                        </div>
                                    </li>
                                    <li role="presentation">
                                        @Html.Raw(ViewBag.PhongBans)
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
                <table style="width: 100%" class="table table-striped table-hover table-condensed tableThemeCustome">

                    <thead>
                        <tr>
                            <th style="width: 35px; text-align: center">STT
                            </th>
                            <th style="text-align: center">Nhân viên
                            </th>

                            <th style="text-align: center">Phòng ban - chức danh
                            </th>

                            <th style="text-align: center">Tên phân ca</th>
                            <th style="text-align: center">Ngày áp dụng</th>

                            <th style="text-align: center">Ngày cập nhật</th>




                        </tr>
                    </thead>
                    <tbody id="contentPC">
                    </tbody>


                </table>


            </div>

            @*<div class="contentToggle" style="display: none">
                <table style="width: 100%" class="table table-striped table-hover table-condensed tableThemeCustome">
                    <thead>
                        <tr>
                            <th style="width: 10%; text-align: center">Lần</th>
                            <th style="width: 30%; text-align: center">Ngày</th>
                            <th style="width: 60%; text-align: center">#</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var phanCaNgayThu7 = ViewBag.PhanCaNgayThu7 as List<fn_tbl_NS_PhanCaNhanVien_NgayThu7Result>;

                            if (phanCaNgayThu7 != null && phanCaNgayThu7.Count() > 0)
                            {
                                foreach (var item in phanCaNgayThu7)
                                {
                            <tr>
                                <td style="text-align: center;">
                                    @item.lanTrongThang
                                </td>
                                <td style="text-align: center;">
                                    @String.Format("{0:dd/MM/yyyy}", item.ngay)
                                </td>
                                <td style="text-align: center;">
                                    @if ((item.lanSetLai ?? 0) > 0)
                                    { 
                                        <input type="checkbox" checked="checked" name="pct7_chk" value="@item.lanTrongThang"/>
                                    }
                                    else
                                    {
                                        <input type="checkbox" name="pct7_chk" value="@item.lanTrongThang"/>
                                    }
                                </td>
                            </tr>
                                }

                            }
                            
                        }
                    </tbody>
                </table>
                <div style="text-align: right;">
                    <input type="button" value="Lưu" onclick="submitFormPhanCaThu7();" />
                </div>
            </div>*@
        </fieldset>
    </div>
    <div id="myModalChonPhongBan" class="modal fade" role="dialog">
        <div class="modal-dialog modal-lg">
            <!-- Modal content-->
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title"></h4>
                </div>
                <div class="modal-body">

                    <div class="container" style="width: 98%">
                        <div class="row">
                            <div id="filter-panel1" class="filter-panel">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                </div>
            </div>

        </div>
    </div>
</form>

