@using BatDongSan.Models.DanhMuc;
@model tbl_NS_PhanCa
@{
    ViewBag.Title = "Cập nhật phân ca";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/Content/bootstrap/css/bootstrap.min.css" />
<script src="~/Scripts/jquery-2.1.4.min.js"></script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/additional-methods.min.js"></script>
<script src="~/Scripts/batdongsan.validate.js"></script>
<script src="~/Scripts/autoNumeric.js"></script>
<script type="text/javascript">
    $(document).ready(function () {
        $(".numberinput").autoNumeric('init', { mDec: 1, lZero: 'deny', aSep: ',', aDec: '.', pSign: 's', vMin: '0' });
        $(".numberinputInt").autoNumeric('init', { lZero: 'deny', mDec: 2, pSign: 's', aSep: ',', aDec: '.' });
        $("#btnTroVe").click(function () {
            var url = "@Url.Action("Index", "PhanCaNhanVien")"
            location.href = url;
        })
    });
</script>
<style>
    #CreatePhanCa td {
        border: none;
    }

    #CreatePhanCa {
        margin: 0;
    }
</style>
<form class="form-horizontal" method="post" id="form-submit" style="width: 100%">
    <div id="container">
        <fieldset class="removeBorderFieldset">
            <div id="tabs" style="" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                    <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active"><a><span>Cập nhật ca làm việc</span></a></li>
                </ul>
            </div>
            <div class="collapse" style="display: block">
                <div class="panel panel-default">
                    <table class="table table-striped table-hover table-condensed" id="CreatePhanCa">
                        <tr>

                            <td style="width: 15%" class="tdtitle">Tên ca</td>
                            <td style="width: 85%" colspan="3">
                                @Html.TextBoxFor(model => model.tenPhanCa, new { @class = "form-control" })
                            </td>
                        </tr>
                        <tr>
                            <td class="tdtitle">Tính ngày/giờ công
                            </td>
                            <td>
                                <div class="checkbox">
                                    <label>
                                        @Html.CheckBox("isSalaryByMont", Convert.ToBoolean(Model.tinhNgayGioCong))</label>
                                </div>
                            </td>
                            <td class="tdtitle">Số giờ làm việc / ngày
                            </td>
                            <td>
                                @Html.TextBoxFor(model => model.tongGioLamViec, new { @class = "form-control numberinput", @style = "width:40%;display:inline", data_v_max = "99" })
                                Note: 0 => Số ngày công sẽ lấy theo tháng.
                            </td>
                        </tr>
                        <tr>
                            <td class="tdtitle">Ghi chú
                            </td>
                            <td colspan="3">
                                @Html.TextAreaFor(model => model.ghiChu, new { @class = "form-control" })
                            </td>
                        </tr>
                        @* <tr>
                            <td colspan="4">&nbsp;</td>
                        </tr>*@
                        <tr>
                            <td colspan="4">
                                @*  <div id="tabs" style="" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                                    <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                                        <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active"><a><span>Quy định ngày làm trong tuần</span></a></li>
                                    </ul>
                                </div>*@
                                <table class="table table-striped table-hover table-condensed" id="QuiDinhNgaylam">
                                    <thead>
                                        <tr>
                                            <th style="text-align: center">THỨ HAI</th>
                                            <th style="text-align: center">THỨ BA</th>
                                            <th style="text-align: center">THỨ TƯ</th>
                                            <th style="text-align: center">THỨ NĂM</th>
                                            <th style="text-align: center">THỨ SÁU</th>
                                            <th style="text-align: center">THỨ BẢY</th>
                                            <th style="text-align: center">CHỦ NHẬT</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td style="text-align: center">@Html.CheckBox("monday", Convert.ToBoolean(Model.thuHai))</td>
                                            <td style="text-align: center">@Html.CheckBox("tuesday", Convert.ToBoolean(Model.thuBa))</td>
                                            <td style="text-align: center">@Html.CheckBox("wednesday", Convert.ToBoolean(Model.thuTu))</td>
                                            <td style="text-align: center">@Html.CheckBox("thursday", Convert.ToBoolean(Model.thuNam))</td>
                                            <td style="text-align: center">@Html.CheckBox("friday", Convert.ToBoolean(Model.thuSau))</td>
                                            <td style="text-align: center">@Html.CheckBox("sathurday", Convert.ToBoolean(Model.thuBay))</td>
                                            <td style="text-align: center">@Html.CheckBox("sunday", Convert.ToBoolean(Model.chuNhat))</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </td>
                        </tr>
                    </table>
                    <table class="table table-striped table-hover table-condensed">
                        <tr>
                            <td class="tdtitle" style="width: 50%;">Nghỉ 2 ngày thứ 7 đầu tiên trong tháng
                            </td>
                            <td colspan="1">
                                @Html.CheckBox("isNghi2NgayThu7DauTienTrongThang", Convert.ToBoolean(Model.isNghi2NgayThu7DauTienTrongThang))
                            </td>
                        </tr>
                    </table>
                    <table style="width: 100%" class="table table-striped table-hover table-condensed tableThemeCustome">
                        <thead>
                            <tr>
                                <th style="width: 10%; text-align: center">Tháng</th>
                                <th style="width: 18%; text-align: center">Tuần 1</th>
                                <th style="width: 18%; text-align: center">Tuần 2</th>
                                <th style="width: 18%; text-align: center">Tuần 3</th>
                                <th style="width: 18%; text-align: center">Tuần 4</th>
                                <th style="width: 18%; text-align: center">Tuần 5</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var phanCaNgayThu7 = ViewBag.PhanCaNgayThu7 as List<fn_tbl_NS_PhanCaNhanVien_NgayThu7Result>;

                                if (phanCaNgayThu7 != null && phanCaNgayThu7.Count() > 0)
                                {
                                    var thangPcs = phanCaNgayThu7.GroupBy(d => new { d.thang }).Select(d => d.Key.thang).OrderBy(d => d.Value).ToList();

                                    foreach (var thang in thangPcs)
                                    {
                                <tr>
                                    <td style="text-align: center;">
                                        @thang
                                    </td>
                                    @foreach (var item in phanCaNgayThu7.Where(d => d.thang == thang).OrderBy(d => d.lan))
                                    {
                                        <td style="text-align: center;">
                                            @String.Format("{0:dd/MM/yyyy}", item.tuan)
                                            @if ((item.chonTuan ?? false))
                                            { 
                                                <input type="checkbox" checked="checked" name="pct7_chk" value="@(item.thang + "_" + item.lan)"/>
                                            }
                                            else
                                            {
                                                <input type="checkbox" name="pct7_chk" value="@(item.thang + "_" + item.lan)"/>
                                            }
                                        </td>
                                    }
                                </tr>
                                            
                                    }
                                }
                            
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div style="text-align: right; margin-bottom: 10px">
                <button class="btn btn-info" id="btnSubmit">Lưu </button>
                <button class="btn btn-info" type="button" id="btnTroVe">Trở về </button>
            </div>
        </fieldset>
    </div>
</form>

