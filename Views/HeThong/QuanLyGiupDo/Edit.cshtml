@using BatDongSan.Models.HeThong;
@{
    ViewBag.Title = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int i = 1;
    // var List = ViewBag.lsTieuChi as List<tbl_NS_TieuChi>;
    Sys_GiupDo item = ViewBag.data;
}
<link rel="stylesheet" href="~/Content/bootstrap-datetimepicker.min.css" />
<script src="~/Scripts/moment.min.js"></script>
<script src="~/Scripts/vi.js"></script>
<script src="~/Scripts/bootstrap-datetimepicker.min.js"></script>
<script src="~/Scripts/autoNumeric.js"></script>
<script src="~/Scripts/batdongsan.uploadfile.js"></script>
<script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>
<script type="text/javascript">
    $().ready(function () {
        $("#btnSave").click(function () {
            if($("#ten").val()==null || $("#ten").val()==""){
                alert("Nhập tên");
                $("#ten").focus();
                return false;
            }
                $("form").submit();
            
        });
      

        setTimeout(function () { $("#divMsg").hide() }, 5000);
    });

   

    function ValidateKeypress(numcheck, e) {
        var keynum, keychar, numcheck;
        if (window.event) {//IE
            keynum = e.keyCode;
        }
        else if (e.which) {// Netscape/Firefox/Opera
            keynum = e.which;
        }
        if (keynum == 8 || keynum == 127 || keynum == null || keynum == 9 || keynum == 0 || keynum == 13) return true;
        keychar = String.fromCharCode(keynum);
        var result = numcheck.test(keychar);
        return result;
    }           

</script>
<style>
    td
    {
        border: none!important;
    }

    .input-group-btn
    {
        position: absolute;
        font-size: 0;
    }

    .numberinput
    {
        text-align: right;
    }
</style>

<script src="~/Scripts/ckeditor/ckeditor.js"></script>
<script src="~/Scripts/ckfinder/ckfinder.js"></script>
<script>
    $(document).ready(function () {
       
        var newCKEdit=  CKEDITOR.replace("noiDung", {
            toolbar: 'DauThau',
        });
        CKFinder.setupCKEditor(newCKEdit, '@Url.Content("~/Scripts/ckfinder")');
    });
</script>
@using (Html.BeginForm())
{
    <fieldset class="fieldset1">
        
        <legend class="legend">Sửa giúp đỡ</legend>
        <div  id="divMsg" style="color: Red;text-align: left">
            @{if ((string)ViewBag.Message != "")
              {
               <span>@ViewBag.Message.ToString()</span>
              }
            }
        </div>
       
        <div class="tab-content">
            <div class="tab-pane in active" id="tab1">
                <table border="0" cellpadding="0" cellspacing="0" style="width: 100%;">
                    <tr>
                        <td style="width: 150px"  class="tdtitle">Tên
                        </td>
                        <td >
                            <input type="text" id="ten" name="ten" value="@item.ten"
                            maxlength="250"  />
                        </td>
                    </tr>
                    <tr>
                        <td class="tdtitle">Nội dung
                        </td>
                        <td >
                         
                             <textarea id="noiDung" name="noiDung"  class="form-control"  required="required">@item.noiDung</textarea>
                        </td>
                    </tr>
                   
                    <tr>
                        <td>&nbsp;
                        </td>
                        <td colspan="2">
                            <input type="button" class="btnBlack" id="btnSave" value="Lưu" />
                            <input type="button" class="btnBlack" value="Trở về" onclick="window.location='@Url.Action("Index", "QuanLyGiupDo")'" />
                        </td>
                    </tr>
                </table>
            </div>
        </div>
    </fieldset>
}
