@using BatDongSan.Models.HeThong;
@using BatDongSan.Controllers.HeThong;
@model Sys_NhomUser
@{    
    ViewBag.Title = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";    
}
<link rel="stylesheet" href="~/Content/bootstrap/css/bootstrap.min.css" />
<script src="~/Scripts/jquery-2.1.4.min.js"></script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/additional-methods.min.js"></script>
<script src="~/Scripts/batdongsan.validate.js"></script>

<style>
    td
    {
        border: none;
    }

    table
    {
        margin: 0;
    }

    input
    {
        border: none;
    }
</style>
<script>
    $(document).ready(function () {
        $("#btnTroVe").click(function () {
            var url = "@Url.Action("Index", "PhanQuyen")";
            location.href = url;
        })
    });
</script>
<form class="form-horizontal" method="post" id="form-submit" style="width: 757px">
    <fieldset>
        <legend style="display: inline">Tạo nhóm mới</legend>
        <div class="collapse" style="display: block">
            <div class="panel panel-default">
                <table class="table table-striped table-hover table-condensed">
                    <tr>
                        <td class="tdtitle">Mã nhóm người dùng  <span style="font-style: italic; color: red">*</span></td>
                        <td>
                            @Html.TextBoxFor(model => model.maNhomUser, new { @class = "form-control", @maxlenght = "20", required = "required" })
                            <span style="font-style: italic; color: red">@TempData["MessgId"]</span>
                        </td>
                        <td style="text-align: right" class="tdtitle">Tên nhóm  <span style="font-style: italic; color: red">*</span>
                        </td>
                        <td>
                            @Html.TextBoxFor(model => model.tenNhomUser, new { @class = "form-control", @maxlenght = "100", required = "required" })
                            <span style="font-style: italic; color: red">@TempData["MessgTen"]</span>
                        </td>
                    </tr>
                    <tr>
                        <td class="tdtitle">Ghi chú
                        </td>
                        <td colspan="3">
                            @Html.TextAreaFor(model => model.ghiChu, new { @class = "form-control", @maxlenght = "100" })
                        </td>
                    </tr>
                </table>
            </div>
        </div>
        <div style="text-align: right; margin-bottom: 10px">
            <button class="btn btn-info" id="btnSubmit">Lưu </button>
            <button class="btn btn-info" type="button" id="btnTroVe">Trở về </button>
        </div>
    </fieldset>
</form>
