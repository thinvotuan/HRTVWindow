<form id="form-submit" method="post">
    <div style="width: 100%">
        <fieldset>
            <legend style="display: inline">Đăng ký người dùng</legend>
            <div id="error-message" class="form-error alert alert-danger" style="display: none">
                <strong>Đăng ký không thành công!</strong>
                <ul>
                </ul>
            </div>
            <div class="panel-body">
                <div>
                    <table class="table main-tbl">
                        <tr>
                            <td class="tdtitle">Nhân viên <span style="font-style: italic; float: right; color: red">*</span></td>
                            <td>
                                <div style="display: inline-flex; width: 100%;">
                                    @Html.HiddenFor(model => model.manv)
                                    <input type="text" class="form-control" required="required" name="nhanvien" id="nhanvien" />
                                    <div style="width: 125px; float: right">
                                        <button style="" type="button" class="btn btn-primary btn-sm btnNhanVien" id="btnNhanVien" data-toggle="modal" data-target="#myModalChonPhongBan">
                                            <span class="glyphicon glyphicon-th-list" aria-hidden="true"></span>&nbsp;Chọn nhân viên</button>
                                    </div>
                                    <span style="color: red; font-style: italic">@TempData["MaNhanVien"]</span>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="col-md-1 tdtitle">Tên đăng nhập <span style="font-style: italic; float: right; color: red">*</span>
                            </td>
                            <td id="ttlmauser" class="col-md-2">
                                @Html.TextBoxFor(model => model.userName, new { @class = "form-control", maxlength = "50", required = "required", @readonly = "readonly" })
                                <span style="color: red; font-style: italic">@TempData["TenDangNhap"]</span>
                            </td>
                        </tr>

                        @*<tr>
                            <td class="tdtitle">Mật khẩu <span style="font-style: italic; float: right; color: red">*</span></td>
                            <td>
                                @Html.PasswordFor(model => model.password, new { @class = "form-control", required = "required", maxlength = "200" })
                            </td>
                        </tr>
                        <tr>
                            <td class="tdtitle">Xác nhận mật khẩu <span style="font-style: italic; float: right; color: red">*</span>
                            </td>
                            <td>
                                <input type="password" class="form-control" required="required" name="xacnhanpass" id="xacnhanpass" maxlength="200" />
                            </td>
                        </tr>*@
                        <tr>
                            <td class="tdtitle">Email <span style="font-style: italic; float: right; color: red">*</span></td>
                            <td>
                                @Html.TextBoxFor(model => model.email, new { @class = "form-control", required = "required", @readonly = "readonly" })
                            </td>
                        </tr>
                        @*<tr>
                            <td class="tdtitle">Số điện thoại di động
                            </td>
                            <td>
                                @Html.TextBoxFor(model => model.telephone, new { @class = "form-control", @maxlength = "20" })
                            </td>
                        </tr>*@
                        <tr>
                            <td class="tdtitle">Trạng thái kích hoạt
                            </td>
                            <td>
                                @Html.CheckBox("status", ischecked, new { @class = "form-control" })
                            </td>
                        </tr>
                        <tr>
                            <td class="tdtitle">Ghi chú
                            </td>
                            <td>
                                @Html.TextAreaFor(model => model.note, new { @class = "form-control" })
                            </td>
                        </tr>
                    </table>
                </div>
                <div style="text-align: center">
                    <button type="button" id="btnTaoAccount" class="btn btn-info">Tạo account</button>
                    <button class="btn btn-info" type="button" id="btnTroVe">Trở về </button>
                </div>
            </div>
            <!-- Modal -->
            <div id="myModalChonPhongBan" class="modal fade" role="dialog">
                <div class="modal-dialog modal-lg">
                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-header">
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                            <h4 class="modal-title"></h4>
                        </div>
                        <div class="modal-body">
                            <div class="container" style="width: 98%">
                                <div class="row">
                                    <div id="filter-panel" class="filter-panel">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                        </div>
                    </div>

                </div>
            </div>

        </fieldset>
    </div>
</form>
