        $('.btnNhanVien').click(function () {
            var url = '@Url.Action("GetNhanVienInfo", "User")';
            $('#filter-panel .panel-default').load(url, function () {
                if ($('#filter-panel >:first').html().trim() == '') {
                    $('#filter-panel').toggleClass('in');
                }
            });
        })
        $(".btnNhanVien").click(function () {

            var Url = '/User/ChonNhanVien';
            $('#filter-panel').load(Url);
        });

        $("#myModal").on("hidden.bs.modal", function () {
