</script>
<form class="form-inline" id="form-submit" method="post">
<div>
    <div id="dialog" class="alert alert-info" style="display:none">
        <strong>Thông báo!</strong> Vui lòng chọn đối tượng để cập nhật.  
    </div>
    <div id="container">
        <fieldset  class="removeBorderFieldset">
           
            <div id="tabs" style="" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                    <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active"><a><span>
                       Danh sách mẫu in</span></a></li>
                </ul>
            </div>
            <div style="text-align: right;"  class="background_top">                
                <button class="btn btn-info btnThemeAdd" type="button" onclick="themMoi()">Thêm </button>                
            </div>
            <table class="table table-striped table-hover table-condensed" id="maintable">
                <thead>
                    <tr id="trtop">
                        <th>STT</th>
                        <th>Mã mẫu in</th>
                        <th>Tên mẫu in</th>                                                                 
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td  class="setSizeSTT">
                                @count
                            </td>
                            <td>@item.maMauIn</td>
                            <td>@item.tenMauIn</td>                                                                         
                            <td style="width:1px; white-space:nowrap">
                                <a style="color:#519ee5" href="@Url.Action("Edit", "PrintTemplate", new { id = item.id })">Sửa</a>
                                <a style="color:#ef6666" class="delEmail" id="@item.id">Xóa</a>
                            </td>
                        </tr>
                        count++;
                    }
                </tbody>
            </table>
        </fieldset>
    </div>
</div>
</form>