@using BatDongSan.Models.HeThong;
@model Sys_NhomUser
@{    
    ViewBag.Title = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";    
}
<script src="~/Scripts/jquery-2.1.4.min.js"></script>
<link rel="stylesheet" href="~/Content/bootstrap/css/bootstrap.min.css" />
<style>
    table
    {
        margin:0;
    }

    td
    {
        border: none;
    }    
</style>
<script>
    $(document).ready(function () {
        $("#btnTroVe").click(function () {
            var url = "@Url.Action("Index", "UserGroup")";
            location.href = url;
        })
    })
</script>
<form class="form-horizontal" method="post" style="width: 60%">
    <fieldset>
        <legend style="display: inline">Cập nhật thông tin nhóm</legend>
        <div class="collapse" style="display: block">
            <div class="panel panel-default">
                <table class="table table-striped table-hover table-condensed">
                    <tr>
                        <td>Mã nhóm người dùng        
                        </td>
                        <td style="color: red">
                            @Html.TextBoxFor(model => model.maNhomUser, new { @class = "form-control", @disabled = "disabled" })
                            @TempData["MessgId"]
                        </td>
                        <td style="text-align: right">Tên nhóm        
                        </td>
                        <td style="color: red">
                            @Html.TextBoxFor(model => model.tenNhomUser, new { @class = "form-control", @maxlenght = "100" })
                            @TempData["MessgTen"]
                        </td>
                    </tr>
                    <tr>
                        <td>Ghi chú
                        </td>
                        <td colspan="3">
                            @Html.TextAreaFor(model => model.ghiChu, new { @class = "form-control", @maxlenght = "100" })
                        </td>
                    </tr>
                </table>
            </div>
        </div>
        <div style="text-align: right; margin-bottom: 10px">
            <button class="btn btn-info" id="btnSubmit">Cập nhật </button>
            <button class="btn btn-info" type="button" id="btnTroVe">Trở về </button>
        </div>
    </fieldset>
</form>
