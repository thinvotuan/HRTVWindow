@using BatDongSan.Models.HeThong
@model IList<Sys_ThongBao>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int i = 1;
    var List = ViewBag.lsThongBao as List<sp_Sys_User_ThongBaoResult>;
}
<link rel="stylesheet" href="~/Content/batdongsan-alert.css" />
<script src="~/Scripts/batdongsan.generals.js"></script>
<script src="~/Scripts/autoNumeric.js"></script>
 
    <style>
    #content td
    {
        border-bottom: 1px inset #ADC2D6;
        position: relative;
        text-align: center;
    }

        ul.multi li:hover a
        {
            color:#04828F!important;
        }

        ul.multi li:hover i
        {
            color:#04828F!important;
            transform:scale(180deg);
        }


    .TieuDe
    {
        background: #04828F;
        padding: 5px;
        color: #fff;
        font-weight:bold;
    }
    .NoiDung
    {
padding: 5px;
    }
        .acTiveLink
        {
                color: #f95521 !important;
        }
       
</style>
<script type="text/javascript">
    $(document).ready(function () {
        $(".hideLightLink").click(function () {
           
           
            var index = $(".hideLightLink").index(this);
            $(".hideLightLink").eq(index).removeClass("activeLine");
        });

    });

    function ViewChiTiet(idThongBao, tenThongBao) {
        $(".tenTieuDe").html(tenThongBao);

        var url = "@Url.Action("GetThongTin", "QuanLyThongBao")" + "/" + idThongBao;
        $.ajax({
            url: url,
            type: "POST",
            dataType: "html",
            success: function (data) {
                $(".NoiDung").html(data);
            },
            error: function () {
                Alert.error(data, "Lỗi", { displayDuration: 2000 });
            }
        })
    }
</script>
<form id="form-submit">
    <div id="container">
        <fieldset class="removeBorderFieldset">
            

            <div id="content">
               
                <div class="boxTieuDeThongBao">
                    <div id="tabs" class="ui-tabs">
                <ul class="ui-tabs-nav">
                    <li class="ui-tabs-selected ui-state-active"><a><span>Danh sách thông báo</span></a></li>
                </ul>
            </div>
                <ul class="multi">
                    @foreach (var item in List)
                    {
                        // Check if chua xem =2 => HightLight.
                        var active ="";
                       if(item.trangThaiXem ==0)
                       {
                           active = "activeLine";  
                       }
                        <li class="@active hideLightLink">
                            <a  href="javascript:void(0)" style="color:#1749de;text-decoration:none;transition:all 300ms" onclick="ViewChiTiet('@item.id','@item.tenThongBao')" ><i class="fa fa-folder" aria-hidden="true" style="transition:all 300ms"></i> @item.tenThongBao</a>
                        </li>
                        
                        
                    }
                </ul>
                    </div>

                <div id="HienThiNoiDung" class="boxHienThiNoiDung">
                    <div class="TieuDe">
                        Tiêu đề: <span class="tenTieuDe">...</span>
                    </div>
                    <div class="NoiDung">

                    </div>
                    
                </div>
              
            </div>
        </fieldset>
    </div>
</form>
