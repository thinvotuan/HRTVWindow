@using BatDongSan.Models.HeThong;
@using BatDongSan.Controllers.HeThong;
@model Sys_CongViec
@{    
    ViewBag.Title = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var congViecs = ViewBag.CongViecs as List<Sys_CongViec>;
    var vuViecs = ViewBag.VuViecs as List<Sys_VuViec>;
    bool ischecked = false;
}
<link rel="stylesheet" href="~/Content/bootstrap-switch/bootstrap3/bootstrap-switch.min.css" />
<script src="~/Scripts/jquery-2.1.4.min.js"></script>
<script src="~/Scripts/bootstrap-switch.min.js"></script>
<script src="~/Scripts/jquery.validate.min.js" type="text/javascript"></script>
<script src="~/Scripts/additional-methods.min.js" type="text/javascript"></script>
<script src="~/Scripts/autoNumeric.js"></script>
<script src="~/Scripts/batdongsan.validate.js"></script>

<style>
    .dropdown-menu
    {
        left: 80%;
        text-align: center;
        transform: translate(-50%, 0);
    }

    td
    {
        border: none !important;
    }
</style>
<script>
    $(document).ready(function () {
        $("#onmenu").attr("data-size", "mini").bootstrapSwitch();

        $("#macongviec").keypress(function (e) {
            if (e.keyCode == 32) {
                return false;
            }
        });

        $(".numberinput").autoNumeric('init', { mDec: 0, lZero: 'deny', aSep: ',', aDec: '.', pSign: 's', vMin: '0', vMax: '20' });

        $("#btnTroVe").click(function () {
            location.href = "@Url.Action("Index", "CongViec")";
        });
        $(document).on("click", "#chonIcon", function () {

            url = "@Url.Action("ListIcons/", "CongViec")";
            $("#listAllIcon").load(url);
        });
    });
</script>
@using (Html.BeginForm("Create", "CongViec", FormMethod.Post, new { id = "form-submit" }))
{
    <div class="dropdown">
        <fieldset class="removeBorderFieldset">
            <div id="tabs" class="ui-tabs">
                <ul class="ui-tabs-nav">
                    <li class="ui-tabs-selected ui-state-active"><a><span>Thêm mới công việc</span></a></li>
                </ul>
            </div>
            <table class="table">
                <tr>
                    <td class="col-sm-5">
                        <div>
                            <table class="table">
                                <tr>
                                    <td  class="tdtitle">Mã công việc        
                                    </td>
                                    <td style="color: red" id="ttlmacongviec">
                                        <input type="hidden" id="maIcon" name="maIcon" />
                                        @Html.TextBoxFor(model => model.maCongViec, new { @class = "form-control", required = "required", maxlength = "20" })
                                        @TempData["Mssg"]
                                    </td>
                                </tr>
                                <tr>
                                    <td class="tdtitle">Tên công việc</td>
                                    <td>
                                        @Html.TextBoxFor(model => model.tenCongViec, new { @class = "form-control", required = "required", maxlength = "100" })
                                    </td>
                                </tr>
                                <tr>
                                    <td class="tdtitle">Tên controller        
                                    </td>
                                    <td>
                                        @Html.TextBoxFor(model => model.tenController, new { @class = "form-control", required = "required", @placeholder = "VD: Hệ thống => HeThong", maxlength = "50" })
                                    </td>
                                </tr>
                                <tr>
                                    <td class="tdtitle">Tên action</td>
                                    <td>
                                        @Html.TextBoxFor(model => model.tenAction, new { @class = "form-control", @placeholder = "Ví dụ: Index, Create, Details", maxlength = "50" })
                                    </td>
                                </tr>
                                <tr>
                                    <td class="tdtitle">Công việc cha
                                    </td>
                                    <td>
                                        @Html.DropDownListFor(model => model.maCha, ViewBag.CongViecs as SelectList, new { @class = "form-control" })
                                    </td>
                                </tr>
                                <tr>
                                    <td class="tdtitle">Hiển thị trên menu
                                    </td>
                                    <td>
                                        @Html.CheckBox("onmenu", ischecked, new { @class = "form-control" })
                                    </td>
                                </tr>
                                <tr>
                                    <td class="tdtitle">Chọn Icon
                                    </td>
                                    <td>
                                        <div class="popup" style="float: left">
                                            <!-- Button trigger modal -->
                                            <button type="button" class="btn btn-primary btn-lg" data-toggle="modal" data-target="#myModal" id="chonIcon">
                                                Chọn Icon
                                            </button>

                                            <!-- Modal -->
                                            <div class="modal fade" id="myModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel">
                                                <div class="modal-dialog modal-lg" role="document">
                                                    <div class="modal-content">
                                                        <div class="modal-header">
                                                            <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                                                            <h4 class="modal-title" id="myModalLabel">List Icon</h4>
                                                        </div>



                                                        <div class="modal-body" id="listAllIcon">
                                                            
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            </div>
                                            <div class="xemtruoc" style="float: right; margin-right: 10px;">
                                            </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="tdtitle">Độ ưu tiên
                                    </td>
                                    <td>
                                        @Html.TextBoxFor(model => model.doUuTien, new { @class = "form-control numberinput", style = "width:50px" })
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </td>
                    <td class="col-sm-5" style="vertical-align: top!important">
                        <div id="container">
                            <table class="table" id="tblvuviec" style="border: 1px inset #d7d1d1">
                                <tr>
                                    <th>Mã quyền hạn
                                    </th>
                                    <th>Loại quyền hạn
                                    </th>
                                    <th id="estrath"></th>
                                </tr>
                                @foreach (var vuviec in vuViecs)
                                {                                
                                    <tr>
                                        <td  class="tdtitle">
                                            @vuviec.maVuViec
                                        </td>
                                        <td>
                                            @vuviec.tenVuViec
                                        </td>
                                        <td>
                                            <input name="maVuViecs" type="checkbox" class="styled" value="@vuviec.maVuViec">
                                        </td>
                                    </tr>                                                                     
                                }
                            </table>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td colspan="3" style="text-align: right;">
                        <button class="btn btn-info" id="btnSubmit">Lưu </button>
                        <button class="btn btn-info" type="button" id="btnTroVe">Trở về </button>
                    </td>
                </tr>
            </table>
        </fieldset>
    </div>
}
