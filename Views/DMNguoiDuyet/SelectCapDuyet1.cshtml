@{
    Layout = "~/Views/Shared/_Popup.cshtml";
}
<style>
    #container #maintable td, #container #maintable th
    {
        border: none;
        border-bottom: 1px inset #ADC2D6;
        position: relative;
        border-right: 1px solid rgba(173, 194, 214, 0.4);
    }

    #container #maintable
    {
        border-top: 1px inset #ADC2D6;
        border-left: 1px solid rgba(173, 194, 214, 0.4);
    }

    td
    {
        border: none;
    }

    .checkMacDinh
    {
        color: #AAAAAA;
        display: block;
        position: relative;
        float: none;
        text-align: center;
        margin: 0px auto;
        height: 100%;
        width: 100%;
    }

        .checkMacDinh input[type=radio]
        {
            position: absolute;
            visibility: hidden;
        }

        .checkMacDinh label
        {
            display: block;
            position: relative;
            font-weight: 300;
            font-size: 1.35em;
            padding: 10px 0px 10px 0px;
            margin: 10px auto;
            z-index: 9;
            cursor: pointer;
            -webkit-transition: all 0.25s linear;
        }

        .checkMacDinh:hover label
        {
            color: red;
        }

        .checkMacDinh .check
        {
            display: block;
            position: absolute;
            border: 5px solid #1a9dcc;
            border-radius: 100%;
            height: 20px;
            width: 20px;
            top: 0px;
            left: 28%;
            right: 28%;
            z-index: 5;
            transition: border .25s linear;
            -webkit-transition: border .25s linear;
        }

        .checkMacDinh:hover .check
        {
            border: 5px solid #bf5a5a;
        }

    .check::before
    {
        display: block;
        position: absolute;
        content: '';
        border-radius: 100%;
        height: 10px;
        width: 10px;
        top: 0px;
        left: 0px;
        margin: auto;
        transition: background 0.25s linear;
        -webkit-transition: background 0.25s linear;
    }

    input[type=radio]:checked ~ .check
    {
        border: 5px solid #0DFF92;
    }

        input[type=radio]:checked ~ .check::before
        {
            background: #ff0000;
        }

    input[type=radio]:checked ~ label
    {
        color: #0DFF92;
    }

    .activeRadio
    {
        background-color: #f5264c;
    }

    .content-wrapper
    {
        overflow: hidden;
    }
</style>
<script type="text/javascript">
    $(document).ready(function () {
        var obj = window.opener;
        $("#btnGoiDuyet").click(function () {
            if (window.confirm('Bạn có chắc chắn chọn người duyệt này ko?')) {
                $("#btnGoiDuyet").replaceWith("Đang xử lý...");
                $(".pageLoading").show();
                $.post('@Url.Action("DuyeTheoQuiTrinhDong", "DMNguoiDuyet")', { lyDo: $('#lyDo').val(), maNhanVien: $('input:radio[name=rdb]:checked').val(), url: $("#url").val(), maPhieu: $('#maPhieu').val(), soNgayNghiPhep: $('#soNgayNghiPhep').val(), maCongViec: $('#maCongViec').val(), tenNhanVien: $('#tenNhanVien').val(), idQuiTrinh: $('input:radio[name=quiTrinhDuyet]:checked').val(), sendMail: document.getElementById('email').checked, sendSMS: document.getElementById('sms').checked }, function (data) {
                    if (data.length == 0) {
                        window.close();
                        obj.LoadLaiTrangChiTiet();
                    }
                    else {
                        alert(data);
                        $(this).attr("disabled", false);
                    }
                });
            }
        });
    });
</script>
@{    
    var ds = ViewBag.DSNhanVienDuyet as List<BatDongSan.Models.NhanSu.NhanVienModel>;
    var quiTrinhDuyet = ViewData["lisQuiTrinhDuyet"] as List<BatDongSan.Models.HeThong.sp_QuiTrinhDuyetASResult>;
}
<div id="container">
    <fieldset class="removeBorderFieldset">
        <div id="tabs" style="height: auto; border: none; float: left; box-sizing: border-box; overflow: hidden; clear: none;" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
            <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active ">
                    <a><i class="fa fa-yelp" aria-hidden="true"></i>Danh mục quy trình duyệt</a></li>
            </ul>
        </div>
        <form name="form" action="" method="post">
            <input type="hidden" id="maPhieu" value="@ViewData["maPhieu"]" />
            <input type="hidden" id="maCongViec" value="@ViewData["maCongViec"]" />
            <input type="hidden" id="trangThai" value="@ViewData["trangThai"]" />
            <input type="hidden" id="soNgayNghiPhep" value="@ViewData["soNgayNghiPhep"]" />
            <input type="hidden" id="tenNhanVien" value="@ViewData["tenNhanVien"]" />
            <input type="hidden" id="lyDo" value="@ViewData["lyDo"]" />
            <input type="hidden" id="maNV" />
            <input type="hidden" id="idQuiTrinh" value="@ViewBag.IdQuiTrinh"/>
            <input type="hidden" id="checkQuyTrinhDuyet" />
            <input type="hidden" id="url" value="@ViewBag.URL" />
            <table style="width: 100%; font-family: Tahoma;" cellpadding="2" cellspacing="0"
                border="0">
                <tr>
                    <td style="font-size: 25px; text-align: center;" colspan="2"></td>
                </tr>

                <tr style="text-align: center">
                    <td colspan="2">Send Email:<input type="checkbox"  id="email" />
                        &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Send SMS:<input type="checkbox" id="sms" />

                    </td>
                </tr>

                <tr>
                    <td colspan="2">
                        <table id="maintable" class="table">
                            <tbody>
                                @{
                                    int count1 = 0;
                                    if ((string)ViewBag.Duyet1Cap == "true")
                                    {
                                        int idDuyet1Cap = (int)ViewBag.MaID1Cap;
                                        if (quiTrinhDuyet != null && quiTrinhDuyet.Count > 0)
                                        {
                                            foreach (var it in quiTrinhDuyet.Where(d => d.Id == idDuyet1Cap))
                                            {
                                                count1++;
                                    <tr>
                                        <td>
                                            <span style="color: #0000FF">
                                                @it.TenQuiTrinh: </span>&nbsp;&nbsp                                         
                                            @Html.Raw(it.chuoiBuocDuyet)
                                        </td>
                                        <td style="width: 50px; text-align: center">
                                            <div class="checkMacDinh">
                                                <input type="radio" name="quiTrinhDuyet" value="@it.Id" checked="checked">
                                                <label for="@(it.Id)-option"></label>
                                                <div class="check activeRadio"></div>
                                            </div>

                                        </td>
                                    </tr>
                                            }
                                        }
                                    }
                                    else
                                    {
                                        int idDuyet2Cap = (int)ViewBag.MaID2Cap;
                                        if (quiTrinhDuyet != null && quiTrinhDuyet.Count > 0)
                                        {
                                            foreach (var it in quiTrinhDuyet.Where(d => d.Id == idDuyet2Cap))
                                            {
                                                count1++;
                                    <tr>
                                        <td>
                                            <span style="color: #0000FF">
                                                @it.TenQuiTrinh: </span>&nbsp;&nbsp                                         
                                            @Html.Raw(it.chuoiBuocDuyet)
                                        </td>
                                        <td style="width: 50px; text-align: center">
                                            <div class="checkMacDinh">
                                                @if (count1 == 1)
                                                {
                                                    <input type="radio" name="quiTrinhDuyet" value="@it.Id" checked="checked">
                                                }
                                                else
                                                {
                                                    <input type="radio" name="quiTrinhDuyet" value="@it.Id">
                                                }
                                                <label for="@(it.Id)-option"></label>
                                                <div class="check activeRadio"></div>
                                            </div>
                                        </td>
                                    </tr>
                                            }
                                        }
                                    }
                                }
                            </tbody>
                        </table>
                    </td>
                </tr>
                <tr>
                    <td colspan="2">
                        <div>
                            <table id="maintable" class="table">
                                <thead>
                                    <tr>
                                        <th style="text-align: center">STT
                                        </th>
                                        <th style="text-align: center">Mã nhân viên
                                        </th>
                                        <th style="text-align: center">Tên nhân viên
                                        </th>
                                        <th style="text-align: center">Tên phòng ban
                                        </th>
                                        <th style="width: 30px">&nbsp;
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        int count = 0;
                                        if (ds != null && ds.Count > 0)
                                        {
                                            foreach (var item in ds)
                                            {
                                                count++;
                                        <tr>
                                            <td style="text-align: center">@count</td>
                                            <td style="text-align: center">@item.maNhanVien</td>
                                            <td style="text-align: center">@item.hoVaTen</td>
                                            <td style="text-align: center">@item.tenPhongBan</td>
                                            <td style="text-align: center" data-label="">
                                                @if (count == 1)
                                                {
                                                    <input type="radio" name="rdb" value="@item.maNhanVien" checked="checked" />
                                                }
                                                else
                                                {
                                                    <input type="radio" name="rdb" value="@item.maNhanVien"/>
                                                }
                                            </td>
                                        </tr>
                                            }
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td align="center" style="padding: 7px 0;" colspan="2">
                        <input type="button" class="btn btn-info" value="Gửi duyệt" id="btnGoiDuyet" />
                        <input type="button" class="btn btn-info" value="Đóng" onclick="window.close()" />
                    </td>
                </tr>
            </table>
        </form>
    </fieldset>

</div>
