    <script>
        //Set Time
        //var startTime = 2100;    //  Sau 35p, Time, tính bằng giây 1 = 1s
        var startTime = 300; // 5 phut request 1 lan
        var s = startTime;
        var countTime = 0;
        var status = false;

        var timeout = null; // Timeout
        function start() {

            if (s == -1) {




                $.ajax({
                    type: "POST",
                    url: '/Home/CheckSession/',
                    data: {

                    },
                    success: function (result) {

                        if (result) {


                            s = startTime;
                            // Reset Time
                            countTime = 0;
                            clearTimeout(timeout);
                            start();
                        }
                        else {
                            window.location = '/Home/Index';
                        }
                    }
                });



            }
            else {
                timeout = setTimeout(function () {
                    s--;
                    start();
                }, 1000);
            }
        }

        function doSetTimeout(i) {
            setTimeout(function () { alert(i); }, 1000);
        }
        start();

        //End Set Time

        function ViewDetailHistoryLayout(soPhieu, maQuiTrinh) {
            var url = '/DMNguoiDuyet/LichSuDuyetPhieu/' + soPhieu + '?maQuiTrinh=' + maQuiTrinh;
            PopUpManagerLayout(url, "DUYET", 900, 250);
        }

        function PopUpManagerLayout(url, title, w, h) {
            var left = (screen.width / 2) - (w / 2);
            var top = (screen.height / 2) - (h / 2);
            var targetWin = window.open(url, title, 'width=' + w + ', height=' + h + ', top=' + top + ', left=' + left);
        }

    </script>
