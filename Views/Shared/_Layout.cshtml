    @RenderSection("scripts", required: false)
    @*@Scripts.Render("~/bundles/jquery")*@
    <script type="text/javascript">


        $(document).ready(function () {
            $(document).on("click", "ul.pagination li", function () {
                $('body,html').animate({
                    scrollTop: 0
                }, 0);
            });

            // end GH
            $(".box-cd .content_chude div").click(function () {
                var index = $(".box-cd .content_chude div").index(this);
                var url = window.location.href;
                var valClass = $(".box-cd .content_chude div").eq(index).attr("class");

                arrColor = valClass.split(" ");

                // setTimeout(function() {

                window.location = '/Home/changeTheme?maMau=' + arrColor[0] + '&tenMau=' + arrColor[1] + '&positionVal=' + arrColor[2] + '&url=' + url;
                //  },);
            });
            //HOtline
            $('#HotLineSupport').click(function () {
                $("#ShowHotLine").fadeIn(200);
            }).mouseleave(function () {
                $("#ShowHotLine").fadeOut(200);
            });
            //End hotLine
            // Set Download
            $(".box-cd").hide();
            $('.txt-download').click(function () {
                $(".box-download").fadeIn(200);
            }).mouseleave(function () {
                $(".box-download").fadeOut(200);
            });

            // End download
            // Set Chu De
            $(".box-cd").hide();
            $('.txt-cd').click(function () {
                $(".box-cd").fadeIn(200);
            }).mouseleave(function () {
                $(".box-cd").fadeOut(200);
            });

            //End Chu De
            $('#menu li.responsive > a').click(function () {
                $('li.responsive').removeClass('active');
                $(this).parent().addClass('active');
            });

            $(".mo-rong").click(function () {
                $("#res-menu").toggleClass("show-res");
            });
            $("#inForHover").click(function () {
                $("#popUpUser").toggleClass("addHeightWidth");
                $(".gb_u").toggle();
            });
            $('#ToBackTop').hide();
            $(window).scroll(function () {
                if ($(this).scrollTop() > 100) {
                    $('#ToBackTop').fadeIn();
                } else {
                    $('#ToBackTop').fadeOut();
                }
            });
            $('#ToBackTop').click(function () {
                $('body,html').animate({
                    scrollTop: 0
                }, 500);
                return false;
            });
            //Setting
            $(".iconSetting").click(function () {
                $(".contentSetting").slideToggle();
            });
            // End setting

        });


    </script>
    <link rel="stylesheet" href="~/Content/mobile.css" type="text/css" />
    <script>
        (function ($) {
            var ico = $('<i class="fa fa-caret-right"></i>');
            $('nav#menuMobile li:has(ul) > a').append(ico);
            $('nav#menuMobile li:has(ul)').addClass('parentMenuID');
            $('nav#menuMobile li li:has(ul)').addClass('parentMenu').removeClass('parentMenuID');
            $('.parentMenu').on('click', function () {
                var clsMenuParent = $(this).parent().parent().attr('id');
                var idclsMenuParent = "#" + clsMenuParent;

                if ($(this).hasClass('open')) {


                    $(this).removeClass('open');
                }
                else {
                    $(this).addClass('open');

                }
            });
            $('.parentMenuID a').on('click', function () {
                var clsMenuParent = $(this).parent().attr('id');
                var idclsMenuParent = "#" + clsMenuParent;
                if ($(idclsMenuParent).hasClass('open')) {
                    $(idclsMenuParent).removeClass('open');
                }
                else {
                    $(idclsMenuParent).addClass('open');
                }
            });

            $('a#toggle').on('click', function (e) {
                $('html').toggleClass('open-menu');
                return false;
            });


            $('div#overlay').on('click', function () {
                $('html').removeClass('open-menu');
            })
            // Get height
            var heightWD = $(document).height();

            $(".main-content").css("min-height", heightWD);
        })(jQuery)

    </script>

    <div id="ToBackTop" class="hvr-icon-bob">
        <i class="fa fa-chevron-up"></i>
    </div>

</body>
