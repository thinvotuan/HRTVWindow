<nav class="navbar-default setwrapper" id="nav">
    <div>
        <ul id="menu">
            @if (Session["CongViecUser"] != null)
            {
                IList<sp_Sys_CongViecCuaUsersResult> congViecs = Session["CongViecUser"] as IList<sp_Sys_CongViecCuaUsersResult>;
                IList<sp_Sys_CongViecCuaUsersResult> congViecOfUser = congViecs.Where(s => String.IsNullOrEmpty(s.maCha)).ToList();
                foreach (var root in congViecOfUser.OrderBy(o => o.doUuTien))
                {
                    if (congViecs.Where(s => s.maCha == root.maCongViec).Count() > 0)
                    {
                <li class="parent" data-priority="@root.doUuTien"><i class="@root.maIcon iconParent"></i><a href="#">@Html.Raw(root.tenCongViec)</a>
                    @*@Html.ActionLink(root.tenCongViec, "Index", "")*@
                    @Html.Raw(MenuHelper.BuildMenu(congViecs, root.maCongViec).ToString())
                </li> 
                    }
                }
            }
        </ul>
    </div>
</nav>
