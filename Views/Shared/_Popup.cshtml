    <style>
        
       
        #nav, ul#menu,ul#menu li.parent,p.MK,div.help, div.logout, #container th,.btnMenuMobile, .hvr-underline-from-center:before
        {
           background-color: #@Session["maMau"] !important;
            color: #fff;
    font-size: 14px;
    font-weight: normal;
        }
        #wrapper.btn, #wrapper.btn{
         background-color: #@Session["maMau"] !important;
        }
