        string positionVal = (string)Session["positionVal"];


        positionVal = "-168px";
        tenMau = "colorTheme";
        if (tenMau == "colorTheme")
        {
        <style>
     input[value="Tìm kiếm"], input[value="Search"], button[value="Tìm kiếm"], button[value="Search"],input[value="Tìm"], button[value="Tìm"],input[id="btnSearch"],
     input[value="Thêm"],button[value="Thêm"], input[value="Sửa"], button[value="Sửa"],
     input[value="Xóa"], button[value="Xóa"], input[value="Gửi duyệt"], button[value="Gửi duyệt"],.btnPrint, #btnPrint, 
     input[value="Thêm dòng"],button[value="Thêm dòng"], input[value="Lưu"], button[value="Lưu"],
     input[value="In"],button[value="In"],input[value="Print"],button[value="Print"],input[value="Print View"],
     button[value="Print View"],input[value="Trở về"], button[value="Trở về"], input[value="Thêm file"], button[value="Thêm file"],input[value="Import file"], button[value="Import file"], 
     input[value="Xuất File"], button[value="Xuất File"],input[value="Xuất file"], button[value="Xuất file"],input[value="Export file"], button[value="Export file"],input[value="Xuất Excel"], button[value="Xuất Excel"],#btnTroVe,#btnSubmit,.btnDelete,#btnDelete,.btnUpdate,#btnUpdate,.btnThemeAdd,#btnThem,.btnThemeAddFile,.btnTroVe,.btnThemeSave,.btnUpdate,input[value="Gửi duyệt"], button[value="Gửi duyệt"]
    {
        background-position: 0px @positionVal !important;
        border: 1px solid #fff !important;
    }
    
</style>

        }
    }
    <!-- End Icon -->

</head>

<body class="wrapper_Popup">
    @* class="container-fluid" *@
    <div id="wrapper">
        <div class="pageLoading" style="display: none">
            <img src="/Content/images/loadingPage.gif" />
        </div>
        @RenderSection("featured", required: false)
        <section class="content-wrapper main-content clear-fix" style="padding-top: 10px">
            @RenderBody()
        </section>

    </div>
    @RenderSection("scripts", required: false)
    @*@Scripts.Render("~/bundles/jquery")*@
    <script type="text/javascript">
        $(document).ready(function () {
            $(".box-cd .content_chude div").click(function () {
                var index = $(".box-cd .content_chude div").index(this);
                var url = window.location.href;
                var valClass = $(".box-cd .content_chude div").eq(index).attr("class");

                arrColor = valClass.split(" ");

                // setTimeout(function() {

                window.location = '/Home/changeTheme?maMau=' + arrColor[0] + '&tenMau=' + arrColor[1] + '&positionVal=' + arrColor[2] + '&url=' + url;
                //  },);
            });
            //HOtline
            $('#HotLineSupport').click(function () {
                $("#ShowHotLine").fadeIn(200);
            }).mouseleave(function () {
                $("#ShowHotLine").fadeOut(200);
            });
            //End hotLine
            // Set Download
            $(".box-cd").hide();
            $('.txt-download').click(function () {
                $(".box-download").fadeIn(200);
            }).mouseleave(function () {
                $(".box-download").fadeOut(200);
            });

            // End download
            // Set Chu De
            $(".box-cd").hide();
            $('.txt-cd').click(function () {
                $(".box-cd").fadeIn(200);
            }).mouseleave(function () {
                $(".box-cd").fadeOut(200);
            });

            //End Chu De
            $('#menu li.responsive > a').click(function () {
                $('li.responsive').removeClass('active');
                $(this).parent().addClass('active');
            });

            $(".mo-rong").click(function () {
                $("#res-menu").toggleClass("show-res");
            });
            $("#inForHover").click(function () {
                $("#popUpUser").toggle();
                $(".gb_u").toggle();
            });

        });
    </script>
    <link rel="stylesheet" href="~/Content/mobile.css" type="text/css" />
    <script src="~/Scripts/scriptbreaker-multiple-accordion-1.js" type="text/javascript"></script>
    <script>
        $(document).ready(function () {
            //Begin Menu
            $(".topnav").accordion({
                accordion: false,
                speed: 500,
                closedSign: '<i class="fa fa-plus-circle"></i>',
                openedSign: '<i class="fa fa-minus"></i>'
            });
            $(".btnMenuMobile").click(function () {

                $("ul.topnav").slideToggle().toggleClass("fullWidthMenu");
                if ($(".btnMenuMobile i").hasClass("fa-bars")) {
                    $(".btnMenuMobile i").removeClass("fa-bars").addClass("fa-times");
                }
                else {
                    $(".btnMenuMobile i").removeClass("fa-times").addClass("fa-bars");
                }
                if ($(".Menumobile").hasClass("addWidth")) {
                    $(".Menumobile").removeClass("addWidth");
                    $("ul.topnav ul").hide();
                    $("ul.topnav i").removeClass("fa-minus").addClass("fa-plus-circle");
                }
                else {
                    $(".Menumobile").addClass("addWidth");
                }
                if ($(".btnMenuMobile").hasClass("removeBorder")) {
                    $(".btnMenuMobile").removeClass("removeBorder");
                }
                else {

                    $(".btnMenuMobile").addClass("removeBorder");
                }


            });

            //End Menu
        }
        );
    </script>
</body>
</html>
