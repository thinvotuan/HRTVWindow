<script src="~/Scripts/autoNumeric.js"></script>
<link rel="stylesheet" href="~/Content/bootstrap-switch/bootstrap3/bootstrap-switch.min.css" />
<script src="~/Scripts/bootstrap-switch.min.js"></script>
<script src="~/Scripts/bootstrap-datetimepicker.min.js"></script>
<link rel="stylesheet" href="~/Content/bootstrap-datetimepicker.min.css" />

<style>
    #content td {
        border-bottom: 1px inset #ADC2D6;
        position: relative;
    }

    .avatar {
        background-size: 15px;
        width: 50px;
        height: 50px;
        object-fit: cover;
    }

    .modal-body {
        overflow-y: auto;
        max-height: 600px;
        width: 100%;
    }
</style>
<style>
    .pageActive, .pageCurrent:hover, .pageNext:hover, .pageLast:hover, .pageFirst:hover, .pagePrevious:hover {
        padding: 7px 11px;
        background-color: #4D8AFF;
        color: #FFFFFF;
        display: inline-block;
        border: 1px solid #80ABFF;
        border-radius: 20px;
        text-decoration: none;
        font-weight: bold;
    }

    .pageCurrent, .pageNext, .pageLast, .pageFirst, .pagePrevious {
        padding: 7px 11px;
        background-color: #fff;
        display: inline-block;
        border: 1px solid #80ABFF;
        border-radius: 20px;
        font-weight: bold;
    }
</style>
<script type="text/javascript">
    $(document).ready(function () {
        $(".datepicker").datetimepicker({
            locale: 'vi',
            format: 'DD/MM/YYYY'
        });
        ToMonth();
        //OnCriteria(1);
        $("#btnTimKiem").click(function () {
            OnCriteria(1);
        });

        $("#maCuaHang").change(function () {
            OnCriteria(1);
        });
