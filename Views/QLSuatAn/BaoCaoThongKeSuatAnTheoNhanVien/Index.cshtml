        //                type: 'POST',
        //                dateType: 'json',
        //                data: fd,
        //                cache: false,
        //                contentType: false,
        //                processData: false,
        //                success: function (data) {
        //                    if (data.success == true) {
        //                        $('#btnSearch').click();
        //                        Alert.success(data.message, "Thông báo", { displayDuration: 2000 });

        //                        $("#fileImport").val("");

        //                    } else {
        //                        console.log(data);
        //                        Alert.warning(data.message, "Thông báo", { displayDuration: 0 });
        //                    }
        //                },
        //                error: function (request, textStatus, errorThrown) {
        //                    Alert.error("Lưu không thành công", "Thông báo", { displayDuration: 0 });
        //                }
        //            })
        //        }
        //    });
        //});

        $("#btnXuatFile").click(function () {
            var url = "@Url.Action("XuatFileNhanVien", "BaoCaoThongKeSuatAnTheoNhanVien")";
            window.location.href = url;
        });
    });


    function beginPaging(args) {
        // Animate        
        $('#content').fadeOut('fast');
    }
    function successPaging() {
        $('#content').fadeIn('fast');
    }


    function OnCriteria(page) {
        var giatri = $("#searchString").val().replace(/ /gi, '+');

        var url = '@Url.Action("Index", "BaoCaoThongKeSuatAnTheoNhanVien")'
                            + "?maCuaHang=" + $("#maCuaHang").val()
                            + "&tuNgay=" + $("#tuNgay").val()
                            + "&denNgay=" + $("#denNgay").val()
                            + "&qSearch=" + giatri
                            + "&_page=" + page;

        var imageUrl = '<div id="divMsg" align="center"><img src="@Url.Content("~/Content/Images/loading.gif")"/></div>';

        $('#content').html(imageUrl);
        $('#content').load(url);
    }
    function enterToSeacrh(event) {
        if (event.keyCode == 13)
            $("#btnTimKiem").click();
    }

    function ToWeek() {
        $("#denNgay").data("DateTimePicker").date(moment());
        $("#tuNgay").data("DateTimePicker").date(moment().subtract(7, "day"));
    }
    function ToMonth() {
        $("#denNgay").data("DateTimePicker").date(moment());
        $("#tuNgay").data("DateTimePicker").date(moment().subtract(1, "month"));
    }
</script>



<form id="form-listview">
    <div id="container">
        <fieldset class="removeBorderFieldset">
            <div id="tabs" style="" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                    <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active"><a><span>Danh sách phiếu công tác</span></a></li>
                </ul>
            </div>
            <div id="filter-panel" class="collapse filter-panel" style="display: block; position: relative">
                <div class="panel panel-default background_top">
                    <div class="panel-body">
                        <div style="line-height: 28px; float:left;">
                            <input type="text" id="tuNgay" class="form-control datepicker" placeholder="Từ ngày" style="width: 80px; float: left; margin-right: 5px" />
                            <input type="text" id="denNgay" class="form-control datepicker" placeholder="Đến ngày" style="width: 80px; float: left; margin-right: 5px" />
                            <div style="float: left">
                                <a href="javascript:void(0)" onclick="ToWeek()"><i class="fa fa-calendar" aria-hidden="true"></i>7 ngày</a> <a href="javascript:void(0)" onclick="ToMonth()"><i class="fa fa-calendar" aria-hidden="true"></i>30 ngày</a>
                            </div>
                            <div style="float: right; margin-left: 5px" class="clrFullMobile">
                                <span style="float: left">Cửa hàng:</span> @Html.DropDownList("maCuaHang", ViewBag.CuaHangs as SelectList, new { @class = "form-control", @style = "float:left;width:150px" })
                            </div>

                        </div>
                        <div style="display: inline-flex; width: 350px; float:right;" class="clrFullMobile">
                            <input type="text" class="form-control input-sm" style="width: 100%" id="searchString" value="" placeholder="Nhập giá trị tìm kiếm" onkeypress="enterToSeacrh(event)">
                            <div style="float: right">
                                <button id="btnTimKiem" type="button" class="btn btn-primary btn-sm" style="border: 1px double; margin-left: 5px">
                                    <span class="glyphicon glyphicon-search"></span>Tìm kiếm
                                </button>

                            </div>
                            <button id="btnXuatFile" type="button" class="btn btn-primary btn-sm" style="border: 1px double; margin-left: 5px">
                                Xuất file
                            </button>
                        </div>

                    </div>
                </div>
            </div>
            <div>
                <table class="table table-striped table-hover table-condensed TableMobile IndexPhanQuyenMobile" id="maintable">
                    <thead>
                        <tr>
                            <th style="text-align: center; width: 30px">STT</th>
                            <th style="width: 100px;">Mã nhân viên</th>
                            <th style="width: 150px;">Tên nhân viên</th>
                            <th style="width: 200px;">Tên phòng ban</th>
                            <th style="width: 50px;">Công chuẩn</th>
                            <th style="width: 50px;">Số phiếu đăng ký</th>
                        </tr>
                    </thead>
                    <tbody id="content">
                        @{Html.RenderPartial("ViewIndex");}
                    </tbody>
                </table>

            </div>


        </fieldset>
    </div>
</form>
