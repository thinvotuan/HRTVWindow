                <h4 class="modal-title">Danh sách cửa hàng</h4>
                <div class="groupbtnChon" style="float: right; overflow: hidden; clear: both;">
                    <button class="btn btn-primary btnChonCH btn-sm" type="button"><i class="fa fa-save"></i>Chọn</button>

                </div>
            </div>
            <div class="modal-body">

                <div class="container" style="width: 100%">
                    <div class="row">
                        <div id="custom-panel" class="filter-panel clsLoadDanhSachCuaHang">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary btnChonCH btn-sm" type="button"><i class="fa fa-save"></i>Chọn</button>
                    <button type="button" class="btn btn-default" data-dismiss="modal" id="btnCloseEmail">Đóng</button>
                </div>
            </div>
        </div>
    </div>
</div>
