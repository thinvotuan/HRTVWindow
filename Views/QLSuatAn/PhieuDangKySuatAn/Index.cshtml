<script type="text/javascript">
    $().ready(function () {
        $(".datepicker").datetimepicker({
            locale: 'vi',
            format: 'DD/MM/YYYY'
        });
        $(".tabToggle").click(function () {
            $(".tabToggle").removeClass("ui-tabs-selected ui-state-active activeColorTab");
            $(".contentToggle").hide(300);
            var index = $(".tabToggle").index(this);
            $(".tabToggle").eq(index).addClass("ui-tabs-selected ui-state-active activeColorTab");
            $(".contentToggle").eq(index).show(300);
        });
        $('#btnSearch').click(function () {
            listFilter();
        });
        $(document).on("change", "select", function () {
            listFilter(this)
        });


        $("#btnModalCreate").click(function () {
            var url = "@Url.Action("Create", "PhieuDangKySuatAn")";
            location.href = url;
            @* var url = "@Url.Action("Create", "PhieuDangKySuatAn")";
             var form = document.getElementById("form-submit");
             form.action = url;
             $("#custom-panel").load(url)*@
        })
        $(document).on("click", ".btnEdit", function () {
            var url = "@Url.Action("Edit", "PhieuDangKySuatAn")" + "/" + $(this).attr("alt");
            location.href = url;
            //var form = document.getElementById("form-submit");
            //form.action = url;
            //$("#custom-panel").load(url);
        })

        $(document).on("click", ".btnDelete", function () {
            var url = "@Url.Action("Delete", "PhieuDangKySuatAn")" + "/" + $(this).attr("alt");
            bootbox.confirm("Bạn có muốn xóa không", function (result) {
                if (result) {
                    var form = document.getElementById("form-listview");
                    form.method = "post";
                    form.action = url;
                    form.submit();
                }
            });
        });
        $("#btnPrint").click(function () {
            var url = "@Url.Action("PrintSuatAn", "PhieuDangKySuatAn")";
            location.href = url;
        });
        //tbody_PB
        $("#thang,#nam").change(function () {
            loadPartiaViewBaoCaoPhanBo();
        });

        loadPartiaViewBaoCaoPhanBo();
    });

    function loadPartiaViewBaoCaoPhanBo() {
        var url = "@Url.Action("LoadDanhSachPhanBo", "PhieuDangKySuatAn")" + "?thang=" + $("#thang").val() + "&nam=" + $("#nam").val();
        var imageUrl = '<div id="divMsg" align="center"><img src="@Url.Content("~/Content/images/loading.gif")"/></div>';
        $('#tbody_PB').html(imageUrl);
        $('#tbody_PB').load(url, function () { });
    }

    function listFilter() {
        var giaTri = $("#pref-search").val().replace(/ /gi, '+');
        var url = "@Url.Action("ViewIndex", "PhieuDangKySuatAn")" + "?maCuaHang=" + $("#maCuaHang").val()
            + "&tuNgay=" + $("#tuNgay").val() + "&denNgay=" + $("#denNgay").val()
                                                                + "&searchString=" + giaTri
                                                                + "&_page=" + 1;
        var imageUrl = '<div id="divMsg" align="center"><img src="@Url.Content("~/Content/images/loading.gif")"/></div>';
        $('#content').html(imageUrl);
        $('#content').load(url, function () { });
    }
    function OnCriteria(page) {
        var giaTri = $("#pref-search").val().replace(/ /gi, '+');
        var url = "@Url.Action("ViewIndex", "PhieuDangKySuatAn")" + "?maCuaHang=" + $("#maCuaHang").val() + "&searchString=" + giaTri + "&tuNgay=" + $("#tuNgay").val() + "&denNgay=" + $("#denNgay").val()
                                                                + "&_page=" + page;
        var imageUrl = '<div id="divMsg" align="center"><img src="@Url.Content("~/Content/images/loading.gif")"/></div>';
        $('#content').html(imageUrl);
        $('#content').load(url, function () { });
    }


    function enterToSearch(event) {
        if (event.keyCode == 13) {
            listFilter();
        }
    }
    function InFileWorld(obj) {
        var li = $(obj).parent();
        var maPhieuSA = $(obj).attr("attrmaPhieu");

        var xhr = new XMLHttpRequest();
        xhr.open('POST', "/PhieuDangKySuatAn/PrintDocumentSuatAn", true);
        xhr.responseType = 'arraybuffer';
        xhr.onload = function () {
            if (this.status === 200) {
                var filename = "";
                var disposition = xhr.getResponseHeader('Content-Disposition');
                if (disposition && disposition.indexOf('attachment') !== -1) {
                    var filenameRegex = /filename[^;=\n]*=((['"]).*?\2|[^;\n]*)/;
                    var matches = filenameRegex.exec(disposition);
                    if (matches != null && matches[1]) filename = matches[1].replace(/['"]/g, '');
                }
                var type = xhr.getResponseHeader('Content-Type');

                var blob = new Blob([this.response], { type: type });
                if (typeof window.navigator.msSaveBlob !== 'undefined') {
                    // IE workaround for "HTML7007: One or more blob URLs were revoked by closing the blob for which they were created. These URLs will no longer resolve as the data backing the URL has been freed."
                    window.navigator.msSaveBlob(blob, filename);
                } else {
                    var URL = window.URL || window.webkitURL;
                    var downloadUrl = URL.createObjectURL(blob);

                    if (filename) {
                        // use HTML5 a[download] attribute to specify filename
                        var a = document.createElement("a");
                        // safari doesn't support this yet
                        if (typeof a.download === 'undefined') {
                            window.location = downloadUrl;
                        } else {
                            a.href = downloadUrl;
                            a.download = filename;
                            document.body.appendChild(a);
                            a.click();
                        }
                    } else {
                        window.location = downloadUrl;
                    }

                    setTimeout(function () { URL.revokeObjectURL(downloadUrl); }, 100); // cleanup
                }

            }
        };
        xhr.onloadstart = function (e) {
            li.html('<img src="/Images/progress.gif" />')
        };
        xhr.onloadend = function (e) {
            li.html(obj);
        };
        xhr.setRequestHeader('Content-type', 'application/x-www-form-urlencoded');
        xhr.send($.param({
            maPhieu: maPhieuSA
        }));
    }

    function ToDay() {
        $("#denNgay").data("DateTimePicker").date(moment());
        $("#tuNgay").data("DateTimePicker").date(moment());
    }
    function ToWeek() {
        $("#denNgay").data("DateTimePicker").date(moment());
        $("#tuNgay").data("DateTimePicker").date(moment().subtract(7, "day"));
    }
    function ToMonth() {
        $("#denNgay").data("DateTimePicker").date(moment());
        $("#tuNgay").data("DateTimePicker").date(moment().subtract(1, "month"));
    }
    

</script>
<style>
    .clsMauVay {
        background-color: #3197a3;
        color: #fff;
    }

    .clsMauBanGiao {
        background-color: #31a34a;
