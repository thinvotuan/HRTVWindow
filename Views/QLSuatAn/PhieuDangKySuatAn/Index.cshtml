    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var danhSachCuaHang = ViewBag.danhSachCuaHang as List<BatDongSan.Models.QLSuatAn.LuuVet.tbl_SA_CuaHang>;
}
