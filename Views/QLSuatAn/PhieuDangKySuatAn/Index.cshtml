                                        <input type="text" id="denNgay" class="form-control datepicker" placeholder="Đến ngày" style="width: 80px; float: left; margin-right: 5px" />
                                    </td>
                                    <td style="width: 35%">
                                        <div style="float: left">
                                            <a href="javascript:void(0)" onclick="ToDay()"><i class="fa fa-calendar" aria-hidden="true"></i>Hôm nay</a><a href="javascript:void(0)" onclick="ToWeek()"><i class="fa fa-calendar" aria-hidden="true"></i>7 ngày</a> <a href="javascript:void(0)" onclick="ToMonth()"><i class="fa fa-calendar" aria-hidden="true"></i>30 ngày</a>
                                        </div>
                                    </td>
                                     <td style="width: 15%"><b>Tên cửa hàng</b></td>
                                    <td style="width: 35%">
                                        @Html.DropDownList("maCuaHang", ViewBag.lstCuaHangs as SelectList, new { @class = "form-control" })
                                    </td>
                                </tr>
                                <tr class="background_tr">

                                   
                                    <td style="width: 15%"><b>Tìm kiếm</b></td>
                                    <td style="width: 35%">
                                        <div style="display: flex">
                                            <input type="text" class="form-control input-sm" style="width: 100%" id="pref-search" value="" onkeypress="enterToSearch(event)">
                                            <button id="btnSearch" type="button" class="btn btn-primary btn-sm" style="border: 1px double; margin-left: 5px">
                                                <span class="glyphicon glyphicon-search"></span>Tìm kiếm
                                            </button>
                                           
                                            @* <button class="btn btn-info" id="btnPrint" type="button" style="text-align:center"><i class="fa fa-print"></i>Print</button>*@
                                        </div>
                                    </td>
                                    <td colspan="2" style="text-align:right"> <button class="btn btn-info" id="btnModalCreate" type="button" data-toggle="modal" data-target="#customModal">Thêm </button></td>
                                </tr>

                            </table>
                        </div>
                    </div>

                    <div id="content">
                        @{Html.RenderPartial("PartialContent");}
                    </div>
                </div>
                <div class="contentToggle" style="display: none" id="tab-2">
                    <div id="filter-panel" class="collapse filter-panel" style="display: block; position: relative">
                        <div class="panel panel-default background_top">
                            <div class="panel-body">
                                <div style="line-height: 26px; float: left">
                                    <div style="float: left">
                                        Tháng:@Html.DropDownList("thang", ViewData["thangs"] as SelectList, new { @style = "" })
                                        Năm:@Html.DropDownList("nam", ViewData["nams"] as SelectList, new { @style = "" })
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="infor_PhanBo" style="display: none"></div>
                    <table style="width: 100%" class="table table-striped table-hover table-condensed tableThemeCustome">

                        <thead>
                            <tr>
                                <th style="width: 35px; text-align: center">STT
                                </th>
                                <th style="text-align: center">Mã cửa hàng
                                </th>
                                <th style="text-align: center">Tên cửa hàng</th>
                                <th style="text-align: center">Số lần ăn</th>
                                <th style="text-align: center">Công chuẩn</th>
                            </tr>
                        </thead>
                        <tbody id="tbody_PB">
                        </tbody>


                    </table>
                </div>
            </fieldset>
        </div>
    </div>
</form>
