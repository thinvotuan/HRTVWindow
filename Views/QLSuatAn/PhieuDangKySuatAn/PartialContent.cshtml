@using BatDongSan.Models.QLSuatAn;
@{    
   
    int page_ = Convert.ToInt32(ViewData["page"]);
    int total_ = Convert.ToInt32(ViewData["total"]);
    int i = 1;
    var danhSach = ViewBag.List as List<sp_NS_DanhSachPhieuDangKySuatAn_IndexResult>;
}
<style>
    .groupBoth {
        clear: both;
        float: none;
        margin: 10px 10px 10px 0;
        border: 1px solid rgba(204,204,204,.35);
        box-shadow: 0 1px 0 rgba(75,101,128,.25);
        overflow: hidden;
        padding: 10px;
    }

    .ViewTongQuan .trangThaiCanHo ul li {
        margin-bottom: 0px;
    }
</style>
<div class="ViewTongQuan">


    <div class="TongSoDong" style="clear: both">
        Trang @page_ của @(Convert.ToInt32(ViewData["totalRow"]) / 20 + 1) / @ViewData["totalRow"]
    </div>
    <div class="Page">

        @if (page_ > 1)
        {
       
            <a class="pageFirst" href="javascript:void(0)" onclick="javascript:OnCriteria(1);">First</a>
            <a class="pagePrevious" href="javascript:void(0)" onclick="javascript:OnCriteria(@(page_ - 1));">Previous</a>
       
        }       @if (page_ - 2 >= 1)
                { 
            <a class="pageCurrent" href="javascript:void(0)" onclick="javascript:OnCriteria(@(page_ - 2));">
                @(page_ - 2)</a> <a class="pageCurrent" href="javascript:void(0)" onclick="javascript:OnCriteria(@(page_ - 1));">
                    @(page_ - 1)</a>
                }<span class="pageActive">@page_</span>
        @if (page_ + 2 <= total_)
        { 
            <a class="pageCurrent" href="javascript:void(0)" onclick="javascript:OnCriteria(@(page_ + 1));">
                @(page_ + 1)</a> <a class="pageCurrent" href="javascript:void(0)" onclick="javascript:OnCriteria(@(page_ + 2));">
                    @(page_ + 2)</a>
        }
        @if (page_ < total_)
        {        
            <a class="pageNext" href="javascript:void(0)" onclick="javascript:OnCriteria(@(page_ + 1));">Next</a>
            <a class="pageLast" href="javascript:void(0)" onclick="javascript:OnCriteria(@total_);">Last</a>
       
        }
    </div>
  

    <table class="table table-striped table-hover table-condensed TableMobile TableInlineMobile" id="maintable" style="width: 100% !important">
        <style type="text/css">
            .color-money {
                font: bold;
                background-color: blue;
            }
        </style>
        <thead>
            <tr>
                <th>STT</th>
                <th>Mã phiếu</th>
                <th>Mã nhân viên</th>
                <th>Họ tên</th>
                <th>Cửa hàng</th>
                <th>Hình ảnh</th>
                <th>Lập phiếu</th>
                @* <th>Số suất ăn / cửa hàng</th>*@
               @* <th>Thao tác</th>*@
            </tr>
        </thead>
        <tbody>
            @* <tr style="font-weight: bold" class="tongtien removeBefore">
            <td colspan="3" style="text-align: center">Tổng cộng: @ViewData["totalRow"] dòng</td>
            <td style="text-align: right">@String.Format("{0:#,##0}", tongGiaSauVAT)</td>
            <td style="text-align: right">@String.Format("{0:#,##0}", tongGiaTriDaTT)</td>
            <td></td>
            <td style="text-align: right">@String.Format("{0:#,##0}", tongGiaTriConLai)</td>
            <td></td>
            <td></td>
            <td></td>
           
        </tr>*@
            @if (danhSach != null && danhSach.Count > 0)
            {
                foreach (var item in danhSach)
                {
                   
                
                
                <tr>
                    <td style="text-align: center">@i</td>
                    <td><a href="@Url.Action("Details", "PhieuDangKySuatAn", new { id = item.maPhieu })" target="_blank">@item.maPhieu</a></td>
                    <td>
                        @item.maNhanVien

                    </td>
                    <td>
                        @item.hoVaTen
                    </td>
                    <td>@item.tenCuaHang</td>
                    <td style="text-align: right">
                        <img src="@item.avatar" style="width:150px; height:100px; object-fit: contain;" />
                    </td>

                    <td style="text-align: left">@item.hoTenNguoiLap <br />@String.Format("{0:dd/MM/yyyy hh:mm:ss}",item.ngayLapPhieu)</td>
                   @* <td style="text-align: center">*@
                        @*<a class="btnEdit" alt="@item.maPhieu" data-toggle="modal" data-target="#customModal"  title ="Sửa phiếu"><i class="fa fa-pencil-square-o" style="font-size: 30px; color: orange; cursor: pointer;" aria-hidden="true">| </i></a>
                        *@@*<span>

                            <a class="btnPrint btnInFileWorld" alt="@item.maPhieu" onclick="InFileWorld(this)" attrmaPhieu="@item.maPhieu" title ="In phiếu"><i class="fa fa-print" style="font-size: 30px; color: #3197a3; cursor: pointer;" aria-hidden="true"></i></a>
                        </span>*@
                        @*<a class="btnDelete" alt="@item.maPhieu" title ="Xoá phiếu"><i class="fa fa-trash" style="font-size: 30px; color: red; cursor: pointer;" aria-hidden="true"></i></a>*@


                    @*</td>*@
                </tr>   
                    i++;
                }
            }

        </tbody>

    </table>
    <div class="TongSoDong">
        Trang @page_ của @(Convert.ToInt32(ViewData["totalRow"]) / 20 + 1) / @ViewData["totalRow"]
    </div>

    <div class="Page">

        @if (page_ > 1)
        {
       
            <a class="pageFirst" href="javascript:void(0)" onclick="javascript:OnCriteria(1);">First</a>
            <a class="pagePrevious" href="javascript:void(0)" onclick="javascript:OnCriteria(@(page_ - 1));">Previous</a>
       
        }       @if (page_ - 2 >= 1)
                { 
            <a class="pageCurrent" href="javascript:void(0)" onclick="javascript:OnCriteria(@(page_ - 2));">
                @(page_ - 2)</a> <a class="pageCurrent" href="javascript:void(0)" onclick="javascript:OnCriteria(@(page_ - 1));">
                    @(page_ - 1)</a>
                }<span class="pageActive">@page_</span>
        @if (page_ + 2 <= total_)
        { 
            <a class="pageCurrent" href="javascript:void(0)" onclick="javascript:OnCriteria(@(page_ + 1));">
                @(page_ + 1)</a> <a class="pageCurrent" href="javascript:void(0)" onclick="javascript:OnCriteria(@(page_ + 2));">
                    @(page_ + 2)</a>
        }
        @if (page_ < total_)
        {        
            <a class="pageNext" href="javascript:void(0)" onclick="javascript:OnCriteria(@(page_ + 1));">Next</a>
            <a class="pageLast" href="javascript:void(0)" onclick="javascript:OnCriteria(@total_);">Last</a>
       
        }
    </div>

</div>
<style>
    .pagination {
        font-size: 13px;
        color: Black;
        margin: 10px 0;
        display: inline-block;
    }

        .pagination span.current {
            /*background-color	: #FFFFFF; 	border				: 1px solid #FFFFFF; 	color				: #333333; 	font-weight			: bold; 	margin				: 2px; 	padding				: 2px 4px;*/
            background-color: #4D8AFF;
            color: #FFFFFF;
            font-weight: bold;
            margin: 2px;
            padding: 7px 11px;
            border-radius: 98px;
        }

    .pageActive, .pageCurrent:hover, .pageNext:hover, .pageLast:hover, .pageFirst:hover, .pagePrevious:hover {
        padding: 7px 11px;
        background-color: #4D8AFF;
        color: #FFFFFF;
        display: inline-block;
        border: 1px solid #80ABFF;
        border-radius: 20px;
        text-decoration: none;
        font-weight: bold;
    }

    .pageCurrent, .pageNext, .pageLast, .pageFirst, .pagePrevious {
        padding: 7px 11px;
        background-color: #fff;
        display: inline-block;
        border: 1px solid #80ABFF;
        border-radius: 20px;
        font-weight: bold;
    }

    .pagination a, .pagination a:link, .pagination a:active, .pagination a:visited {
        /*background-color	: #FFFFFF; 	border				: 1px solid #80ABFF; 	font-weight			: bold; 	margin				: 2px; 	padding				: 2px 4px; 	text-decoration		: none;*/
        background-color: #FFFFFF;
        border: 1px solid #80ABFF;
        font-weight: bold;
        margin: 2px;
        padding: 7px 11px;
        text-decoration: none;
        border-radius: 20px;
    }

        .pagination a:hover, .pagination a:focus {
            /*background-color	: #4D8AFF; 	border				: 1px solid #0057FF; 	color				: #FFFFFF;*/
            background-color: #4D8AFF;
            border: 1px solid #0057FF;
            color: #FFFFFF;
        }
</style>
