@using BatDongSan.Models.HeThong;
@model tbl_DM_TienIchTheme
<script src="~/Scripts/autoNumeric.js"></script>
 <link href="~/Scripts/colorpicker/dist/css/bootstrap-colorpicker.min.css" rel="stylesheet">
    <link href="~/Scripts/colorpicker/dist/css/bootstrap-colorpicker-plus.css" rel="stylesheet">
<script src="~/Scripts/colorpicker/dist/js/bootstrap-colorpicker.min.js"></script>
    <script src="~/Scripts/colorpicker/dist/js/bootstrap-colorpicker-plus.js"></script>
<script type="text/javascript">
    $(document).ready(function () {
        $(".numberinput").autoNumeric('init', { mDec: 0, lZero: 'deny', aSep: ',', aDec: '.', pSign: 's', vMin: '0', vMax: '10' });
        $("#maMau").keyup(function () {
          
            var maMau = $("#maMau").val();
            $(".mauXemTruoc").css("background-color", maMau)
        });

      
        var demo3 = $('.colorpickerplus-embed .colorpickerplus-container');
        demo3.colorpickerembed();
        demo3.on('changeColor', function (e) {
            var maMau = $(".colorpicker-element").val();
            $("#maMau").val(maMau);
            $(".mauXemTruoc").css("background-color", maMau)
            if (e.color == null)
                $('#demo3').val('transparent').css('background-color', '#fff');//tranparent
            else
                $('#demo3').val(e.color).css('background-color', e.color);
        });
  
       
    })
</script>
<style>
    input.colorpicker-element
    {
        width: 136px !important;
    }
    .colorpickerplus-embed .input-group-sm
    {
       width: 138px !important;
    }
    .colorpickerplus-embed .input-group-sm .input-group-btn
    {
      float: right;
      height: 18px;
    }
    .colorpickerplus-embed .input-group-sm .input-group-btn .btn-default
    {
        
    height: 24px;

    }
</style>


<div class="bs-callout bs-callout-info" id="callout-glyphicons-location">
    <h4 style="color: #1b809e; margin-left: 10px">Thêm mới Theme</h4>
</div>
<div style="margin-top: 15px">
    <table class="table table-striped table-hover table-condensed" style="width:100%" id="tbl-create">
        @Html.HiddenFor(model => model.maMau, new { @class = "form-control", required = "required" })
        <tr>
            <td  class="tdtitle">Tên</td>
            <td>@Html.TextBoxFor(model => model.ten, new { @class = "form-control"})</td>
        </tr>
        
        <tr>
            <td  class="tdtitle">
               Chọn màu
            </td>
             <td>
             
        <div class="colorpickerplus-embed">
          <div class="colorpickerplus-container"></div>
        </div>

          
            </td>

        </tr>
        <tr>
           
        </tr>
        <tr>
            <td  class="tdtitle">Xem trước</td>
            <td class="mauXemTruoc"></td>
        </tr>
        
        
    </table>
</div>

<style>
    #tbl-create td
    {
        border: none;
    }

    #tbl-create
    {
        margin: 0;
    }

    #tbl-mota td
    {
        border: none;
    }
</style>
