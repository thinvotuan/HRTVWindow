@using BatDongSan
@model IPagedList<BatDongSan.Models.DanhMuc.sp_DanhMucNhomDanhGia_IndexResult>
@{
    Layout = null;
    int i = 1;
    string[] parameters = TempData["Params"].ToString().Split(',');
    BatDongSan.Models.HeThong.Sys_User user1 = new BatDongSan.Models.HeThong.Sys_User();
    if (Session["User"] != null)
    {
        user1 = (BatDongSan.Models.HeThong.Sys_User)Session["User"];
    }
}
<style>
    td
    {
        border: none;
    }
</style>
<script type="text/javascript">
    $(document).ready(function () {
        $('#btnSearch').click(function () {
            var searchText = $('#searchString').val().replace(/\ /g, '+');
            var url = "@Url.Action("Index", "DMNhomDanhGia")" + "?searchString=" + searchText;
            beginPaging();
            $('#content').html('<h4>Loading...</h4>').load(url);
            successPaging();
        });


        $(document).on("click", ".btnCapNhatDSDK", function () {
            var url = "@Url.Action("Create", "DMNhomDanhGia")" + "/" + this.value;
            location.href = url;
        })

        $(".btnThamGiaDT").click(function () {
            var url = "@Url.Action("Create", "DMNhomDanhGia")" + "/" + this.value;
            location.href = url;
        })

        $('.btnChon').click(function () {
            var selected = $(this).parent();
            if (selected.length != 0) {
                var hoten = selected.find('#hoten').val();
                var manv = selected.find('#manhanvien').val();
                $('#nhanvien').val(hoten);
                $('#manv').val(manv);
                //$('.panel-default').html('');
            }
            //$('#filter-panel').removeClass('in');
        })
    })
</script>
<table class="table table-striped table-hover table-condensed" id="maintable">
    <thead>
        <tr>
            <th style="text-align: center; width: 45px">STT</th>
            <th style="text-align: center; width: 150px">Mã nhóm đánh giá</th>
            <th style="text-align: center; width: 150px">Tên nhóm đánh giá</th>
            <th style="text-align: center; width: 150px">Phòng ban</th>
            <th style="text-align: center; width: 200px">Ghi chú</th>
            <th style="width: 83px"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {                                                        
            <tr>
                <td style="text-align: center">@item.NUMBER</td>
                <td style="text-align: left">
                    <i class="fa fa-clipboard"></i><a style="color:blue" href="@Url.Action("Details", "DMNhomDanhGia", new { id = item.maNhomDanhGia })">@item.maNhomDanhGia</a>
                    <br />
                    <i class="fa fa-credit-card" aria-hidden="true"></i>@item.hoTenNguoiLap
                    <br />
                    <i class="fa fa-calendar" aria-hidden="true"></i>@String.Format("{0: dd/MM/yyyy}", item.ngayLap)
                </td>
                <td style="text-align: left">@item.tenNhomDanhGia</td>
                <td style="text-align: left">@item.tenPhongBan
                    <br />
                    <i class="fa fa-ticket" aria-hidden="true"></i>@item.tenChucDanh
                </td>
                <td style="text-align: left">@Html.Raw(item.ghiChu)</td>
                <td style="text-align: right">
                    @if (item.nguoiLap == user1.manv)
                    {
                        <button class="btn btn-primary btn-xs btnEdit" title="Sửa" value="@item.maNhomDanhGia" type="button">Sửa</button>
                        <button class="btn btn-warning btn-xs btnDelete" title="Xóa" value="@item.maNhomDanhGia" type="button">Xóa</button>
                    }
                </td>
            </tr> 
                    i++;
        }
    </tbody>
</table>
<div>
    Trang @Model.PageNumber của @Model.PageCount / @ViewBag.Count
</div>
<div>
    <ul class="pagination">
        @Html.Raw(Ajax.Pager(new AjaxOptions { UpdateTargetId = "content", OnBegin = "beginPaging", OnSuccess = "successPaging", OnFailure = "failurePaging" }, Model.PageSize, Model.PageNumber, Model.TotalItemCount,
        new { controller = "DMNhomDanhGia", action = "Index", searchString = parameters[0] }))
    </ul>
</div>

