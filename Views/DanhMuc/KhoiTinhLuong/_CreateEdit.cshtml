@using BatDongSan.Models.DanhMuc;
@model tbl_NS_KhoiTinhLuong
<div class="bs-callout bs-callout-info" id="callout-glyphicons-location">
    <h4 style="color: #1b809e; margin-left: 10px">@ViewBag.TitleHead khối tính lương</h4>
</div>
<div style="margin-top: 15px">
    <table class="table table-responsive" id="tbl-create">
        <tr>
            <td>Mã cha</td>
            <td>@Html.DropDownListFor(model => model.maCha, ViewBag.KhoiTinhLuong as SelectList, new { @class = "form-control" })</td>
        </tr>
        <tr>
            <td>Tên khối tính lương <span style="font-style: italic; color: red">*</span></td>
            <td>@Html.TextBoxFor(model => model.tenKhoiTinhLuong, new { @class = "form-control", required = "required" })</td>
        </tr>
        <tr>
            <td>Khối đề nghị chi lương</td>
            <td>@Html.DropDownListFor(model => model.maKhoiDeNghiChiLuong, ViewBag.KhoiChiLuongs as SelectList, new { @class = "form-control" })</td>
        </tr>
        <tr>
            <td>Ghi chú </td>
            <td>@Html.TextBoxFor(model => model.ghiChu, new { @class = "form-control" })</td>
        </tr>
    </table>
</div>
<style>
    #tbl-create td {
        border: none;
    }

    #tbl-create {
        margin: 0;
    }
</style>
