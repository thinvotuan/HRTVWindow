@using BatDongSan.Models.DanhMuc
@model IList<tbl_DM_TaiLieu>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int i = 1;
    tbl_DM_TaiLieu taiLieu = ViewBag.TaiLieu;
}
<script src="~/Scripts/moment.min.js"></script>
<style>
    #content td
    {
        border-bottom: 1px inset #ADC2D6;
        position: relative;
        text-align: center;
    }
</style>
<script type="text/javascript">
    $(document).ready(function () {
        $("#btnModalCreate").click(function () {
            var url = "@Url.Action("Create", "TaiLieuAdmin")";
            var form = document.getElementById("form-submit");
            form.action = url;
            $("#custom-panel").load(url)
        })

        $("#customModal").on("hide.bs.modal", function () {
            $("#custom-panel").html("");
        });        

        $(document).on("click", ".btnDelete", function () {
            var url = "@Url.Action("Delete", "TaiLieuAdmin")" + "/" + this.value;
            var form = document.getElementById("form-listview");
            form.method = "post";
            form.action = url;
            form.submit();
        })
    });

</script>
<form id="form-listview">
    <div id="container">
        <fieldset class="removeBorderFieldset">
            <div id="tabs" style="" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                    <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active"><a><span>Danh sách bằng cấp</span></a></li>
                </ul>
            </div>
            <div id="filter-panel" class="collapse filter-panel" style="display: block">
                <div class="panel panel-default background_top">
                    <div class="panel-body">
                        <div class="form-group" style="float: right">
                            <input type="hidden" id="nguoiUpLoad" name="nguoiUpLoad" value="@taiLieu.tenNguoiUpload" />
                            <button class="btn btn-info" id="btnModalCreate" type="button" data-toggle="modal" data-target="#customModal">Thêm </button>
                        </div>
                    </div>
                </div>
            </div>
            <div id="content">
                <table class="table table-striped table-hover table-condensed" id="maintable">
                    <thead>
                        <tr>
                            <th style="text-align: center; width: 45px">STT</th>
                            <th>Tên tài liệu</th>
                            <th>Người upload</th>
                            <th>Ngày upload</th>
                            <th style="width: 83px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td style="text-align: center">@i</td>
                                <td style="text-align:left ;color:#519ee5">@item.tenTaiLieu</td>
                                <td>@item.tenNguoiUpload</td>
                                <td>@item.ngayLap.Value.ToString("dd/MM/yyyy")</td>
                                <td style="text-align: right">
                                    <button class="btn btn-warning btn-xs btnDelete" type="button" value="@item.id">Xóa</button>
                                </td>
                            </tr> 
                            i++;
                        }
                    </tbody>
                </table>
            </div>
            <div style="text-align: center; display: none" id="loader">
                <img src="/Images/loader.gif" />
            </div>
        </fieldset>
    </div>
</form>
<form id="form-submit" method="post">
    <!--------------------------- Modal - Thêm Sửa Modal Form ------------------------>
    <div id="customModal" class="modal fade" role="dialog">
        <div class="modal-dialog">
            <!-- Modal content-->
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title"></h4>
                  </div>
                <div class="modal-body">
                    <div class="container" style="width: 100%">
                        <div class="row">
                            <div id="custom-panel" class="filter-panel">
                                <table class="table table-condensed table-responsive" id="tbl-uploading">
                                    <tbody>
                                        <tr>
                                            <td colspan="4">
                                                <input type="file" name="files" id="files" class="form-control" /></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-primary" id="btnSubmit">Lưu</button>
                        <button type="button" class="btn btn-default" data-dismiss="modal" id="btnCloseEmail">Đóng</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
