                         @*   <button class="btn btn-info btn-xs" type="button" id="btnReload">Tải lại</button>*@
                            
                            <input type="hidden" id="flag" name="flag" />
                        </div>
                    </td>
                    <td style="width: 70%; padding-left: 3px; box-sizing: border-box; vertical-align: top">
                      
                            <div style="padding: 5px; padding-right: 0px; background-color: #DADEE4; overflow:hidden;">
                                <div style="width: 389px;float: left;">
                                <div style="float:left;">Nhập mã hoặc tên:</div>
                               
                               
                                 <div class="input-group">
